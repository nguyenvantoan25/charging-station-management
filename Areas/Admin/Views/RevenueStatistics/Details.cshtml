@model tramsac99.Areas.Admin.Models.PaymentTransaction
@using tramsac99.Areas.Admin.Models
@{
    ViewData["Title"] = "Chi tiết giao dịch";
    var activityAt = Model.PaidAt ?? Model.CancelledAt ?? Model.CreatedAt;
    var stationName = Model.Station?.Name ?? Model.RegistrationRequest?.StationName ?? "-";
    var ownerName = Model.User?.FullName ?? Model.User?.Username ?? Model.User?.Email ?? "-";
    var statusClass = Model.Status == PaymentTransactionStatus.Paid || Model.Status == "success" || Model.Status == "paid" ? "success" :
        Model.Status == PaymentTransactionStatus.Pending || Model.Status == "pending" ? "warning" : "danger";
}

@section Styles {
    <style>
        .transaction-detail-page { padding: 22px 8px 36px; }
        .detail-card { border:0; border-radius:24px; box-shadow:0 18px 48px rgba(15,23,42,.08); overflow:hidden; }
        .detail-header { background:linear-gradient(135deg,#064e3b,#0f766e); color:#fff; padding:24px; display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; }
        .detail-title { margin:0; font-size:28px; font-weight:950; }
        .detail-subtitle { margin:6px 0 0; color:rgba(255,255,255,.82); }
        .detail-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:16px; padding:22px; }
        .detail-item { background:#f8fafc; border:1px solid #e2e8f0; border-radius:18px; padding:16px; }
        .detail-label { color:#64748b; font-size:13px; font-weight:900; text-transform:uppercase; margin-bottom:6px; }
        .detail-value { color:#0f172a; font-size:18px; font-weight:900; word-break:break-word; }
        .detail-value.money { color:#16a34a; font-size:26px; }
        @@media(max-width:767.98px){ .detail-grid{grid-template-columns:1fr;} }
    </style>
}

<section class="content transaction-detail-page">
    <div class="container-fluid">
        <div class="detail-card bg-white">
            <div class="detail-header">
                <div>
                    <h1 class="detail-title">Chi tiết giao dịch</h1>
                    <p class="detail-subtitle">Mã giao dịch: @(Model.PayOsOrderCode?.ToString() ?? $"GD{Model.Id:D6}")</p>
                </div>
                <a class="btn btn-light font-weight-bold" asp-area="Admin" asp-controller="RevenueStatistics" asp-action="Index">
                    <i class="fas fa-arrow-left"></i> Quay lại thống kê
                </a>
            </div>
            <div class="detail-grid">
                <div class="detail-item"><div class="detail-label">Số tiền</div><div class="detail-value money">@Model.Amount.ToString("N0")đ</div></div>
                <div class="detail-item"><div class="detail-label">Trạng thái</div><div class="detail-value"><span class="badge badge-@statusClass px-3 py-2">@Model.Status</span></div></div>
                <div class="detail-item"><div class="detail-label">Loại phí</div><div class="detail-value">@PaymentTransactionType.ToDisplay(Model.PaymentType)</div></div>
                <div class="detail-item"><div class="detail-label">Phương thức</div><div class="detail-value">@(Model.PayOsOrderCode.HasValue ? "PayOS" : "Hệ thống")</div></div>
                <div class="detail-item"><div class="detail-label">Chủ trạm</div><div class="detail-value">@ownerName</div></div>
                <div class="detail-item"><div class="detail-label">Trạm sạc</div><div class="detail-value">@stationName</div></div>
                <div class="detail-item"><div class="detail-label">Thời gian tạo</div><div class="detail-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="detail-item"><div class="detail-label">Thời gian xử lý</div><div class="detail-value">@activityAt.ToString("dd/MM/yyyy HH:mm")</div></div>
                <div class="detail-item"><div class="detail-label">Mô tả</div><div class="detail-value">@(Model.Description ?? "-")</div></div>
                <div class="detail-item"><div class="detail-label">Ghi chú</div><div class="detail-value">@(Model.Note ?? "-")</div></div>
            </div>
        </div>
    </div>
</section>
