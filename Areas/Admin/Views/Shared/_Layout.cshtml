@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using tramsac99.Areas.Admin.Models
@inject tramsac99.Data.AppDbContext DbContext

@{
    var currentAdminIdRaw = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int.TryParse(currentAdminIdRaw, out var currentAdminId);

    var currentAdmin = currentAdminId > 0
        ? DbContext.AppUsers.AsNoTracking().FirstOrDefault(x => x.Id == currentAdminId)
        : null;

    var adminDisplayName = !string.IsNullOrWhiteSpace(currentAdmin?.FullName)
        ? currentAdmin!.FullName!
        : (!string.IsNullOrWhiteSpace(currentAdmin?.Username) ? currentAdmin!.Username : "Admin");

    var adminRole = !string.IsNullOrWhiteSpace(currentAdmin?.Role) ? currentAdmin!.Role : "Admin";

    var adminInitial = !string.IsNullOrWhiteSpace(adminDisplayName)
        ? adminDisplayName.Trim()[0].ToString().ToUpper()
        : "A";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TramSac99 Admin | @ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Montserrat:wght@600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css" />
    <link rel="stylesheet" href="~/admin/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css" />
    <link rel="stylesheet" href="~/admin/plugins/icheck-bootstrap/icheck-bootstrap.min.css" />
    <link rel="stylesheet" href="~/admin/plugins/jqvmap/jqvmap.min.css" />
    <link rel="stylesheet" href="~/admin/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/admin/plugins/overlayScrollbars/css/OverlayScrollbars.min.css" />
    <link rel="stylesheet" href="~/admin/plugins/daterangepicker/daterangepicker.css" />
    <link rel="stylesheet" href="~/admin/plugins/summernote/summernote-bs4.min.css" />
    <link rel="stylesheet" href="~/css/admin-enterprise.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/css/vinfast-premium-admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-icon-fix.css" asp-append-version="true" />
</head>

<body class="hold-transition sidebar-mini layout-fixed admin-theme-green">
    <div class="wrapper">
        <div class="preloader flex-column justify-content-center align-items-center">
            <img class="animation__shake" src="~/admin/dist/img/AdminLTELogo.png" alt="AdminLTELogo" height="60" width="60">
        </div>

        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link">Tổng quan</a>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto align-items-center">
                <li class="nav-item mr-2">
                    <a asp-area="Admin" asp-controller="User" asp-action="Edit" asp-route-id="@currentAdminId" class="admin-topbar-profile">
                        @if (!string.IsNullOrWhiteSpace(currentAdmin?.AvatarUrl))
                        {
                            <span class="admin-topbar-avatar">
                                <img src="@currentAdmin.AvatarUrl" alt="Admin Avatar">
                            </span>
                        }
                        else
                        {
                            <span class="admin-topbar-avatar-fallback">@adminInitial</span>
                        }

                        <span class="admin-topbar-meta">
                            <span class="admin-topbar-name">@adminDisplayName</span>
                            <span class="admin-topbar-role">@adminRole</span>
                        </span>
                    </a>
                </li>

                <li class="nav-item mr-2">
                    <a class="admin-topbar-btn" data-widget="fullscreen" href="#" role="button" title="Toàn màn hình">
                        <i class="fas fa-expand-arrows-alt"></i>
                    </a>
                </li>

                <li class="nav-item">
                    <form asp-area="User" asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="admin-topbar-logout">
                            <i class="fas fa-arrow-right mr-2"></i>Đăng xuất
                        </button>
                    </form>
                </li>
            </ul>
        </nav>

        @{
            var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        }

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="brand-link">
                <img src="~/admin/dist/img/AdminLTELogo.png" alt="Logo" class="brand-image img-circle elevation-3" style="opacity: .9">
                <span class="brand-text font-weight-light">TramSac99</span>
            </a>

            <div class="sidebar">
                <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                    <div class="image">
                        @if (!string.IsNullOrWhiteSpace(currentAdmin?.AvatarUrl))
                        {
                            <img src="@currentAdmin.AvatarUrl" class="img-circle elevation-2" alt="Admin Image" style="width:34px;height:34px;object-fit:cover;">
                        }
                        else
                        {
                            <div style="width:34px;height:34px;border-radius:50%;background:#f4f6f7;color:#20302a;display:flex;align-items:center;justify-content:center;font-weight:800;">@adminInitial</div>
                        }
                    </div>
                    <div class="info">
                        <a asp-area="Admin" asp-controller="User" asp-action="Edit" asp-route-id="@currentAdminId" class="d-block">@adminDisplayName</a>
                    </div>
                </div>

                <div class="form-inline">
                    <div class="input-group" data-widget="sidebar-search">
                        <input class="form-control form-control-sidebar" type="search" placeholder="Tìm nhanh" aria-label="Search">
                        <div class="input-group-append">
                            <button class="btn btn-sidebar">
                                <i class="fas fa-search fa-fw"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "Dashboard" ? "active" : "")">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>Tổng quan</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="RevenueStatistics" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "RevenueStatistics" ? "active" : "")">
                                <i class="nav-icon fas fa-chart-line"></i>
                                <p>Thống kê doanh thu</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Station" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "Station" ? "active" : "")">
                                <i class="nav-icon fas fa-charging-station"></i>
                                <p>Quản lý trạm sạc</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="StationRequest" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "StationRequest" ? "active" : "")">
                                <i class="nav-icon fas fa-clipboard-check"></i>
                                <p>Xác nhận trạm sạc</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="ChargingPole" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "ChargingPole" ? "active" : "")">
                                <i class="nav-icon fas fa-plug"></i>
                                <p>Quản lý trụ sạc</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="User" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "User" ? "active" : "")">
                                <i class="nav-icon fas fa-users"></i>
                                <p>Quản lý người dùng</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="PaymentTransaction" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "PaymentTransaction" ? "active" : "")">
                                <i class="nav-icon fas fa-receipt"></i>
                                <p>Lịch sử giao dịch</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-area="Admin" asp-controller="Support" asp-action="Index" class="nav-link @(currentArea == "Admin" && currentController == "Support" ? "active" : "")">
                                <i class="nav-icon fas fa-headset"></i>
                                <p>Hỗ trợ</p>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="content-wrapper">
            @RenderBody()
        </div>
    </div>

    <script src="~/admin/plugins/jquery/jquery.min.js"></script>
    <script src="~/admin/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script>
        $.widget.bridge('uibutton', $.ui.button)
    </script>
    <script src="~/admin/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/admin/plugins/chart.js/Chart.min.js"></script>
    <script src="~/admin/plugins/sparklines/sparkline.js"></script>
    <script src="~/admin/plugins/jqvmap/jquery.vmap.min.js"></script>
    <script src="~/admin/plugins/jqvmap/maps/jquery.vmap.usa.js"></script>
    <script src="~/admin/plugins/jquery-knob/jquery.knob.min.js"></script>
    <script src="~/admin/plugins/moment/moment.min.js"></script>
    <script src="~/admin/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="~/admin/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/admin/plugins/summernote/summernote-bs4.min.js"></script>
    <script src="~/admin/plugins/overlayScrollbars/js/jquery.overlayScrollbars.min.js"></script>
    <script src="~/admin/dist/js/adminlte.min.js"></script>
    <script src="~/js/pagination.js"></script>
    <script src="~/js/map4d-common.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

