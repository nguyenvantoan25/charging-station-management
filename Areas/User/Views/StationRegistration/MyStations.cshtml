@model tramsac99.Areas.User.ViewModels.MyStationDashboardViewModel
@using tramsac99.Areas.Admin.Models

@{
    ViewData["Title"] = "Trạm của tôi";

    var approvedRegistrations = Model.RegistrationRequests.Count(x =>
        x.CreatedStationId.HasValue || x.PaymentStatus == "Đã thanh toán");

    var inactiveStations = Model.Stations.Count(x => StationOperationStatus.Normalize(x.OperationStatus) == StationOperationStatus.Inactive);
    var totalPoles = Model.Stations.Sum(x => x.ChargingPoles.Count);
    var maintenanceStations = Model.Stations.Count(x => StationOperationStatus.Normalize(x.OperationStatus) == StationOperationStatus.Maintenance);
    var errorStations = Model.Stations.Count(x => StationOperationStatus.Normalize(x.OperationStatus) == StationOperationStatus.Error);
}

@section Styles {
    <link rel="stylesheet" href="~/user/assets/css/station-workflow.css" asp-append-version="true" />
}

<div class="sub_banner_outer position-relative user-header-shell">
    @await Html.PartialAsync("_UserHeader")
</div>

<section class="station-workflow-page station-my-unified-page">
    <div class="container station-workflow-shell">
        <div class="station-dashboard-card station-unified-hero mb-4">
            <div class="card-body">
                <div class="station-unified-hero__content">
                    <div class="station-unified-hero__left">
                        <span class="station-unified-hero__icon">
                            <i class="fa-solid fa-charging-station"></i>
                        </span>
                        <div>
                            <h1 class="station-page-title mb-2">Trạm của tôi</h1>
                            @* <p class="station-page-subtitle mb-0">
                                Theo dõi hồ sơ đăng ký, danh sách trạm sở hữu, phí duy trì và thao tác vận hành trực tiếp trên cùng một màn hình.
                            </p> *@
                        </div>
                    </div>

                    <div class="station-unified-hero__actions">
                        <a asp-area="User" asp-controller="StationRegistration" asp-action="Register" class="station-btn text-decoration-none">
                            <i class="fa-solid fa-plus"></i>
                            Đăng ký thêm trạm
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="station-unified-stats mb-4">
            <div class="station-stat-card">
                <div class="station-unified-stat__icon is-blue">
                    <i class="fa-regular fa-building"></i>
                </div>
                <div class="station-stat-label">Tổng số trạm</div>
                <div class="station-stat-value">@Model.TotalOwnedStations</div>
            </div>

            <div class="station-stat-card">
                <div class="station-unified-stat__icon is-yellow">
                    <i class="fa-regular fa-clock"></i>
                </div>
                <div class="station-stat-label">Hồ sơ đang xử lý</div>
                <div class="station-stat-value">@Model.PendingRegistrations</div>
            </div>

            <div class="station-stat-card">
                <div class="station-unified-stat__icon is-green">
                    <i class="fa-regular fa-circle-check"></i>
                </div>
                <div class="station-stat-label">Đã được duyệt</div>
                <div class="station-stat-value">@approvedRegistrations</div>
            </div>

            <div class="station-stat-card">
                <div class="station-unified-stat__icon is-slate">
                    <i class="fa-solid fa-power-off"></i>
                </div>
                <div class="station-stat-label">Không hoạt động</div>
                <div class="station-stat-value">@inactiveStations</div>
            </div>

            <div class="station-stat-card">
                <div class="station-unified-stat__icon is-mint">
                    <i class="fa-solid fa-bolt"></i>
                </div>
                <div class="station-stat-label">Trụ đang hoạt động</div>
                <div class="station-stat-value">@Model.ActivePoles</div>
            </div>

            <div class="station-stat-card">
                <div class="station-unified-stat__icon is-dark">
                    <i class="fa-solid fa-charging-station"></i>
                </div>
                <div class="station-stat-label">Tổng số trụ</div>
                <div class="station-stat-value">@totalPoles</div>
            </div>
        </div>

        @await Html.PartialAsync("_MyStationTabs")

        @if (TempData["StationRequestSuccess"] != null)
        {
            <div class="station-alert success">@TempData["StationRequestSuccess"]</div>
        }

        @if (TempData["StationRequestError"] != null)
        {
            <div class="station-alert error">@TempData["StationRequestError"]</div>
        }

        <div class="station-tab-panels">
            <div id="station-tab-list" class="station-tab-panel active">
                <div class="station-list-card mb-4" id="my-station-managed-list">
                    <div class="card-head">
                        <div class="station-unified-head">
                            <div>
                                <h3 class="mb-1 font-weight-bold">Danh sách trạm của tôi</h3>
                                <div class="text-muted">Quản lý tập trung, tìm nhanh theo tên trạm và lọc theo trạng thái để thao tác gọn hơn.</div>
                            </div>

                            <div class="station-unified-toolbar">
                                <div class="station-unified-search">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                    <input id="myStationSearch" type="text" class="station-input" placeholder="Tìm kiếm theo tên trạm, địa chỉ..." />
                                </div>

                                <select id="myStationStatusFilter" class="station-select">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="@StationOperationStatus.Active">Đang hoạt động</option>
                                    <option value="@StationOperationStatus.Error">Lỗi</option>
                                    <option value="@StationOperationStatus.Maintenance">Bảo trì</option>
                                    <option value="@StationOperationStatus.Inactive">Không hoạt động</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="station-unified-counter">
                            Hiển thị <strong id="myStationVisibleCount">@Model.Stations.Count</strong> trạm
                        </div>

                        @if (!Model.Stations.Any())
                        {
                            <div class="station-unified-empty">
                                <i class="fa-regular fa-folder-open"></i>
                                <span>Chưa có trạm nào thuộc quyền quản lý của bạn.</span>
                            </div>
                        }
                        else
                        {
                            <div id="myStationList">
                                @foreach (var station in Model.Stations)
                                {
                                    var latestOperation = Model.OperationRequests
                                    .Where(x => x.StationId == station.Id)
                                    .OrderByDescending(x => x.CreatedAt)
                                    .FirstOrDefault();

                                    var phoneNumber = Model.RegistrationRequests
                                    .FirstOrDefault(x => x.CreatedStationId == station.Id)?.ContactPhone ?? "-";

                                    var systemStatus = StationSystemStatus.Normalize(station.SystemStatus);
                                    var operationStatus = StationOperationStatus.Normalize(string.IsNullOrWhiteSpace(station.OperationStatus) ? station.Status : station.OperationStatus);
                                    var operationStatusText = StationOperationStatus.ToDisplay(operationStatus);
                                    var maintenanceStatus = StationMaintenanceStatus.Normalize(station.MaintenanceFeeStatus);
                                    var maintenanceDue = StationMaintenanceStatus.CanPayMaintenance(maintenanceStatus);
                                    var maintenanceChipClass = maintenanceStatus switch
                                    {
                                        var s when s == StationMaintenanceStatus.Paid || s == StationMaintenanceStatus.Active => "station-chip",
                                        var s when s == StationMaintenanceStatus.Pending || s == StationMaintenanceStatus.ExpiringSoon => "station-chip-warning",
                                        var s when s == StationMaintenanceStatus.Unpaid || s == StationMaintenanceStatus.Expired || s == StationMaintenanceStatus.MaintenanceUnpaid => "station-chip-danger",
                                        var s when s == StationMaintenanceStatus.Hidden => "station-chip-soft",
                                        var s when s == StationMaintenanceStatus.Locked => "station-chip-danger",
                                        _ => "station-chip-soft"
                                    };
                                    var maintenanceStatusText = StationMaintenanceStatus.ToDisplay(maintenanceStatus);
                                    var maintenanceDueDateText = station.MaintenanceFeeDueDate.HasValue ? station.MaintenanceFeeDueDate.Value.ToString("dd/MM/yyyy HH:mm") : "-";
                                    var remainingDays = station.MaintenanceFeeDueDate.HasValue ? Math.Ceiling((station.MaintenanceFeeDueDate.Value - DateTime.Now).TotalDays) : 0;
                                    var canPayMaintenance = StationMaintenanceStatus.CanPayMaintenance(maintenanceStatus);

                                    var statusChipClass = operationStatus switch
                                    {
                                        var s when s == StationOperationStatus.Active => "station-chip",
                                        var s when s == StationOperationStatus.Maintenance => "station-chip-warning",
                                        var s when s == StationOperationStatus.Error => "station-chip-danger",
                                        var s when s == StationOperationStatus.Inactive => "station-chip-soft",
                                        _ => "station-chip-soft"
                                    };
                                    var lockedByAdmin = systemStatus == StationSystemStatus.Locked || maintenanceStatus == StationMaintenanceStatus.Locked;

                                    <div class="station-unified-row"
                                         data-search="@($"{station.Name} {station.Address}".ToLowerInvariant())"
                                         data-status="@operationStatus">
                                        <div class="station-unified-row__thumb">
                                            <div class="station-unified-row__thumb-inner">
                                                <i class="fa-solid fa-charging-station"></i>
                                            </div>
                                        </div>

                                        <div class="station-unified-row__main">
                                            <div class="station-unified-row__top">
                                                <div>
                                                    <div class="station-unified-row__title-wrap">
                                                        <h4 class="station-card-title mb-0">@station.Name</h4>
                                                        <span class="station-unified-row__code">TRAM-@station.Id.ToString("D3")</span>
                                                    </div>

                                                    <div class="station-unified-row__address">
                                                        <i class="fa-solid fa-location-dot"></i>
                                                        <span>@station.Address</span>
                                                    </div>
                                                    @if (!station.IsVisible || maintenanceStatus == StationMaintenanceStatus.Hidden || maintenanceStatus == StationMaintenanceStatus.Unpaid || maintenanceStatus == StationMaintenanceStatus.Expired || maintenanceStatus == StationMaintenanceStatus.MaintenanceUnpaid)
                                                    {
                                                        <div class="station-unified-note mt-2">
                                                            <strong>Cảnh báo:</strong> Trạm đang tạm ẩn vì chưa thanh toán phí duy trì. Chủ trạm vẫn xem được, người dùng thường sẽ không thấy trên bản đồ/lộ trình.
                                                        </div>
                                                    }
                                                </div>

                                                <span class="@statusChipClass">@operationStatusText</span>
                                                <span class="station-chip-soft">@StationSystemStatus.ToDisplay(systemStatus)</span>
                                            </div>

                                            <div class="station-unified-metrics">
                                                <div class="station-unified-metric">
                                                    <i class="fa-regular fa-credit-card"></i>
                                                    <div>
                                                        <span>Số trụ</span>
                                                        <strong>@station.ChargingPoles.Count</strong>
                                                    </div>
                                                </div>

                                                <div class="station-unified-metric">
                                                    <i class="fa-solid fa-wave-square"></i>
                                                    <div>
                                                        <span>Vận hành</span>
                                                        <strong>@operationStatusText</strong>
                                                    </div>
                                                </div>

                                                <div class="station-unified-metric">
                                                    <i class="fa-regular fa-calendar"></i>
                                                    <div>
                                                        <span>Nhật ký gần nhất</span>
                                                        <strong>@(latestOperation?.CreatedAt.ToString("dd-MM-yyyy") ?? "-")</strong>
                                                    </div>
                                                </div>

                                                <div class="station-unified-metric">
                                                    <i class="fa-solid fa-wallet"></i>
                                                    <div>
                                                        <span>Phí duy trì</span>
                                                        <strong class="@maintenanceChipClass">@maintenanceStatusText</strong>
                                                        <small>Hạn: @maintenanceDueDateText</small>
                                                        <small>Còn lại: @(remainingDays > 0 ? $"{remainingDays:0} ngày" : "Đã quá hạn")</small>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="station-unified-row__bottom">
                                                <div class="station-unified-owner">
                                                    <span><i class="fa-regular fa-user"></i> @(User.Identity?.Name ?? "Người dùng")</span>
                                                    <span><i class="fa-solid fa-phone"></i> @phoneNumber</span>
                                                </div>

                                                <a asp-area="User"
                                                   asp-controller="StationRegistration"
                                                   asp-action="Details"
                                                   asp-route-id="@station.Id"
                                                   class="station-unified-toggle text-decoration-none">
                                                    Xem chi tiết
                                                    <i class="fa-solid fa-angle-right"></i>
                                                </a>
                                            </div>

                                            <div id="station-action-@station.Id" class="station-unified-actions">
                                                @if (lockedByAdmin)
                                                {
                                                    <div class="station-unified-note mb-3"><strong>Cảnh báo:</strong> Trạm đang bị admin khóa, chủ trạm không thể thao tác vận hành/trụ cho đến khi được mở khóa.</div>
                                                }
                                                <div class="station-unified-actions__grid">
                                                    <div class="station-side-panel">
                                                        <h4>Cập nhật trạng thái</h4>
                                                        <p>Chủ trạm được cập nhật trực tiếp, không cần gửi admin duyệt.</p>

                                                        <form asp-area="User" asp-controller="StationRegistration" asp-action="CreateStatusRequest" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="StationId" value="@station.Id" />

                                                            <div class="row-item">
                                                                <select class="station-select" name="RequestedStatus">
                                                                    <option value="@StationOperationStatus.Active">Đang hoạt động</option>
                                                                    <option value="@StationOperationStatus.Error">Lỗi</option>
                                                                    <option value="@StationOperationStatus.Maintenance">Bảo trì</option>
                                                                    <option value="@StationOperationStatus.Inactive">Không hoạt động</option>
                                                                </select>
                                                            </div>

                                                            <div class="row-item">
                                                                <textarea class="station-textarea" name="Note" placeholder="Ghi rõ lý do cần thay đổi trạng thái..."></textarea>
                                                            </div>

                                                            <button type="submit" class="station-btn-outline w-100">
                                                                <i class="fa-solid fa-arrows-rotate"></i>
                                                                Cập nhật trạng thái
                                                            </button>
                                                        </form>
                                                    </div>

                                                    <div class="station-side-panel">
                                                        <h4>Thêm trụ trực tiếp</h4>
                                                        <p>Thêm trụ mới vào trạm ngay sau khi bấm lưu, không cần admin duyệt.</p>

                                                        <form asp-area="User"
                                                              asp-controller="StationRegistration"
                                                              asp-action="CreateAddPoleBatchRequest"
                                                              method="post"
                                                              class="pole-table-request-form"
                                                              data-pole-request-form="@station.Id">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="StationId" value="@station.Id" />

                                                            <div class="pole-draft-editor">
                                                                <div class="row-item">
                                                                    <input type="text"
                                                                           class="station-input"
                                                                           data-pole-code-input="@station.Id"
                                                                           placeholder="Mã trụ, ví dụ TRU-10" />
                                                                </div>

                                                                <div class="row-item">
                                                                    <input type="text"
                                                                           class="station-input"
                                                                           data-pole-power-input="@station.Id"
                                                                           placeholder="Công suất, ví dụ 120" />
                                                                </div>

                                                                <div class="row-item">
                                                                    <textarea class="station-textarea"
                                                                      data-pole-note-input="@station.Id"
                                                                      placeholder="Ghi chú cho trụ này..."></textarea>
                                                                </div>

                                                                <div class="pole-draft-editor__actions">
                                                                    <button type="button"
                                                                            class="station-btn-outline pole-draft-add-btn"
                                                                            data-station-id="@station.Id">
                                                                        <i class="fa-solid fa-plus"></i>
                                                                        Thêm vào danh sách
                                                                    </button>
                                                                </div>
                                                            </div>

                                                            <div class="pole-draft-table-wrap">
                                                                <table class="pole-draft-table">
                                                                    <thead>
                                                                        <tr>
                                                                            <th>Mã trụ</th>
                                                                            <th>Công suất</th>
                                                                            <th>Ghi chú</th>
                                                                            <th>Thao tác</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody data-pole-draft-body="@station.Id">
                                                                        <tr class="pole-draft-empty-row">
                                                                            <td colspan="4">Chưa có trụ nào trong danh sách nháp.</td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </div>

                                                            <div class="pole-draft-hidden-inputs" data-pole-hidden-inputs="@station.Id"></div>

                                                            <div class="pole-draft-submit">
                                                                <button type="submit" class="station-btn w-100">
                                                                    <i class="fa-solid fa-paper-plane"></i>
                                                                    Thêm toàn bộ trụ trực tiếp
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>

                                                    <div class="station-side-panel">
                                                        <h4>Phí duy trì hàng tháng</h4>
                                                        <p>Phí duy trì là <strong>@((station.MonthlyMaintenanceFee <= 0 ? 10000 : station.MonthlyMaintenanceFee).ToString("N0"))đ</strong>. Chu kỳ duy trì được tính theo từng tháng sau mỗi lần thanh toán.</p>
                                                        <div class="mb-3">
                                                            <span class="@maintenanceChipClass">@maintenanceStatusText</span>
                                                        </div>
                                                        @if (canPayMaintenance || maintenanceStatus == StationMaintenanceStatus.ExpiringSoon)
                                                        {
                                                            <form asp-area="User" asp-controller="StationRegistration" asp-action="StartMaintenancePayment" method="post">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="id" value="@station.Id" />
                                                                <button type="submit" class="station-btn w-100">
                                                                    <i class="fa-solid fa-wallet"></i>
                                                                    Thanh toán phí duy trì qua PayOS
                                                                </button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <button type="button" class="station-btn-outline w-100" disabled>
                                                                <i class="fa-regular fa-circle-check"></i>
                                                                Phí duy trì còn hiệu lực
                                                            </button>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div id="station-tab-registrations" class="station-tab-panel">
                <div class="station-list-card">
                    <div class="card-head">
                        <h3 class="mb-1 font-weight-bold">Hồ sơ đăng ký thêm trạm</h3>
                        <div class="text-muted">Luồng chuẩn: user gửi yêu cầu → admin duyệt → user thanh toán phí kích hoạt lần đầu 50.000đ → hệ thống tự động thêm trạm. Phí duy trì là 10.000đ/tháng.</div>
                    </div>

                    <div class="card-body">
                        @if (!Model.RegistrationRequests.Any())
                        {
                            <div class="station-unified-empty">
                                <i class="fa-regular fa-file-lines"></i>
                                <span>Bạn chưa có hồ sơ đăng ký trạm nào.</span>
                            </div>
                        }
                        else
                        {
                            foreach (var request in Model.RegistrationRequests)
                            {
                                var approvalClass = request.ApprovalStatus switch
                                {
                                    StationWorkflowStatus.Pending => "station-chip-warning",
                                    StationWorkflowStatus.Rejected => "station-chip-danger",
                                    StationWorkflowStatus.Approved => "station-chip-blue",
                                    StationWorkflowStatus.AwaitingPayment => "station-chip-soft",
                                    StationWorkflowStatus.Completed => "station-chip",
                                    _ => "station-chip"
                                };

                                <div class="station-unified-registration">
                                    <div class="station-unified-registration__info">
                                        <h4 class="station-card-title mb-2">@request.StationName</h4>

                                        <div class="station-meta mb-2">
                                            <div><strong>Đơn vị vận hành:</strong> @request.OperatorName</div>
                                            <div><strong>Địa chỉ:</strong> @request.Address</div>
                                            <div><strong>Ngày gửi:</strong> @request.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                            <div><strong>Phí kích hoạt lần đầu:</strong> @request.FeeAmount.ToString("N0") VND</div>
                                        </div>

                                        <div class="mb-2">
                                            <span class="@approvalClass">@request.ApprovalStatus</span>
                                            <span class="station-chip-soft">@request.PaymentStatus</span>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(request.AdminNote))
                                        {
                                            <div class="station-unified-note">
                                                <strong>Ghi chú admin:</strong> @request.AdminNote
                                            </div>
                                        }
                                    </div>

                                    <div class="station-side-panel">
                                        <h4>Thao tác hồ sơ</h4>
                                        <p>Chỉ khi admin duyệt, nút thanh toán mới hoạt động.</p>

                                        @if ((request.ApprovalStatus == StationWorkflowStatus.Approved || request.ApprovalStatus == StationWorkflowStatus.AwaitingPayment) && !request.CreatedStationId.HasValue)
                                        {
                                            <form asp-area="User" asp-controller="StationRegistration" asp-action="StartPayment" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <button type="submit" class="station-btn w-100">
                                                    <i class="fa-solid fa-wallet"></i>
                                                    Thanh toán phí kích hoạt @request.FeeAmount.ToString("N0")đ
                                                </button>
                                            </form>
                                        }
                                        else if (request.CreatedStationId.HasValue)
                                        {
                                            <div class="station-chip">Trạm đã được tạo tự động</div>
                                        }
                                        else
                                        {
                                            <button type="button" class="station-btn-outline w-100" disabled>
                                                <i class="fa-regular fa-clock"></i>
                                                Chờ admin duyệt
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

            <div id="station-tab-history" class="station-tab-panel">
                <div class="station-list-card">
                    <div class="card-head">
                        <h3 class="mb-1 font-weight-bold">Nhật ký thao tác vận hành</h3>
                        <div class="text-muted">Theo dõi nhật ký thao tác trạng thái, thêm, sửa, xóa trụ. Các thao tác hiện được áp dụng trực tiếp bởi chủ trạm.</div>
                    </div>

                    <div class="card-body">
                        @if (!Model.OperationRequests.Any())
                        {
                            <div class="station-unified-empty">
                                <i class="fa-regular fa-clock"></i>
                                <span>Chưa có yêu cầu vận hành nào được gửi.</span>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="station-approve-table">
                                    <thead>
                                        <tr>
                                            <th>Trạm</th>
                                            <th>Loại yêu cầu</th>
                                            <th>Nội dung</th>
                                            <th>Trạng thái</th>
                                            <th>Thời gian</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var request in Model.OperationRequests)
                                        {
                                            var requestBadge = request.Status switch
                                            {
                                                StationWorkflowStatus.Pending => "station-chip-warning",
                                                StationWorkflowStatus.Rejected => "station-chip-danger",
                                                _ => "station-chip"
                                            };

                                            <tr>
                                                <td>
                                                    <div class="font-weight-bold">@(request.Station?.Name ?? "-")</div>
                                                </td>
                                                <td>@request.RequestType</td>
                                                <td>
                                                    @if (request.RequestType == StationOperationRequestType.StatusUpdate)
                                                    {
                                                        <div>Trạng thái yêu cầu: <strong>@request.RequestedStationStatus</strong></div>
                                                    }
                                                    else
                                                    {
                                                        <div>Mã trụ: <strong>@request.PoleCode</strong></div>
                                                        <div>Công suất: <strong>@(string.IsNullOrWhiteSpace(request.PoleMaxPower) ? "-" : request.PoleMaxPower)</strong></div>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(request.UserNote))
                                                    {
                                                        <div class="text-muted mt-1">@request.UserNote</div>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(request.AdminNote))
                                                    {
                                                        <div class="text-muted mt-1"><strong>Admin:</strong> @request.AdminNote</div>
                                                    }
                                                </td>
                                                <td><span class="@requestBadge">@request.Status</span></td>
                                                <td>@request.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const tabButtons = Array.from(document.querySelectorAll('.station-my-tabs__item'));
            const panels = Array.from(document.querySelectorAll('.station-tab-panel'));

            function activateTab(targetId) {
                tabButtons.forEach(btn => {
                    btn.classList.toggle('active', btn.getAttribute('data-tab-target') === targetId);
                });

                panels.forEach(panel => {
                    panel.classList.toggle('active', panel.id === targetId);
                });
            }

            tabButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const targetId = this.getAttribute('data-tab-target');
                    if (!targetId) return;
                    activateTab(targetId);
                });
            });

            const list = document.getElementById('myStationList');
            const searchInput = document.getElementById('myStationSearch');
            const statusFilter = document.getElementById('myStationStatusFilter');
            const visibleCount = document.getElementById('myStationVisibleCount');

            if (list) {
                const rows = Array.from(list.querySelectorAll('.station-unified-row'));

                function applyFilters() {
                    const keyword = (searchInput?.value || '').trim().toLowerCase();
                    const status = statusFilter?.value || '';
                    let shown = 0;

                    rows.forEach(row => {
                        const matchesKeyword = !keyword || (row.dataset.search || '').includes(keyword);
                        const matchesStatus = !status || (row.dataset.status || '') === status;
                        const visible = matchesKeyword && matchesStatus;

                        row.style.display = visible ? '' : 'none';

                        if (visible) {
                            shown++;
                        }
                    });

                    if (visibleCount) {
                        visibleCount.textContent = shown.toString();
                    }
                }

                searchInput?.addEventListener('input', applyFilters);
                statusFilter?.addEventListener('change', applyFilters);
                applyFilters();
            }

            document.querySelectorAll('.station-unified-toggle').forEach(button => {
                button.addEventListener('click', function () {
                    const selector = this.getAttribute('data-target');
                    const target = selector ? document.querySelector(selector) : null;

                    if (!target) return;

                    target.classList.toggle('open');
                    this.classList.toggle('open');
                });
            });

            activateTab('station-tab-list');
        })();


                      document.querySelectorAll('.bulk-pole-add-btn').forEach(button => {
            button.addEventListener('click', function () {
                const stationId = this.getAttribute('data-station-id');
                const list = document.querySelector(`[data-station-pole-list="${stationId}"]`);
                if (!list) return;

                const index = list.querySelectorAll('.bulk-pole-item').length;

                const wrapper = document.createElement('div');
                wrapper.className = 'bulk-pole-item';
                wrapper.innerHTML = `
                    <div class="bulk-pole-head">
                        <div class="bulk-pole-title">
                            <i class="fa-solid fa-charging-station"></i>
                            <span>Trụ mới #${index + 1}</span>
                        </div>

                        <div class="bulk-pole-head-actions">
                            <button type="button" class="bulk-pole-toggle-btn is-open">
                                <span>Xem chi tiết</span>
                                <i class="fa-solid fa-angle-down"></i>
                            </button>

                            <button type="button" class="bulk-pole-delete-icon bulk-pole-remove-btn" title="Xóa trụ này">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    </div>

                    <div class="bulk-pole-body open">
                        <div class="row-item">
                            <input class="station-input" name="Poles[${index}].PoleCode" placeholder="Mã trụ mới, ví dụ TRU-${10 + index}" />
                        </div>

                        <div class="row-item">
                            <input class="station-input" name="Poles[${index}].MaxPower" placeholder="Công suất trụ, ví dụ 120" />
                        </div>

                        <div class="row-item">
                            <textarea class="station-textarea" name="Poles[${index}].Note" placeholder="Mô tả thêm cho trụ này..."></textarea>
                        </div>
                    </div>
                `;

                list.appendChild(wrapper);
                bindBulkPoleItem(wrapper);
                rebuildBulkPoleIndexes(list);
            });
        });

        function bindBulkPoleItem(scope) {
            const toggleBtn = scope.querySelector('.bulk-pole-toggle-btn');
            const removeBtn = scope.querySelector('.bulk-pole-remove-btn');
            const body = scope.querySelector('.bulk-pole-body');

            if (toggleBtn && body) {
                toggleBtn.addEventListener('click', function () {
                    const isOpen = body.classList.toggle('open');
                    this.classList.toggle('is-open', isOpen);
                });
            }

            if (removeBtn) {
                removeBtn.addEventListener('click', function () {
                    const list = scope.parentElement;
                    const totalItems = list ? list.querySelectorAll('.bulk-pole-item').length : 0;

                    if (totalItems <= 1) {
                        alert('Cần giữ lại ít nhất 1 dòng trụ.');
                        return;
                    }

                    scope.remove();
                    rebuildBulkPoleIndexes(list);
                });
            }
        }

        function rebuildBulkPoleIndexes(list) {
            if (!list) return;

            list.querySelectorAll('.bulk-pole-item').forEach((item, index) => {
                const title = item.querySelector('.bulk-pole-title span');
                const poleCode = item.querySelector('input[name*=".PoleCode"]');
                const maxPower = item.querySelector('input[name*=".MaxPower"]');
                const note = item.querySelector('textarea[name*=".Note"]');

                if (title) title.textContent = `Trụ mới #${index + 1}`;
                if (poleCode) poleCode.name = `Poles[${index}].PoleCode`;
                if (maxPower) maxPower.name = `Poles[${index}].MaxPower`;
                if (note) note.name = `Poles[${index}].Note`;
            });
        }

        document.querySelectorAll('.bulk-pole-item').forEach(bindBulkPoleItem);

                document.querySelectorAll('[data-pole-request-form]').forEach(form => {
            const stationId = form.getAttribute('data-pole-request-form');
            const body = form.querySelector(`[data-pole-draft-body="${stationId}"]`);
            const hiddenInputs = form.querySelector(`[data-pole-hidden-inputs="${stationId}"]`);
            const codeInput = form.querySelector(`[data-pole-code-input="${stationId}"]`);
            const powerInput = form.querySelector(`[data-pole-power-input="${stationId}"]`);
            const noteInput = form.querySelector(`[data-pole-note-input="${stationId}"]`);
            const addBtn = form.querySelector(`.pole-draft-add-btn[data-station-id="${stationId}"]`);

            let draftPoles = [];
            let editIndex = -1;

            function escapeHtml(value) {
                return (value || '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function clearEditor() {
                codeInput.value = '';
                powerInput.value = '';
                noteInput.value = '';
                editIndex = -1;
                addBtn.innerHTML = '<i class="fa-solid fa-plus"></i> Thêm vào danh sách';
            }

            function syncHiddenInputs() {
                hiddenInputs.innerHTML = '';

                draftPoles.forEach((pole, index) => {
                    hiddenInputs.insertAdjacentHTML('beforeend', `
                        <input type="hidden" name="Poles[${index}].PoleCode" value="${escapeHtml(pole.poleCode)}" />
                        <input type="hidden" name="Poles[${index}].MaxPower" value="${escapeHtml(pole.maxPower)}" />
                        <input type="hidden" name="Poles[${index}].Note" value="${escapeHtml(pole.note)}" />
                    `);
                });
            }

            function renderDraftTable() {
                if (!draftPoles.length) {
                    body.innerHTML = `
                        <tr class="pole-draft-empty-row">
                            <td colspan="4">Chưa có trụ nào trong danh sách nháp.</td>
                        </tr>
                    `;
                    syncHiddenInputs();
                    return;
                }

                body.innerHTML = draftPoles.map((pole, index) => `
                    <tr>
                        <td><span class="pole-draft-code">${escapeHtml(pole.poleCode)}</span></td>
                        <td>${escapeHtml(pole.maxPower || '-')}</td>
                        <td>${escapeHtml(pole.note || '-')}</td>
                        <td>
                            <div class="pole-draft-actions">
                                <button type="button" class="pole-draft-action-btn edit" data-pole-edit="${index}">
                                    Sửa
                                </button>
                                <button type="button" class="pole-draft-action-btn delete" data-pole-delete="${index}">
                                    Xóa
                                </button>
                            </div>
                        </td>
                    </tr>
                `).join('');

                syncHiddenInputs();

                body.querySelectorAll('[data-pole-edit]').forEach(btn => {
                    btn.addEventListener('click', function () {
                        const index = Number(this.getAttribute('data-pole-edit'));
                        const pole = draftPoles[index];
                        if (!pole) return;

                        codeInput.value = pole.poleCode;
                        powerInput.value = pole.maxPower;
                        noteInput.value = pole.note;
                        editIndex = index;
                        addBtn.innerHTML = '<i class="fa-solid fa-pen"></i> Cập nhật dòng này';
                    });
                });

                body.querySelectorAll('[data-pole-delete]').forEach(btn => {
                    btn.addEventListener('click', function () {
                        const index = Number(this.getAttribute('data-pole-delete'));
                        draftPoles.splice(index, 1);
                        if (editIndex === index) {
                            clearEditor();
                        } else if (editIndex > index) {
                            editIndex--;
                        }
                        renderDraftTable();
                    });
                });
            }

            addBtn?.addEventListener('click', function () {
                const poleCode = (codeInput.value || '').trim();
                const maxPower = (powerInput.value || '').trim();
                const note = (noteInput.value || '').trim();

                if (!poleCode) {
                    alert('Vui lòng nhập mã trụ.');
                    codeInput.focus();
                    return;
                }

                const item = { poleCode, maxPower, note };

                if (editIndex >= 0) {
                    draftPoles[editIndex] = item;
                } else {
                    draftPoles.push(item);
                }

                clearEditor();
                renderDraftTable();
            });

            form.addEventListener('submit', function (e) {
                if (!draftPoles.length) {
                    e.preventDefault();
                    alert('Vui lòng thêm ít nhất 1 trụ vào danh sách trước khi gửi yêu cầu.');
                    return;
                }
            });

            renderDraftTable();
        });

    </script>
}

