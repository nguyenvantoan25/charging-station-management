@{
    ViewData["Title"] = "Tin tức xe điện";
}

@section Styles {
    <style>
        body.user-site-shell {
            background: radial-gradient(circle at top left, rgba(28, 140, 86, 0.08), transparent 28%), linear-gradient(180deg, #f4f7f5 0%, #fbfcfb 32%, #ffffff 100%);
        }

        .news-page {
            padding: 28px 0 74px;
        }

        .news-shell {
            display: flex;
            flex-direction: column;
            gap: 26px;
        }

        .news-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
            padding: 0 4px;
        }

        .news-toolbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .news-toolbar-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 44px;
            padding: 0 18px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(17, 59, 39, 0.08);
            box-shadow: 0 12px 28px rgba(14, 36, 25, 0.05);
            color: #173628;
            font-size: 14px;
            font-weight: 700;
        }

        .news-toolbar-title {
            font-family: "Be Vietnam Pro", sans-serif;
            font-size: clamp(28px, 4vw, 42px);
            line-height: 1.08;
            letter-spacing: -0.03em;
            font-weight: 900;
            color: #0f2018;
            margin: 0;
        }

        .news-intro-card,
        .news-stage,
        .news-ribbon,
        .news-section,
        .news-empty-box {
            background: rgba(255, 255, 255, 0.94);
            border: 1px solid rgba(17, 59, 39, 0.08);
            box-shadow: 0 16px 42px rgba(14, 36, 25, 0.06);
        }

        .news-intro-card {
            display: grid;
            grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
            gap: 34px;
            align-items: stretch;
            border-radius: 32px;
            padding: 32px;
        }

        .news-intro-copy {
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-width: 0;
        }

        .news-intro-badge {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            width: fit-content;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(18, 122, 71, 0.08);
            color: #127447;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-bottom: 18px;
        }

        .news-intro-title {
            font-family: "Be Vietnam Pro", sans-serif;
            margin: 0 0 16px;
            font-size: clamp(38px, 4vw, 62px);
            line-height: 1.02;
            font-weight: 900;
            color: #0f2018;
            letter-spacing: -0.03em;
        }

        .news-intro-text {
            margin: 0;
            max-width: 760px;
            font-size: 18px;
            line-height: 1.8;
            color: #5b6f65;
        }

        .news-intro-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            align-items: center;
            margin-top: 28px;
        }

        .news-intro-time {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            min-height: 48px;
            padding: 0 18px;
            border-radius: 999px;
            border: 1px solid rgba(18, 78, 51, 0.1);
            background: #f8fbf9;
            color: #48645a;
            font-size: 15px;
            font-weight: 700;
        }

        .news-refresh-btn {
            min-height: 48px;
            border: none;
            outline: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 0 22px;
            border-radius: 16px;
            background: linear-gradient(135deg, #16a34a, #0f9f62);
            color: #fff;
            font-size: 16px;
            font-weight: 800;
            box-shadow: 0 14px 28px rgba(22, 163, 74, 0.22);
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .news-refresh-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 18px 32px rgba(22, 163, 74, 0.28);
            }

        .news-intro-image-wrap {
            position: relative;
            min-height: 360px;
            border-radius: 28px;
            overflow: hidden;
            background: linear-gradient(135deg, #deeee5 0%, #f7fbf8 48%, #dcefe4 100%);
        }

        .news-intro-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .news-intro-image-tag {
            position: absolute;
            left: 18px;
            bottom: 18px;
            display: inline-flex;
            align-items: center;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(15, 32, 24, 0.78);
            color: #fff;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.04em;
            backdrop-filter: blur(8px);
        }

        .news-stage {
            border-radius: 30px;
            padding: 22px;
        }

        .news-stage-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.95fr);
            gap: 22px;
        }

        .news-main-story,
        .news-side-story,
        .news-ribbon-card,
        .news-stream-card {
            color: inherit;
            text-decoration: none !important;
            display: block;
        }

        .news-main-story {
            overflow: hidden;
            border-radius: 28px;
            background: #fff;
            border: 1px solid rgba(17, 59, 39, 0.08);
            box-shadow: 0 12px 32px rgba(14, 36, 25, 0.06);
        }

        .news-main-media {
            position: relative;
            height: 430px;
            overflow: hidden;
            background: linear-gradient(135deg, #deeee5 0%, #f7fbf8 48%, #dcefe4 100%);
        }

            .news-main-media img,
            .news-side-media img,
            .news-ribbon-media img,
            .news-stream-media img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                transition: transform 0.35s ease;
            }

        .news-main-story:hover .news-main-media img,
        .news-side-story:hover .news-side-media img,
        .news-ribbon-card:hover .news-ribbon-media img,
        .news-stream-card:hover .news-stream-media img {
            transform: scale(1.03);
        }

        .news-photo-fallback {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #17784a;
            background: linear-gradient(135deg, #deeee5 0%, #f7fbf8 48%, #dcefe4 100%);
            font-size: 32px;
        }

        .news-main-badge {
            position: absolute;
            left: 18px;
            bottom: 18px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 8px 14px;
            border-radius: 999px;
            background: rgba(13, 23, 18, 0.72);
            color: #fff;
            font-size: 12px;
            font-weight: 800;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .news-main-body {
            padding: 22px 24px 24px;
        }

        .news-meta-row {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .news-source,
        .news-time,
        .news-kicker {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            min-height: 34px;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
        }

        .news-source {
            background: rgba(17, 122, 71, 0.08);
            border: 1px solid rgba(17, 122, 71, 0.10);
            color: #127447;
        }

        .news-time,
        .news-kicker {
            background: #f6f8f7;
            border: 1px solid rgba(17, 59, 39, 0.07);
            color: #61766f;
        }

        .news-main-title,
        .news-side-title,
        .news-ribbon-title,
        .news-stream-title {
            font-family: "Be Vietnam Pro", sans-serif;
            letter-spacing: -0.03em;
            color: #101f18;
            margin: 0;
        }

        .news-main-title {
            font-size: clamp(28px, 3.8vw, 40px);
            line-height: 1.16;
            font-weight: 800;
            margin-bottom: 14px;
        }

        .news-summary {
            font-size: 16px;
            line-height: 1.82;
            color: #425952;
            margin: 0;
        }

        .news-main-footer,
        .news-stream-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 18px;
        }

        .news-readmore {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 42px;
            padding: 0 14px;
            border-radius: 999px;
            background: #f6f8f7;
            border: 1px solid rgba(17, 59, 39, 0.08);
            color: #173628;
            font-size: 14px;
            font-weight: 800;
        }

        .news-main-story:hover .news-readmore,
        .news-side-story:hover .news-readmore,
        .news-ribbon-card:hover .news-readmore,
        .news-stream-card:hover .news-readmore {
            color: #127447;
            border-color: rgba(17, 122, 71, 0.14);
        }

        .news-side-stack {
            display: grid;
            grid-template-rows: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .news-side-story {
            overflow: hidden;
            border-radius: 24px;
            border: 1px solid rgba(17, 59, 39, 0.08);
            background: #fff;
            box-shadow: 0 12px 28px rgba(14, 36, 25, 0.05);
        }

        .news-side-media {
            height: 198px;
            background: linear-gradient(135deg, #deeee5 0%, #f7fbf8 48%, #dcefe4 100%);
            overflow: hidden;
        }

        .news-side-body {
            padding: 18px;
        }

        .news-side-title {
            font-size: 21px;
            line-height: 1.3;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .news-side-summary {
            font-size: 14px;
            line-height: 1.75;
            color: #4d645c;
            margin: 0;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .news-ribbon {
            border-radius: 28px;
            padding: 22px;
        }

        .news-ribbon-head,
        .news-section-head {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .news-block-title {
            font-family: "Be Vietnam Pro", sans-serif;
            font-size: clamp(22px, 3vw, 30px);
            letter-spacing: -0.03em;
            line-height: 1.14;
            font-weight: 800;
            color: #102019;
            margin: 0 0 6px;
        }

        .news-block-subtitle {
            font-size: 14px;
            line-height: 1.75;
            color: #5e746c;
            margin: 0;
            max-width: 48rem;
        }

        .news-count-chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 38px;
            padding: 0 14px;
            border-radius: 999px;
            background: rgba(17, 122, 71, 0.07);
            color: #127447;
            border: 1px solid rgba(17, 122, 71, 0.10);
            font-size: 13px;
            font-weight: 800;
        }

        .news-ribbon-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
        }

        .news-ribbon-card {
            overflow: hidden;
            border-radius: 22px;
            border: 1px solid rgba(17, 59, 39, 0.08);
            background: #fff;
        }

        .news-ribbon-media {
            height: 186px;
            background: linear-gradient(135deg, #deeee5 0%, #f7fbf8 48%, #dcefe4 100%);
            overflow: hidden;
        }

        .news-ribbon-body {
            padding: 16px;
        }

        .news-ribbon-title {
            font-size: 18px;
            line-height: 1.34;
            font-weight: 800;
            margin-bottom: 10px;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .news-section {
            border-radius: 30px;
            padding: 24px;
        }

        .news-stream-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .news-stream-card {
            overflow: hidden;
            border-radius: 24px;
            border: 1px solid rgba(17, 59, 39, 0.08);
            background: linear-gradient(180deg, #ffffff 0%, #fbfcfb 100%);
            box-shadow: 0 12px 28px rgba(14, 36, 25, 0.05);
            transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        }

            .news-stream-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 20px 36px rgba(14, 36, 25, 0.09);
                border-color: rgba(17, 122, 71, 0.16);
            }

        .news-stream-media {
            height: 250px;
            background: linear-gradient(135deg, #deeee5 0%, #f7fbf8 48%, #dcefe4 100%);
            overflow: hidden;
        }

        .news-stream-body {
            padding: 18px 18px 20px;
        }

        .news-stream-title {
            font-size: 24px;
            line-height: 1.26;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .news-stream-summary {
            font-size: 15px;
            line-height: 1.8;
            color: #4a625b;
            margin: 0;
            display: -webkit-box;
            -webkit-line-clamp: 4;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .news-empty-box {
            border-radius: 24px;
            padding: 28px;
            color: #566c64;
            font-size: 16px;
            border-style: dashed;
        }

        .news-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            margin-top: 22px;
        }

        .news-page-status {
            color: #60756d;
            font-size: 14px;
        }

        @@media (max-width: 1399.98px) {
            .news-ribbon-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 1199.98px) {
            .news-intro-card,
            .news-stage-grid,
            .news-stream-grid {
                grid-template-columns: 1fr;
            }

            .news-side-stack {
                grid-template-columns: repeat(2, minmax(0, 1fr));
                grid-template-rows: none;
            }

            .news-main-media {
                height: 360px;
            }

            .news-intro-image-wrap {
                min-height: 300px;
            }
        }

        @@media (max-width: 767.98px) {
            .news-page {
                padding: 22px 0 56px;
            }

            .news-intro-card,
            .news-stage,
            .news-ribbon,
            .news-section,
            .news-empty-box {
                border-radius: 22px;
            }

            .news-intro-card,
            .news-stage,
            .news-ribbon,
            .news-section {
                padding: 18px;
            }

            .news-ribbon-grid,
            .news-stream-grid,
            .news-side-stack {
                grid-template-columns: 1fr;
            }

            .news-main-media {
                height: 270px;
            }

            .news-side-media,
            .news-ribbon-media,
            .news-stream-media {
                height: 220px;
            }

            .news-main-title {
                font-size: 28px;
            }

            .news-stream-title {
                font-size: 22px;
            }

            .news-intro-title {
                font-size: 34px;
            }

            .news-intro-text {
                font-size: 16px;
                line-height: 1.75;
            }

            .news-intro-image-wrap {
                min-height: 240px;
                border-radius: 20px;
            }
        }
    </style>
}

<div class="sub_banner_outer position-relative user-header-shell">
    @await Html.PartialAsync("_UserHeader")
</div>

<section class="news-page">
    <div class="container">
        <div class="news-shell">
            <div class="news-toolbar">
                <div class="news-toolbar-left">
                    <div class="news-intro-badge">
                        <i class="fa-solid fa-newspaper"></i>
                        Tin tức EV
                    </div>
                    @* <h1 class="news-toolbar-title">Bảng tin xe điện</h1> *@
                </div>

                <div class="news-intro-actions">
                    <div id="newsRefreshNote" class="news-intro-time">
                        <i class="fa-regular fa-clock"></i>
                        Đang tải dữ liệu...
                    </div>

                    <button id="btnRefreshNews" type="button" class="news-refresh-btn">
                        <i class="fa-solid fa-rotate"></i>
                        <span>Làm mới tin</span>
                    </button>
                </div>
            </div>

            <div id="newsLeadStage"></div>
            <div id="newsVisualRibbon"></div>

            <div class="news-section">
                <div class="news-section-head">
                    <div>
                        <h2 class="news-block-title">Tất cả bài viết</h2>
                        <p class="news-block-subtitle">Bỏ khối intro lớn, vào thẳng cụm tin nổi bật và danh sách bài viết để trang gọn hơn, giống chuyên trang báo điện tử hơn.</p>
                    </div>
                    <div class="news-count-chip">
                        <i class="fa-solid fa-images"></i>
                        <span id="newsImageSummary">0 ảnh hiển thị</span>
                    </div>
                </div>

                <div id="newsList" class="news-stream-grid">
                    <div class="news-empty-box">Đang tải bài viết...</div>
                </div>

                <div class="news-footer">
                    <div id="newsPageInfo" class="news-page-status"></div>
                    <div id="newsPager"></div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        let allNewsItems = [];
        let newsPager = null;

        document.addEventListener('DOMContentLoaded', function () {
            newsPager = TramSacPagination.createPager({
                pageSize: 16,
                paginationContainer: 'newsPager',
                infoContainer: 'newsPageInfo',
                onPageChange: renderNewsPage
            });

            document.getElementById('btnRefreshNews')?.addEventListener('click', loadExternalNews);
            loadExternalNews();
        });

        async function loadExternalNews() {
            try {
                const response = await fetch('/User/api/home/external-ev-news');
                if (!response.ok) {
                    throw new Error('Không thể tải tin tức xe điện.');
                }

                const data = await response.json();
                allNewsItems = data.items || [];

                const refreshText = data.serverTime
                    ? new Date(data.serverTime).toLocaleString('vi-VN')
                    : 'vừa xong';

                document.getElementById('newsRefreshNote').innerHTML = `
                    <i class="fa-regular fa-clock"></i>
                    Cập nhật ${escapeHtml(refreshText)}
                `;

                newsPager.setItems(allNewsItems);
            } catch (error) {
                console.error(error);
                document.getElementById('newsLeadStage').innerHTML = '';
                document.getElementById('newsVisualRibbon').innerHTML = '';
                document.getElementById('newsList').innerHTML = '<div class="news-empty-box">Không thể tải tin tức xe điện từ nguồn ngoài.</div>';
                document.getElementById('newsImageSummary').textContent = '0 ảnh hiển thị';
            }
        }

        function renderNewsPage(items) {
            const leadContainer = document.getElementById('newsLeadStage');
            const ribbonContainer = document.getElementById('newsVisualRibbon');
            const listContainer = document.getElementById('newsList');

            if (!items.length) {
                leadContainer.innerHTML = '';
                ribbonContainer.innerHTML = '';
                listContainer.innerHTML = '<div class="news-empty-box">Chưa có bài viết nào.</div>';
                document.getElementById('newsImageSummary').textContent = '0 ảnh hiển thị';
                return;
            }

            const leadItems = items.slice(0, 3);
            const ribbonItems = items.slice(3, 7);
            const streamItems = items.slice(7);

            leadContainer.innerHTML = renderLeadStage(leadItems);
            ribbonContainer.innerHTML = renderRibbon(ribbonItems);
            listContainer.innerHTML = streamItems.length
                ? streamItems.map(renderStreamCard).join('')
                : '<div class="news-empty-box">Trang này không còn bài phụ nào ngoài nhóm nổi bật phía trên.</div>';

            const imagesShown = items.filter(x => !!x.imageUrl).length;
            document.getElementById('newsImageSummary').textContent = `${imagesShown} ảnh hiển thị`;
        }

        function renderLeadStage(items) {
            const main = items[0];
            const side = items.slice(1, 3);

            if (!main) return '';

            return `
                <section class="news-stage">
                    <div class="news-stage-grid">
                        ${renderMainStory(main)}
                        <div class="news-side-stack">
                            ${side.map(renderSideStory).join('') || '<div class="news-empty-box">Chưa có bài phụ.</div>'}
                        </div>
                    </div>
                </section>
            `;
        }

        function renderRibbon(items) {
            if (!items.length) return '';

            return `
                <section class="news-ribbon">
                    <div class="news-ribbon-head">
                        <div>
                            <h2 class="news-block-title">Ảnh nổi bật trong trang</h2>
                            <p class="news-block-subtitle">Một dải ảnh riêng giúp trang giống chuyên trang báo hơn, không bị cảm giác toàn chữ và nút.</p>
                        </div>
                        <div class="news-count-chip">
                            <i class="fa-solid fa-camera"></i>
                            ${items.length} bài đang được nhấn bằng ảnh
                        </div>
                    </div>

                    <div class="news-ribbon-grid">
                        ${items.map(renderRibbonCard).join('')}
                    </div>
                </section>
            `;
        }

        function renderMainStory(item) {
            return `
                <a class="news-main-story" href="${escapeHtml(item.link || '#')}" target="_blank" rel="noopener noreferrer">
                    <div class="news-main-media">
                        ${renderPhoto(item)}
                        <div class="news-main-badge">
                            <i class="fa-solid fa-star"></i>
                            Bài mở đầu
                        </div>
                    </div>
                    <div class="news-main-body">
                        <div class="news-meta-row">
                            <span class="news-source"><i class="fa-solid fa-newspaper"></i>${escapeHtml(item.source || 'Nguồn ngoài')}</span>
                            <span class="news-time"><i class="fa-regular fa-clock"></i>${formatDateTime(item.publishedAt)}</span>
                            <span class="news-kicker"><i class="fa-solid fa-bolt"></i>Xe điện & hạ tầng sạc</span>
                        </div>
                        <h2 class="news-main-title">${escapeHtml(item.title || 'Bài viết xe điện')}</h2>
                        <p class="news-summary">${escapeHtml(item.summary || 'Không có mô tả ngắn.')}</p>
                        <div class="news-main-footer">
                            <span class="news-readmore">Đọc bài gốc <i class="fa-solid fa-arrow-up-right-from-square"></i></span>
                        </div>
                    </div>
                </a>
            `;
        }

        function renderSideStory(item) {
            return `
                <a class="news-side-story" href="${escapeHtml(item.link || '#')}" target="_blank" rel="noopener noreferrer">
                    <div class="news-side-media">
                        ${renderPhoto(item)}
                    </div>
                    <div class="news-side-body">
                        <div class="news-meta-row">
                            <span class="news-source"><i class="fa-solid fa-newspaper"></i>${escapeHtml(item.source || 'Nguồn ngoài')}</span>
                            <span class="news-time"><i class="fa-regular fa-clock"></i>${formatDateTime(item.publishedAt)}</span>
                        </div>
                        <h3 class="news-side-title">${escapeHtml(item.title || 'Bài viết xe điện')}</h3>
                        <p class="news-side-summary">${escapeHtml(item.summary || 'Không có mô tả ngắn.')}</p>
                    </div>
                </a>
            `;
        }

        function renderRibbonCard(item) {
            return `
                <a class="news-ribbon-card" href="${escapeHtml(item.link || '#')}" target="_blank" rel="noopener noreferrer">
                    <div class="news-ribbon-media">
                        ${renderPhoto(item)}
                    </div>
                    <div class="news-ribbon-body">
                        <div class="news-meta-row">
                            <span class="news-time"><i class="fa-regular fa-clock"></i>${formatDateTime(item.publishedAt)}</span>
                        </div>
                        <h3 class="news-ribbon-title">${escapeHtml(item.title || 'Bài viết xe điện')}</h3>
                        <span class="news-readmore">Mở bài viết <i class="fa-solid fa-arrow-right"></i></span>
                    </div>
                </a>
            `;
        }

        function renderStreamCard(item) {
            return `
                <a class="news-stream-card" href="${escapeHtml(item.link || '#')}" target="_blank" rel="noopener noreferrer">
                    <div class="news-stream-media">
                        ${renderPhoto(item)}
                    </div>
                    <div class="news-stream-body">
                        <div class="news-meta-row">
                            <span class="news-source"><i class="fa-solid fa-newspaper"></i>${escapeHtml(item.source || 'Nguồn ngoài')}</span>
                            <span class="news-time"><i class="fa-regular fa-clock"></i>${formatDateTime(item.publishedAt)}</span>
                        </div>
                        <h3 class="news-stream-title">${escapeHtml(item.title || 'Bài viết xe điện')}</h3>
                        <p class="news-stream-summary">${escapeHtml(item.summary || 'Không có mô tả ngắn.')}</p>
                        <div class="news-stream-footer">
                            <span class="news-readmore">Xem bài viết <i class="fa-solid fa-arrow-up-right-from-square"></i></span>
                        </div>
                    </div>
                </a>
            `;
        }

        function renderPhoto(item) {
            return item.imageUrl
                ? `<img src="${escapeHtml(item.imageUrl)}" alt="${escapeHtml(item.title || 'Tin tức xe điện')}" loading="lazy" referrerpolicy="no-referrer" />`
                : `<div class="news-photo-fallback"><i class="fa-solid fa-image"></i></div>`;
        }

        function formatDateTime(value) {
            if (!value) return '-';
            return new Date(value).toLocaleString('vi-VN');
        }

        function escapeHtml(text) {
            return String(text || '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }
    </script>
}
