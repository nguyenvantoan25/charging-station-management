@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Lộ trình";
}

@section Styles {
    <style>
        body {
            background: linear-gradient(180deg, #f4f7f6 0%, #ffffff 100%);
        }

        .route-page {
            padding: 28px 0 46px;
        }

        .route-shell {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .route-hero,
        .route-plan-card,
        .route-map-card,
        .route-summary-card,
        .route-stop-card {
            background: #fff;
            border-radius: 24px;
            border: 1px solid #e8efec;
            box-shadow: 0 14px 36px rgba(15, 25, 21, 0.07);
        }

        .route-hero {
            padding: 28px;
            display: flex;
            justify-content: space-between;
            gap: 20px;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        .route-hero-content {
            min-width: 0;
            flex: 1 1 560px;
        }

        .route-hero-side {
            flex: 0 1 620px;
            max-width: 620px;
            min-width: 420px;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 12px;
        }

        .route-title {
            font-size: 42px;
            font-weight: 800;
            line-height: 1.1;
            color: #18221e;
            margin-bottom: 10px;
        }

        .route-subtitle {
            font-size: 17px;
            color: #64766f;
            margin-bottom: 0;
            max-width: 760px;
        }

        .route-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border-radius: 999px;
            background: #eef8f2;
            color: #177b46;
            padding: 10px 16px;
            font-size: 14px;
            font-weight: 800;
            white-space: nowrap;
        }

        .route-main-grid {
            display: grid;
            grid-template-columns: minmax(360px, 430px) minmax(0, 1fr);
            gap: 24px;
            align-items: stretch;
        }

        .route-plan-card,
        .route-map-card {
            overflow: hidden;
            min-height: 720px;
            display: flex;
            flex-direction: column;
        }

        .route-plan-card {
            padding: 22px;
        }

        .route-card-title {
            font-size: 28px;
            font-weight: 800;
            color: #18231f;
            margin-bottom: 8px;
        }

        .route-card-subtitle {
            font-size: 15px;
            color: #697a73;
            margin-bottom: 20px;
        }

        .route-group {
            margin-bottom: 16px;
        }

        .route-label {
            display: block;
            font-size: 15px;
            font-weight: 700;
            color: #22312c;
            margin-bottom: 8px;
        }

        .route-plan-card .form-control,
        .route-plan-card .custom-select {
            min-height: 48px;
            border-radius: 14px;
            border: 1px solid #dce6e2;
            box-shadow: none !important;
            font-size: 15px;
        }

            .route-plan-card .form-control:focus,
            .route-plan-card .custom-select:focus {
                border-color: #1faa5f;
            }

        .route-place-wrap {
            position: relative;
        }

        .route-start-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: 10px;
        }

        .route-location-btn {
            min-height: 38px;
            border-radius: 999px;
            font-weight: 800;
            padding-left: 16px;
            padding-right: 16px;
            box-shadow: none !important;
        }

        .route-place-detail {
            margin-top: 8px;
            display: none;
            border-radius: 14px;
            border: 1px solid #dce6e2;
            background: #f8fbfa;
            padding: 10px 12px;
            font-size: 13px;
            color: #4e635b;
            line-height: 1.5;
        }

            .route-place-detail.is-visible {
                display: block;
            }

            .route-place-detail strong {
                color: #1c2a25;
            }

        .route-suggest-box {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            right: 0;
            z-index: 40;
            display: none;
            max-height: 320px;
            overflow: auto;
            border-radius: 18px;
            border: 1px solid #dfe8e4;
            background: #ffffff;
            box-shadow: 0 18px 44px rgba(15, 25, 21, 0.12);
        }

            .route-suggest-box.is-open {
                display: block;
            }

        .route-suggest-item {
            width: 100%;
            border: 0;
            background: transparent;
            text-align: left;
            padding: 12px 14px;
            border-bottom: 1px solid #eef3f0;
            cursor: pointer;
        }

            .route-suggest-item:last-child {
                border-bottom: 0;
            }

            .route-suggest-item:hover,
            .route-suggest-item:focus {
                background: #f3faf6;
                outline: none;
            }

        .route-suggest-title {
            font-size: 14px;
            font-weight: 800;
            color: #1c2a25;
            margin-bottom: 4px;
        }

        .route-suggest-address {
            font-size: 12px;
            color: #667871;
            line-height: 1.5;
        }

        .route-suggest-empty {
            padding: 14px;
            font-size: 13px;
            color: #667871;
        }

        .route-grid-2 {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .route-action-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 8px;
        }

            .route-action-row .btn {
                min-height: 48px;
                border-radius: 14px;
                font-weight: 700;
                box-shadow: none !important;
            }

        .route-go-now-btn {
            width: 100%;
            min-height: 48px;
            border-radius: 14px;
            font-weight: 700;
            margin-top: 12px;
            display: none;
            box-shadow: none !important;
        }

            .route-go-now-btn.is-visible {
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

        .route-list-group-title {
            font-size: 18px;
            font-weight: 800;
            color: #18231f;
            margin: 4px 0 12px;
        }

        .route-note {
            margin-top: 16px;
            padding: 14px 16px;
            border-radius: 16px;
            border: 1px dashed #d1e2da;
            background: #f8fbfa;
            font-size: 14px;
            color: #5a6d66;
        }

        .route-map-topbar {
            padding: 20px 22px;
            border-bottom: 1px solid #eef3f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
            flex-wrap: wrap;
        }

            .route-map-topbar p {
                margin: 0;
                font-size: 14px;
                color: #687a73;
            }

        .route-map-chip {
            border-radius: 999px;
            background: #f4f8f6;
            color: #466359;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 700;
        }

        #routeMap {
            width: 100%;
            flex: 1 1 auto;
            min-height: 640px;
            background: #f6faf8;
        }

            #routeMap.route-map-failed {
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 24px;
                background: #fff5f5;
            }

        .route-map-message {
            max-width: 460px;
            text-align: center;
            font-size: 15px;
            line-height: 1.7;
            color: #b42318;
        }

        .route-summary-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
        }

        .route-summary-card {
            padding: 20px 22px;
        }

        .route-summary-label {
            font-size: 14px;
            color: #71827b;
            margin-bottom: 10px;
        }

        .route-summary-value {
            font-size: 32px;
            font-weight: 800;
            line-height: 1.05;
            color: #17231f;
        }

        .route-stop-card {
            padding: 22px;
        }

        .route-stop-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .route-stop-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .route-stop-item {
            border: 1px solid #e8efec;
            border-radius: 20px;
            background: linear-gradient(180deg, #ffffff 0%, #fafdfb 100%);
            padding: 18px;
        }

        .route-stop-index {
            width: 38px;
            height: 38px;
            border-radius: 999px;
            background: #177b46;
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            font-weight: 800;
            flex-shrink: 0;
        }

        .route-stop-row {
            display: flex;
            gap: 14px;
            align-items: flex-start;
        }

        .route-stop-title {
            font-size: 20px;
            font-weight: 800;
            color: #18231f;
            margin-bottom: 6px;
        }

        .route-stop-address {
            font-size: 14px;
            color: #667871;
            margin-bottom: 10px;
        }

        .route-stop-meta {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .route-stop-pill {
            border-radius: 999px;
            background: #f4f8f6;
            color: #466359;
            padding: 7px 12px;
            font-size: 12px;
            font-weight: 700;
        }

        .route-stop-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

            .route-stop-actions .btn {
                min-height: 38px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 700;
                box-shadow: none !important;
                padding: 8px 14px;
            }

        .route-stop-selected-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 20px;
        }

        .route-selected-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            background: #eef8f2;
            color: #177b46;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 800;
        }

        .route-station-compact-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .route-station-compact-item {
            border: 1px solid #e8efec;
            border-radius: 18px;
            background: #fff;
            padding: 14px 16px;
        }

        .route-station-compact-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 8px;
        }

        .route-station-main {
            min-width: 0;
            flex: 1;
        }

        .route-station-compact-title {
            font-size: 18px;
            font-weight: 800;
            color: #18231f;
            margin-bottom: 4px;
        }

        .route-station-compact-address {
            font-size: 14px;
            color: #667871;
            margin-bottom: 8px;
        }

        .route-station-compact-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 10px;
        }

        .route-station-compact-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

            .route-station-compact-actions .btn {
                min-height: 36px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 700;
                padding: 7px 14px;
                box-shadow: none !important;
            }

        .route-stop-toolbar {
            margin-bottom: 18px;
            padding: 16px 18px;
            border: 1px solid #e6efeb;
            border-radius: 18px;
            background: linear-gradient(180deg, #fbfdfc 0%, #f7faf9 100%);
        }

        .route-toolbar-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.6fr) repeat(4, minmax(0, 1fr));
            gap: 12px;
            align-items: end;
        }

        .route-toolbar-field {
            min-width: 0;
        }

        .route-toolbar-label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #51655d;
            margin-bottom: 6px;
        }

        .route-stop-toolbar .form-control,
        .route-stop-toolbar .custom-select,
        .route-stop-toolbar .btn {
            min-height: 44px;
            border-radius: 12px;
            box-shadow: none !important;
        }

        .route-stop-toolbar .form-control,
        .route-stop-toolbar .custom-select {
            border: 1px solid #dbe7e2;
        }

        .route-toolbar-actions {
            display: flex;
            justify-content: flex-end;
            align-items: end;
            gap: 10px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .route-stop-list-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 14px;
        }

        .route-stop-list-meta-text {
            font-size: 14px;
            color: #63766e;
        }

        .route-count-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 12px;
            border-radius: 999px;
            background: #eef7f2;
            color: #177b46;
            font-size: 12px;
            font-weight: 800;
        }

        .route-section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .route-section-subtitle {
            font-size: 13px;
            color: #72847d;
        }

        .route-stop-list,
        .route-station-compact-list,
        .route-stop-selected-list {
            gap: 12px;
        }

        .route-stop-item,
        .route-station-compact-item {
            box-shadow: 0 8px 18px rgba(15, 25, 21, 0.04);
        }

        .route-pagination {
            margin-top: 18px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

            .route-pagination .btn {
                min-width: 40px;
                height: 40px;
                border-radius: 12px;
                font-weight: 700;
                box-shadow: none !important;
            }

        .route-pagination-status {
            font-size: 13px;
            color: #6b7d76;
            margin: 0 4px;
        }

        /* Why changed: add route overview and stop timeline like the requested UI screenshot. */
        .route-overview-panel,
        .route-timeline-panel {
            background: #fff;
            border-radius: 24px;
            border: 1px solid #e8efec;
            box-shadow: 0 14px 36px rgba(15, 25, 21, 0.07);
            padding: 24px;
        }

        .route-overview-title,
        .route-timeline-title {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 0 0 20px;
            font-size: 26px;
            font-weight: 900;
            color: #0f2019;
            letter-spacing: -0.03em;
        }

            .route-overview-title i,
            .route-timeline-title i {
                color: #033a2d;
                font-size: 20px;
            }

        .route-overview-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
        }

        .route-overview-metric {
            min-height: 78px;
            border: 1px solid #dfeae5;
            background: linear-gradient(180deg, #fbfdfc 0%, #f8fbfa 100%);
            border-radius: 22px;
            padding: 16px 18px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .route-overview-label {
            font-size: 13px;
            font-weight: 800;
            color: #5d7068;
            margin-bottom: 6px;
        }

        .route-overview-value {
            font-size: 26px;
            font-weight: 900;
            line-height: 1.05;
            color: #071a16;
            letter-spacing: -0.03em;
        }

        .route-overview-status {
            display: inline-flex;
            width: fit-content;
            align-items: center;
            gap: 7px;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 900;
            background: #eef7f2;
            color: #137a43;
        }

            .route-overview-status.is-danger {
                background: #ffe4e1;
                color: #b42318;
            }

            .route-overview-status.is-warning {
                background: #fff3cf;
                color: #9a5b00;
            }

            .route-overview-status.is-muted {
                background: #eef3f0;
                color: #52675e;
            }

        .route-timeline-list {
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

            .route-timeline-list.has-items::before {
                content: '';
                position: absolute;
                top: 44px;
                bottom: 44px;
                left: 22px;
                width: 2px;
                background: linear-gradient(180deg, #12a46a 0%, #1d7df2 100%);
                border-radius: 999px;
            }

        .route-timeline-row {
            position: relative;
            display: grid;
            grid-template-columns: 58px minmax(0, 1fr);
            gap: 0;
            align-items: stretch;
        }

        .route-timeline-number {
            position: relative;
            z-index: 2;
            width: 46px;
            height: 46px;
            border-radius: 18px;
            border: 2px solid #d6eee2;
            background: #ffffff;
            color: #04724a;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            font-size: 16px;
            box-shadow: 0 8px 20px rgba(15, 25, 21, 0.06);
        }

        .route-timeline-card {
            border: 1px solid #dfeae5;
            border-radius: 22px;
            background: #ffffff;
            padding: 18px;
            min-width: 0;
        }

            .route-timeline-card.is-station {
                border-color: #bfdbfe;
                background: linear-gradient(180deg, #f8fcff 0%, #f6fbff 100%);
            }

            .route-timeline-card.is-end {
                border-color: #d6eee2;
                background: linear-gradient(180deg, #fbfefc 0%, #f5fbf7 100%);
            }

        .route-timeline-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 8px;
        }

        .route-timeline-name {
            margin: 0;
            font-size: 18px;
            font-weight: 900;
            color: #13241e;
            line-height: 1.25;
        }

        .route-timeline-address {
            font-size: 13px;
            color: #64766f;
            line-height: 1.45;
            margin-bottom: 12px;
        }

        .route-timeline-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 12px;
        }

        .route-timeline-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 8px 11px;
            background: #eef3f0;
            color: #31453d;
            font-size: 12px;
            font-weight: 800;
        }

        .route-timeline-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

            .route-timeline-actions .btn {
                min-height: 38px;
                border-radius: 999px;
                font-weight: 800;
                font-size: 12px;
                padding: 8px 14px;
                box-shadow: none !important;
            }

        .route-timeline-status-chip {
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 7px 11px;
            background: #e9f8ef;
            color: #117a45;
            font-size: 12px;
            font-weight: 900;
        }



        .route-hero-actions {
            width: 100%;
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

            .route-hero-actions .btn {
                min-height: 42px;
                border-radius: 999px;
                font-weight: 800;
                box-shadow: none !important;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }



        .route-login-required {
            width: 100%;
            max-width: 620px;
            border-radius: 18px;
            border: 1px solid #fde68a;
            background: #fff7dc;
            color: #7c4a03;
            padding: 12px 14px;
            font-size: 14px;
            font-weight: 800;
            display: none;
            align-items: center;
            gap: 8px;
        }

            .route-login-required.is-visible {
                display: flex;
            }

        .route-share-box {
            width: 100%;
            max-width: 620px;
            display: none;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 10px;
            padding: 12px;
            border: 1px solid #dceee5;
            border-radius: 18px;
            background: #f8fcfa;
            box-shadow: inset 0 0 0 1px rgba(22, 163, 74, 0.03);
            align-items: center;
            min-width: 0;
        }

            .route-share-box.is-visible {
                display: grid;
            }

        .route-share-input-wrap {
            position: relative;
            min-width: 0;
        }

            .route-share-input-wrap i {
                position: absolute;
                top: 50%;
                left: 15px;
                transform: translateY(-50%);
                color: #0f7a4a;
                font-size: 14px;
                pointer-events: none;
            }

        .route-share-box input {
            width: 100%;
            min-height: 44px;
            border-radius: 999px;
            border: 1px solid #dce6e2;
            padding: 0 15px 0 40px;
            min-width: 0;
            max-width: 100%;
            font-size: 14px;
            font-weight: 700;
            color: #1f332a;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            background: #fff;
            outline: none;
            box-shadow: none !important;
        }

            .route-share-box input:focus {
                border-color: #1faa5f;
            }

        .route-share-box .btn {
            min-height: 44px;
            border-radius: 999px;
            font-weight: 900;
            flex: 0 0 auto;
            box-shadow: none !important;
            white-space: nowrap;
        }

            .route-share-box .btn.is-copied {
                background: #159957;
                border-color: #159957;
                color: #ffffff;
            }


        .route-history-shortcut {
            background: #fff;
            border-radius: 24px;
            border: 1px solid #e8efec;
            box-shadow: 0 14px 36px rgba(15, 25, 21, 0.07);
            padding: 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            flex-wrap: wrap;
        }

            .route-history-shortcut p {
                margin: 0;
                color: #63766e;
                font-size: 15px;
            }

            .route-history-shortcut .btn {
                border-radius: 999px;
                font-weight: 800;
                min-height: 44px;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

        .route-history-card {
            background: #fff;
            border-radius: 24px;
            border: 1px solid #e8efec;
            box-shadow: 0 14px 36px rgba(15, 25, 21, 0.07);
            padding: 22px;
        }

        .route-history-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .route-history-tools {
            display: grid;
            grid-template-columns: minmax(220px, 1fr) 170px 130px;
            gap: 10px;
            align-items: center;
            margin-bottom: 14px;
        }

            .route-history-tools .form-control,
            .route-history-tools .custom-select {
                min-height: 44px;
                border-radius: 14px;
                border: 1px solid #dce6e2;
                box-shadow: none !important;
            }

        .route-history-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .route-history-item {
            border: 1px solid #e5eeea;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbfa 100%);
            border-radius: 20px;
            padding: 16px;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 14px;
            align-items: center;
        }

        .route-history-title-row {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 6px;
        }

        .route-history-title {
            font-size: 18px;
            font-weight: 900;
            color: #18231f;
            margin: 0;
        }

        .route-history-path {
            font-size: 14px;
            color: #50635c;
            line-height: 1.5;
            margin-bottom: 10px;
        }

        .route-history-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .route-history-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
            flex-wrap: wrap;
            min-width: 300px;
        }

            .route-history-actions .btn {
                border-radius: 999px;
                font-weight: 800;
                min-height: 38px;
                box-shadow: none !important;
            }

        .route-star-btn {
            border: 0;
            background: #fff7dc;
            color: #a16207;
            width: 36px;
            height: 36px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: inset 0 0 0 1px #fde68a;
        }

            .route-star-btn.is-active {
                background: #facc15;
                color: #422006;
                box-shadow: none;
            }

        .route-history-status {
            border-radius: 999px;
            background: #eef8f2;
            color: #177b46;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 900;
        }

        .route-empty,
        .route-error,
        .route-loading {
            border-radius: 18px;
            padding: 18px;
            text-align: center;
            font-size: 15px;
        }

        .route-empty,
        .route-loading {
            background: #f7faf9;
            color: #556861;
            border: 1px dashed #d3e2db;
        }

        .route-error {
            background: #fff5f5;
            color: #b42318;
            border: 1px dashed #f0c2c2;
        }

        .route-main-grid > *,
        .route-summary-grid > *,
        .route-overview-grid > *,
        .route-timeline-card {
            min-width: 0;
        }

        @@media (max-width: 1199.98px) {
            .route-toolbar-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .route-main-grid,
            .route-summary-grid {
                grid-template-columns: 1fr 1fr;
            }

            .route-overview-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 991.98px) {
            .route-main-grid,
            .route-summary-grid,
            .route-toolbar-grid {
                grid-template-columns: 1fr;
            }

            .route-toolbar-actions {
                justify-content: stretch;
            }

                .route-toolbar-actions .btn {
                    width: 100%;
                }

            .route-history-tools,
            .route-history-item {
                grid-template-columns: 1fr;
            }

            .route-history-actions {
                justify-content: stretch;
                min-width: 0;
            }

                .route-history-actions .btn {
                    flex: 1 1 120px;
                }

            .route-hero-side {
                width: 100%;
                max-width: 100%;
                min-width: 0;
                align-items: stretch;
            }

            .route-hero-actions {
                justify-content: flex-start;
            }

            .route-share-box,
            .route-login-required {
                max-width: 100%;
            }

            .route-share-box {
                grid-template-columns: 1fr;
            }

                .route-share-box .btn {
                    width: 100%;
                }

            #routeMap {
                height: 480px;
            }
        }

        @@media (max-width: 767.98px) {
            .route-page {
                padding-top: 20px;
            }

            .route-title {
                font-size: 34px;
            }

            .route-hero-actions .btn {
                flex: 1 1 100%;
            }

            .route-grid-2,
            .route-action-row,
            .route-overview-grid {
                grid-template-columns: 1fr;
            }

            .route-start-actions {
                justify-content: stretch;
            }

                .route-start-actions .btn {
                    width: 100%;
                }

            .route-overview-panel,
            .route-timeline-panel {
                padding: 18px;
            }

            .route-timeline-row {
                grid-template-columns: 44px minmax(0, 1fr);
            }

            .route-timeline-number {
                width: 36px;
                height: 36px;
                border-radius: 14px;
            }

            .route-timeline-list.has-items::before {
                left: 17px;
            }

            .route-stop-card,
            .route-plan-card,
            .route-summary-card,
            .route-overview-metric,
            .route-timeline-card {
                padding-left: 16px;
                padding-right: 16px;
            }

            .route-stop-actions,
            .route-station-compact-actions,
            .route-timeline-actions {
                flex-direction: column;
            }

                .route-stop-actions .btn,
                .route-station-compact-actions .btn,
                .route-timeline-actions .btn {
                    width: 100%;
                }
        }
    </style>
}

