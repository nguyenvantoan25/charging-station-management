        function ensureRouteMapReady() {
            if (routeMap) {
                return Promise.resolve(routeMap);
            }

            if (mapReadyPromise) {
                return mapReadyPromise;
            }

            mapReadyPromise = new Promise((resolve, reject) => {
                if (!MAP4D_API_KEY || MAP4D_API_KEY.includes('DAN_KEY_MAP4D_CUA_BAN_VAO_DAY')) {
                    reject(new Error('Bạn chưa dán API key Map4D vào Route.cshtml.'));
                    return;
                }

                if (window.map4d) {
                    try {
                        initRouteMap();
                        resolve(routeMap);
                    } catch (error) {
                        reject(error);
                    }
                    return;
                }

                // Why changed: register the callback first so the SDK can initialize safely.
                window.__map4dRouteSdkLoaded = function () {
                    try {
                        initRouteMap();
                        resolve(routeMap);
                    } catch (error) {
                        reject(error);
                    }
                };

                const existingScript = document.getElementById('map4d-sdk-script');
                if (existingScript) {
                    existingScript.addEventListener('error', function () {
                        reject(new Error('Không tải được file SDK từ Map4D.'));
                    }, { once: true });
                    return;
                }

                const sdkScript = document.createElement('script');
                sdkScript.id = 'map4d-sdk-script';
                sdkScript.defer = true;
                sdkScript.src = `https://api.map4d.vn/sdk/map/js?version=3.0&key=${encodeURIComponent(MAP4D_API_KEY)}&callback=__map4dRouteSdkLoaded`;
                sdkScript.onerror = function () {
                    reject(new Error('Không tải được file SDK từ Map4D. Hãy kiểm tra lại key và kết nối mạng.'));
                };

                document.head.appendChild(sdkScript);
            });

            return mapReadyPromise;
        }

        function initRouteMap() {
            if (routeMap) {
                return;
            }

            const mapElement = document.getElementById('routeMap');
            mapElement.classList.remove('route-map-failed');
            mapElement.innerHTML = '';

            routeMap = new map4d.Map(mapElement, {
                center: DEFAULT_MAP_CENTER,
                zoom: 6,
                controls: true
            });
        }


        function setupPlaceAutosuggest(prefix) {
            const inputId = prefix === 'start' ? 'startPoint' : 'endPoint';
            const input = document.getElementById(inputId);

            if (!input) {
                return;
            }

            input.addEventListener('input', function () {
                placePickerState[prefix].selected = null;
                renderSelectedPlace(prefix, null);

                const keyword = input.value.trim();
                window.clearTimeout(placePickerState[prefix].debounceId);

                if (keyword.length < 2) {
                    renderSuggestItems(prefix, []);
                    return;
                }

                placePickerState[prefix].debounceId = window.setTimeout(async function () {
                    try {
                        const items = await fetchPlaceSuggestions(keyword);
                        renderSuggestItems(prefix, items);
                    } catch (error) {
                        console.error(error);
                        renderSuggestItems(prefix, [], 'Không lấy được gợi ý địa điểm.');
                    }
                }, 280);
            });

            input.addEventListener('focus', function () {
                const keyword = input.value.trim();
                if (keyword.length >= 2) {
                    window.clearTimeout(placePickerState[prefix].debounceId);
                    placePickerState[prefix].debounceId = window.setTimeout(async function () {
                        try {
                            const items = await fetchPlaceSuggestions(keyword);
                            renderSuggestItems(prefix, items);
                        } catch (error) {
                            console.error(error);
                        }
                    }, 120);
                }
            });

            input.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeSuggestBox(prefix);
                }
            });
        }

        async function fetchPlaceSuggestions(keyword) {
            const response = await fetch(`/User/Home/PlaceSuggest?keyword=${encodeURIComponent(keyword)}`);
            if (!response.ok) {
                throw new Error('Không tải được gợi ý địa điểm.');
            }

            const data = await response.json();
            return Array.isArray(data)
                ? data.filter(item => !item.lat || !item.lng || isLikelyInsideVietnamShape(item.lat, item.lng))
                : [];
        }

        async function fetchResolvedPlace(keyword, placeId) {
            const query = new URLSearchParams();
            query.set('keyword', keyword || '');
            if (placeId) {
                query.set('placeId', placeId);
            }

            const response = await fetch(`/User/Home/PlaceResolve?${query.toString()}`);
            if (!response.ok) {
                return null;
            }

            const data = await response.json();
            return data && data.success && data.item ? data.item : null;
        }

        function renderSuggestItems(prefix, items, fallbackMessage) {
            const box = document.getElementById(`${prefix}SuggestBox`);
            if (!box) {
                return;
            }

            const safeItems = Array.isArray(items) ? items.slice(0, 8) : [];

            if (safeItems.length === 0) {
                if ((document.getElementById(prefix === 'start' ? 'startPoint' : 'endPoint')?.value || '').trim().length < 2) {
                    box.innerHTML = '';
                    box.classList.remove('is-open');
                    return;
                }

                box.innerHTML = `<div class="route-suggest-empty">${escapeHtml(fallbackMessage || 'Không tìm thấy địa điểm phù hợp.')}</div>`;
                box.classList.add('is-open');
                return;
            }

            box.innerHTML = safeItems.map((item, index) => `
                <button type="button"
                        class="route-suggest-item"
                        onclick="selectSuggestedPlace('${prefix}', ${index})">
                    <div class="route-suggest-title">${escapeHtml(item.displayName || item.name || 'Địa điểm')}</div>
                    <div class="route-suggest-address">${escapeHtml(item.address || item.displayName || '')}</div>
                </button>
            `).join('');

            placePickerState[prefix].items = safeItems;
            box.classList.add('is-open');
        }

        function closeSuggestBox(prefix) {
            const box = document.getElementById(`${prefix}SuggestBox`);
            if (!box) {
                return;
            }

            box.classList.remove('is-open');
        }

        function selectSuggestedPlace(prefix, index) {
            const items = Array.isArray(placePickerState[prefix].items) ? placePickerState[prefix].items : [];
            const item = items[index];
            if (!item) {
                return;
            }

            const input = document.getElementById(prefix === 'start' ? 'startPoint' : 'endPoint');
            if (input) {
                input.value = item.displayName || item.name || '';
            }

            placePickerState[prefix].selected = item;
            renderSelectedPlace(prefix, item);
            closeSuggestBox(prefix);
        }

        function renderSelectedPlace(prefix, item) {
            const detailElement = document.getElementById(`${prefix}PlaceDetail`);
            if (!detailElement) {
                return;
            }

            if (!item) {
                detailElement.innerHTML = '';
                detailElement.classList.remove('is-visible');
                return;
            }

            const title = item.name || item.displayName || 'Địa điểm đã chọn';
            const address = item.address || item.displayName || '';
            detailElement.innerHTML = `
                <strong>Đã chọn:</strong> ${escapeHtml(title)}
                ${address ? `<br /><span>${escapeHtml(address)}</span>` : ''}
            `;
            detailElement.classList.add('is-visible');
        }

        function getBrowserCurrentPosition() {
            return new Promise((resolve, reject) => {
                if (!navigator.geolocation) {
                    reject(new Error('Trình duyệt của bạn chưa hỗ trợ lấy vị trí hiện tại.'));
                    return;
                }

                navigator.geolocation.getCurrentPosition(resolve, reject, {
                    enableHighAccuracy: true,
                    timeout: 12000,
                    maximumAge: 60000
                });
            });
        }

        async function useCurrentLocationAsStart() {
            const button = document.getElementById('btnUseMyLocation');
            const originalHtml = button ? button.innerHTML : '';

            try {
                if (button) {
                    button.disabled = true;
                    button.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i>Đang lấy vị trí';
                }

                const position = await getBrowserCurrentPosition();
                const lat = Number(position.coords.latitude);
                const lng = Number(position.coords.longitude);

                if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                    throw new Error('Không đọc được tọa độ vị trí hiện tại.');
                }

                if (!isLikelyInsideVietnamShape(lat, lng)) {
                    throw new Error('Vị trí hiện tại có vẻ nằm ngoài Việt Nam nên chưa thể dùng để lập lộ trình trong hệ thống.');
                }

                const currentPlace = {
                    id: 'my-current-location',
                    lat,
                    lng,
                    name: 'Vị trí của tôi',
                    displayName: 'Vị trí hiện tại của tôi',
                    address: `Tọa độ ${lat.toFixed(5)}, ${lng.toFixed(5)}`
                };

                const startInput = document.getElementById('startPoint');
                if (startInput) {
                    startInput.value = currentPlace.displayName;
                }

                placePickerState.start.selected = currentPlace;
                renderSelectedPlace('start', currentPlace);
                closeSuggestBox('start');

                if (routeMap) {
                    focusStopOnMap(lat, lng, currentPlace.displayName);
                }

                document.getElementById('routeNote').innerHTML =
                    'Đã dùng <strong>vị trí hiện tại của bạn</strong> làm điểm đi. Hãy nhập điểm đến rồi bấm <strong>Lập kế hoạch</strong>.';
            } catch (error) {
                console.error(error);
                alert(error.message || 'Không lấy được vị trí hiện tại. Hãy bật quyền vị trí cho trình duyệt rồi thử lại.');
            } finally {
                if (button) {
                    button.disabled = false;
                    button.innerHTML = originalHtml || '<i class="fa-solid fa-location-crosshairs mr-2"></i>Vị trí của tôi';
                }
            }
        }

        async function resolvePlaceInput(prefix) {
            const input = document.getElementById(prefix === 'start' ? 'startPoint' : 'endPoint');
            const rawText = String(input?.value || '').trim();

            if (!rawText) {
                return null;
            }

            const selected = placePickerState[prefix].selected;
            if (selected && Number.isFinite(Number(selected.lat)) && Number.isFinite(Number(selected.lng))) {
                return {
                    lat: Number(selected.lat),
                    lng: Number(selected.lng),
                    displayName: selected.displayName || selected.name || rawText,
                    address: selected.address || selected.displayName || rawText
                };
            }

            const resolved = await fetchResolvedPlace(rawText, selected?.id || '');
            if (!resolved) {
                return null;
            }

            const normalized = {
                lat: Number(resolved.lat),
                lng: Number(resolved.lng),
                displayName: resolved.displayName || resolved.name || rawText,
                address: resolved.address || resolved.displayName || rawText
            };

            placePickerState[prefix].selected = resolved;
            renderSelectedPlace(prefix, resolved);

            if (input) {
                input.value = normalized.displayName;
            }

            return normalized;
        }

        function resetPlacePicker(prefix) {
            placePickerState[prefix].selected = null;
            placePickerState[prefix].items = [];
            window.clearTimeout(placePickerState[prefix].debounceId);
            closeSuggestBox(prefix);
            renderSelectedPlace(prefix, null);
        }

        async function planTrip() {
            const startText = document.getElementById('startPoint').value.trim();
            const endText = document.getElementById('endPoint').value.trim();
            const vehicleRangeKm = Number(document.getElementById('vehicleRangeKm').value || 0);
            const startBattery = Number(document.getElementById('startBattery').value || 0);
            const reserveBattery = Number(document.getElementById('reserveBattery').value || 0);
            const maxDetourKm = Number(document.getElementById('maxDetourKm').value || 10);

            if (!startText || !endText) {
                alert('Vui lòng nhập đầy đủ điểm đi và điểm đến.');
                return;
            }

            if (vehicleRangeKm < 100) {
                alert('Tầm hoạt động tối đa phải từ 100 km trở lên.');
                return;
            }

            if (startBattery <= reserveBattery) {
                alert('Pin hiện tại phải lớn hơn pin dự phòng tối thiểu.');
                return;
            }

            try {
                await ensureRouteMapReady();
                setRouteLoadingState();

                const [start, end] = await Promise.all([
                    resolvePlaceInput('start'),
                    resolvePlaceInput('end')
                ]);

                if (!start || !end) {
                    throw new Error('Không tìm thấy một trong hai địa điểm. Hãy chọn lại từ gợi ý chi tiết.');
                }

                if (!isLikelyInsideVietnamShape(start.lat, start.lng) || !isLikelyInsideVietnamShape(end.lat, end.lng)) {
                    throw new Error('Hệ thống chỉ hỗ trợ lập lộ trình đường ô tô trong lãnh thổ Việt Nam.');
                }

                // Why changed: use a real road path so the map shows an actual trip, not only a straight line.
                const routeData = await getDrivingRoute(start, end);
                const routePath = routeData.path.length >= 2
                    ? routeData.path
                    : [
                        { lat: start.lat, lng: start.lng },
                        { lat: end.lat, lng: end.lng }
                    ];

                const totalDistanceKm = routeData.distanceKm > 0
                    ? routeData.distanceKm
                    : calculateDistanceKm(start.lat, start.lng, end.lat, end.lng);

                const firstLegKm = vehicleRangeKm * ((startBattery - reserveBattery) / 100);
                const fullSafeLegKm = vehicleRangeKm * ((100 - reserveBattery) / 100);

                const response = await fetch('/User/api/stations');
                if (!response.ok) {
                    throw new Error('Không tải được danh sách trạm.');
                }

                const allStations = await response.json();
                const activeStations = (allStations || []).filter(station =>
                    station &&
                    station.status === 'Đang hoạt động' &&
                    Number.isFinite(Number(station.latitude)) &&
                    Number.isFinite(Number(station.longitude))
                );

                // Đo trạm theo hành lang tuyến Việt Nam. Nếu bán kính người dùng quá hẹp khiến xe đi 2000km
                // nhưng chỉ thấy 1-2 trạm, hệ thống tự mở rộng dần để vẫn đề xuất được chuỗi dừng an toàn.
                const measuredStations = activeStations
                    .filter(station => isLikelyInsideVietnamShape(station.latitude, station.longitude))
                    .map(station => {
                        const metrics = analyzeStationAgainstRoute(
                            Number(station.latitude),
                            Number(station.longitude),
                            routePath
                        );

                        return {
                            ...station,
                            routeDistanceKm: metrics.routeDistanceKm,
                            detourKm: metrics.routeDistanceKm,
                            progressKm: metrics.progressKm,
                            progressRatio: totalDistanceKm <= 0 ? 0 : metrics.progressKm / totalDistanceKm,
                            distanceToDestinationKm: calculateDistanceKm(
                                Number(station.latitude),
                                Number(station.longitude),
                                end.lat,
                                end.lng
                            )
                        };
                    })
                    .sort((a, b) => a.progressKm - b.progressKm);

                const detourCandidates = [...new Set([maxDetourKm, 10, 20, 30, 50, 80]
                    .filter(value => Number(value) >= Number(maxDetourKm)))]
                    .sort((a, b) => a - b);

                let corridorStations = [];
                let plan = null;
                let appliedDetourKm = maxDetourKm;

                for (const detourLimit of detourCandidates) {
                    const candidateStations = measuredStations
                        .filter(station => station.routeDistanceKm <= detourLimit)
                        .sort((a, b) => a.progressKm - b.progressKm);
                    const candidatePlan = buildRoutePlan(candidateStations, totalDistanceKm, firstLegKm, fullSafeLegKm);

                    if (!plan || candidatePlan.stops.length > plan.stops.length || candidatePlan.isReachable) {
                        plan = candidatePlan;
                        corridorStations = candidateStations;
                        appliedDetourKm = detourLimit;
                    }

                    if (candidatePlan.isReachable) {
                        break;
                    }
                }

                plan = plan || buildRoutePlan([], totalDistanceKm, firstLegKm, fullSafeLegKm);
                const requiredStopCount = Math.max(0, Math.ceil(Math.max(totalDistanceKm - firstLegKm, 0) / Math.max(fullSafeLegKm, 1)));
                plan.requiredStopCount = requiredStopCount;
                plan.missingStopCount = Math.max(0, requiredStopCount - plan.stops.length);
                plan.appliedDetourKm = appliedDetourKm;

                drawRoute(start, end, routePath, corridorStations, plan.stops);
                renderRouteSummary(totalDistanceKm, firstLegKm, corridorStations.length, Math.max(plan.stops.length, plan.requiredStopCount || 0), {
                    vehicleRangeKm,
                    startBattery,
                    reserveBattery,
                    isReachable: plan.isReachable
                });
                renderRouteStops(plan, totalDistanceKm, maxDetourKm, corridorStations);

                document.getElementById('routeMapHint').textContent =
                    `Đã lập kế hoạch từ ${escapeHtml(start.displayName)} đến ${escapeHtml(end.displayName)}.`;
                document.getElementById('routeMapChip').textContent =
                    `${plan.stops.length}/${plan.requiredStopCount} điểm dừng cần thiết · ${corridorStations.length} trạm gần tuyến`;
                document.getElementById('routeResultState').textContent =
                    plan.isReachable ? 'Có phương án' : 'Cần bổ sung trạm';
                document.getElementById('routeNote').innerHTML = plan.isReachable
                    ? `Đường đi đã hiển thị trong lãnh thổ Việt Nam. Hệ thống cần khoảng <strong>${plan.requiredStopCount}</strong> điểm dừng, đã chọn <strong>${plan.stops.length}</strong> trạm. Bán kính lệch tuyến đang dùng: <strong>${appliedDetourKm} km</strong>.`
                    : `Tuyến này cần khoảng <strong>${plan.requiredStopCount}</strong> điểm dừng nhưng hiện mới chọn được <strong>${plan.stops.length}</strong> trạm phù hợp. Hãy tăng bán kính lệch tuyến, thêm trạm dọc tuyến hoặc kiểm tra dữ liệu trạm đang hoạt động.`;

                // Why changed: keep the whole planning context so users can add or remove stops later.
                latestTripContext = {
                    start,
                    end,
                    routePath,
                    corridorStations,
                    totalDistanceKm,
                    firstLegKm,
                    vehicleRangeKm,
                    startBattery,
                    reserveBattery,
                    maxDetourKm: appliedDetourKm,
                    requestedDetourKm: maxDetourKm,
                    requiredStopCount: plan.requiredStopCount,
                    fullSafeLegKm,
                    missingStopCount: plan.missingStopCount,
                    isReachable: plan.isReachable,
                    blockingDistanceKm: plan.blockingDistanceKm,
                    selectedStops: sortStationsByProgress(plan.stops),
                    stops: sortStationsByProgress(plan.stops)
                };
                updateRouteNoteAfterSelection();
                renderRouteTimeline(latestTripContext);
                updateCurrentRouteActionButtons();
                autoSavePlannedRoute();
                toggleGoNowButton(true);
            } catch (error) {
                console.error(error);
                latestTripContext = null;
                toggleGoNowButton(false);
                setRouteErrorState(error.message || 'Có lỗi xảy ra khi lập kế hoạch.');
            }
        }

        function buildRoutePlan(corridorStations, totalDistanceKm, firstLegKm, fullSafeLegKm) {
            const safeFirstLegKm = Math.max(Number(firstLegKm) || 0, 0);
            const safeFullLegKm = Math.max(Number(fullSafeLegKm) || 0, 0);
            const totalKm = Math.max(Number(totalDistanceKm) || 0, 0);
            const toleranceKm = 1;

            if (safeFirstLegKm + toleranceKm >= totalKm) {
                return {
                    isReachable: true,
                    stops: [],
                    blockingDistanceKm: totalKm
                };
            }

            const uniqueStations = new Map();
            (Array.isArray(corridorStations) ? corridorStations : []).forEach(station => {
                if (!station) {
                    return;
                }

                const progressKm = Number(station.progressKm || 0);
                if (!Number.isFinite(progressKm) || progressKm <= 3 || progressKm >= totalKm - 3) {
                    return;
                }

                const normalizedId = normalizeStationId(station.id);
                if (!normalizedId) {
                    return;
                }

                const normalizedStation = {
                    ...station,
                    progressKm
                };
                const existing = uniqueStations.get(normalizedId);

                if (!existing || Number(normalizedStation.routeDistanceKm || 999999) < Number(existing.routeDistanceKm || 999999)) {
                    uniqueStations.set(normalizedId, normalizedStation);
                }
            });

            const stations = [...uniqueStations.values()]
                .sort((a, b) => Number(a.progressKm || 0) - Number(b.progressKm || 0));

            const getTotalDetour = stops => (Array.isArray(stops) ? stops : [])
                .reduce((sum, station) => sum + Math.max(Number(station.routeDistanceKm || station.detourKm || 0), 0), 0);

            const getTotalActivePoles = stops => (Array.isArray(stops) ? stops : [])
                .reduce((sum, station) => sum + Number(station.activePoleCount || station.availablePoleCount || 0), 0);

            const isBetterCompletePath = (candidate, current) => {
                if (!current) {
                    return true;
                }

                if (candidate.stops.length !== current.stops.length) {
                    return candidate.stops.length < current.stops.length;
                }

                const candidateDetour = getTotalDetour(candidate.stops);
                const currentDetour = getTotalDetour(current.stops);
                if (Math.abs(candidateDetour - currentDetour) > 0.01) {
                    return candidateDetour < currentDetour;
                }

                return getTotalActivePoles(candidate.stops) > getTotalActivePoles(current.stops);
            };

            const isBetterPartialPath = (candidate, current) => {
                if (!current) {
                    return true;
                }

                if (Math.abs(candidate.blockingDistanceKm - current.blockingDistanceKm) > 0.5) {
                    return candidate.blockingDistanceKm > current.blockingDistanceKm;
                }

                if (candidate.stops.length !== current.stops.length) {
                    return candidate.stops.length < current.stops.length;
                }

                return getTotalDetour(candidate.stops) < getTotalDetour(current.stops);
            };

            const stateByIndex = new Map();
            let bestSolution = null;
            let bestPartial = {
                isReachable: false,
                stops: [],
                blockingDistanceKm: Math.min(totalKm, safeFirstLegKm)
            };

            stations.forEach((station, index) => {
                if (Number(station.progressKm || 0) <= safeFirstLegKm + toleranceKm) {
                    const candidate = {
                        isReachable: false,
                        stops: [station],
                        blockingDistanceKm: Math.min(totalKm, Number(station.progressKm || 0) + safeFullLegKm)
                    };
                    stateByIndex.set(index, candidate);

                    if (isBetterPartialPath(candidate, bestPartial)) {
                        bestPartial = candidate;
                    }
                }
            });

            for (let i = 0; i < stations.length; i += 1) {
                const state = stateByIndex.get(i);
                if (!state) {
                    continue;
                }

                const currentStation = stations[i];
                const currentProgressKm = Number(currentStation.progressKm || 0);
                const reachLimitKm = currentProgressKm + safeFullLegKm + toleranceKm;

                if (reachLimitKm >= totalKm) {
                    const solution = {
                        isReachable: true,
                        stops: state.stops,
                        blockingDistanceKm: totalKm
                    };

                    if (isBetterCompletePath(solution, bestSolution)) {
                        bestSolution = solution;
                    }
                    continue;
                }

                for (let j = i + 1; j < stations.length; j += 1) {
                    const nextStation = stations[j];
                    const nextProgressKm = Number(nextStation.progressKm || 0);

                    if (nextProgressKm > reachLimitKm) {
                        break;
                    }

                    if (nextProgressKm <= currentProgressKm + 3) {
                        continue;
                    }

                    const candidate = {
                        isReachable: false,
                        stops: [...state.stops, nextStation],
                        blockingDistanceKm: Math.min(totalKm, nextProgressKm + safeFullLegKm)
                    };

                    const currentBestForNext = stateByIndex.get(j);
                    if (!currentBestForNext || isBetterCompletePath(candidate, currentBestForNext)) {
                        stateByIndex.set(j, candidate);
                    }

                    if (isBetterPartialPath(candidate, bestPartial)) {
                        bestPartial = candidate;
                    }
                }
            }

            return bestSolution || bestPartial;
        }

        function setRouteText(id, value) {
            const element = document.getElementById(id);
            if (element) {
                element.textContent = value;
            }
        }

        function formatDistanceValue(value, digits = 1) {
            const number = Math.max(Number(value) || 0, 0);
            const shouldShowDecimal = digits > 0 && Math.abs(number - Math.round(number)) > 0.05;
            return `${number.toLocaleString('vi-VN', {
                minimumFractionDigits: shouldShowDecimal ? digits : 0,
                maximumFractionDigits: digits
            })} km`;
        }

        function formatPercentValue(value) {
            const number = Math.max(Number(value) || 0, 0);
            return `${number.toLocaleString('vi-VN', { maximumFractionDigits: 0 })}%`;
        }

        function formatEstimatedDuration(totalDistanceKm) {
            const totalMinutes = Math.max(0, Math.round((Math.max(Number(totalDistanceKm) || 0, 0) / 62) * 60));
            const hours = Math.floor(totalMinutes / 60);
            const minutes = totalMinutes % 60;

            if (hours <= 0) {
                return `${minutes} phút`;
            }

            return `${hours} giờ ${minutes.toString().padStart(2, '0')} phút`;
        }

        function getCurrentRouteBatteryConfig() {
            return {
                vehicleRangeKm: Number(document.getElementById('vehicleRangeKm')?.value || 0),
                startBattery: Number(document.getElementById('startBattery')?.value || 0),
                reserveBattery: Number(document.getElementById('reserveBattery')?.value || 0)
            };
        }

        function getRouteStatusMeta(isReachable, hasData) {
            if (!hasData) {
                return { text: 'Chưa lập', icon: 'fa-circle-info', className: 'is-muted' };
            }

            return isReachable
                ? { text: 'Khả thi', icon: 'fa-circle-check', className: '' }
                : { text: 'Không khả thi', icon: 'fa-circle-xmark', className: 'is-danger' };
        }

        function renderRouteSummary(totalDistanceKm, firstLegKm, corridorCount, stopCount, options) {
            const config = Object.assign({}, getCurrentRouteBatteryConfig(), options || {});
            const hasData = Math.max(Number(totalDistanceKm) || 0, 0) > 0;
            const status = getRouteStatusMeta(!!config.isReachable, hasData);
            const statusElement = document.getElementById('summaryStatus');

            setRouteText('summaryTotalDistance', formatDistanceValue(totalDistanceKm, 1));
            setRouteText('summaryEstimatedTime', formatEstimatedDuration(totalDistanceKm));
            setRouteText('summaryFirstLeg', formatDistanceValue(firstLegKm, 1));
            setRouteText('summaryStopCount', `${Math.max(Number(stopCount) || 0, 0)} trạm`);
            setRouteText('summaryCorridorCount', String(corridorCount ?? 0));
            setRouteText('summaryVehicleRange', formatDistanceValue(config.vehicleRangeKm, 0));
            setRouteText('summaryStartBattery', formatPercentValue(config.startBattery));
            setRouteText('summaryReserveBattery', formatPercentValue(config.reserveBattery));

            if (statusElement) {
                statusElement.className = `route-overview-status ${status.className}`.trim();
                statusElement.innerHTML = `<i class="fa-solid ${status.icon}"></i>${status.text}`;
            }
        }

        function renderRouteTimeline(context) {
            const container = document.getElementById('routeTimelineList');
            if (!container) {
                return;
            }

            if (!context || !context.start || !context.end || !Number(context.totalDistanceKm)) {
                container.classList.remove('has-items');
                container.innerHTML = '<div class="route-empty">Lập kế hoạch để xem tuyến đi, trạm cần sạc và mức pin dự kiến theo từng điểm.</div>';
                return;
            }

            const stops = sortStationsByProgress(context.selectedStops || context.stops || []);
            const items = [];
            items.push(buildTimelineStartHtml(context.start, context));
            stops.forEach((station, index) => {
                items.push(buildTimelineStationHtml(station, index, stops, context));
            });
            items.push(buildTimelineEndHtml(context.end, stops, context));

            container.classList.add('has-items');
            container.innerHTML = items.join('');
        }

        function buildTimelineStartHtml(start, context) {
            const startName = escapeHtml(start.displayName || start.name || 'Vị trí hiện tại của tôi');
            const address = escapeHtml(start.address || `Tọa độ ${Number(start.lat || 0).toFixed(5)}, ${Number(start.lng || 0).toFixed(5)}`);
            return `
                <article class="route-timeline-row">
                    <div class="route-timeline-number">1</div>
                    <div class="route-timeline-card">
                        <div class="route-timeline-head">
                            <h3 class="route-timeline-name">${startName}</h3>
                        </div>
                        <div class="route-timeline-address">${address}</div>
                        <div class="route-timeline-pills">
                            <span class="route-timeline-pill">Pin lúc xuất phát ${formatPercentValue(context.startBattery)}</span>
                            <span class="route-timeline-pill">Đi an toàn ${formatDistanceValue(context.firstLegKm, 1)}</span>
                        </div>
                    </div>
                </article>
            `;
        }

        function buildTimelineStationHtml(station, index, stops, context) {
            const stationName = escapeHtml(station.name || 'Trạm sạc');
            const stationAddress = escapeHtml(station.address || '-');
            const stationLatitude = Number(station.latitude);
            const stationLongitude = Number(station.longitude);
            const stationId = escapeHtml(station.id);
            const availablePoleCount = Number(station.activePoleCount || station.availablePoleCount || 0);
            const totalPoleCount = Number(station.totalPoleCount || 0);
            const progressKm = Math.max(Number(station.progressKm || 0), 0);
            const previousProgressKm = index === 0 ? 0 : Math.max(Number(stops[index - 1]?.progressKm || 0), 0);
            const gapKm = Math.max(progressKm - previousProgressKm, 0);
            const arrivalBattery = estimateArrivalBattery(gapKm, index === 0 ? context.startBattery : 100, context.vehicleRangeKm);
            const nextProgressKm = index < stops.length - 1
                ? Math.max(Number(stops[index + 1]?.progressKm || 0), progressKm)
                : Math.max(Number(context.totalDistanceKm || 0), progressKm);
            const nextGapKm = Math.max(nextProgressKm - progressKm, 0);
            const chargeMinutes = estimateChargeMinutes(arrivalBattery, nextGapKm, context.vehicleRangeKm, context.reserveBattery);
            const chargerType = escapeHtml(station.chargerType || station.ChargerType || 'Loại sạc đang cập nhật');
            const status = escapeHtml(station.status || 'Đang hoạt động');
            const displayIndex = index + 2;

            return `
                <article class="route-timeline-row">
                    <div class="route-timeline-number">${displayIndex}</div>
                    <div class="route-timeline-card is-station">
                        <div class="route-timeline-head">
                            <div>
                                <h3 class="route-timeline-name">${stationName}</h3>
                                <div class="route-timeline-address">${stationAddress}</div>
                            </div>
                            <span class="route-timeline-status-chip">${status}</span>
                        </div>
                        <div class="route-timeline-pills">
                            <span class="route-timeline-pill">Cách điểm trước ${formatDistanceValue(gapKm, 1)}</span>
                            <span class="route-timeline-pill">Pin dự kiến khi đến ${formatPercentValue(arrivalBattery)}</span>
                            <span class="route-timeline-pill">Sạc đề xuất khoảng ${chargeMinutes} phút</span>
                            <span class="route-timeline-pill">${chargerType}</span>
                            <span class="route-timeline-pill">Trụ khả dụng ${availablePoleCount}/${totalPoleCount}</span>
                        </div>
                        <div class="route-timeline-actions">
                            <a href="/User/Station/Details/${station.id}" class="btn btn-outline-secondary">
                                <i class="fa-solid fa-circle-info mr-1"></i>Xem chi tiết
                            </a>
                            <button type="button"
                                    class="btn btn-success"
                                    onclick="focusStopOnMapFromButton(this)"
                                    data-lat="${stationLatitude}"
                                    data-lng="${stationLongitude}"
                                    data-name="${stationName}">
                                <i class="fa-solid fa-map-location-dot mr-1"></i>Xem trên bản đồ
                            </button>
                            <button type="button"
                                    class="btn btn-outline-dark"
                                    onclick="openSingleStationDirection(this)"
                                    data-lat="${stationLatitude}"
                                    data-lng="${stationLongitude}">
                                <i class="fa-solid fa-location-arrow mr-1"></i>Dẫn đường
                            </button>
                            <button type="button"
                                    class="btn btn-outline-danger"
                                    onclick="removeStationFromRouteFromButton(this)"
                                    data-station-id="${stationId}">
                                <i class="fa-solid fa-xmark mr-1"></i>Bỏ
                            </button>
                        </div>
                    </div>
                </article>
            `;
        }

        function buildTimelineEndHtml(end, stops, context) {
            const endName = escapeHtml(end.displayName || end.name || 'Điểm đến');
            const address = escapeHtml(end.address || `Tọa độ ${Number(end.lat || 0).toFixed(5)}, ${Number(end.lng || 0).toFixed(5)}`);
            const lastStop = stops.length > 0 ? stops[stops.length - 1] : null;
            const previousProgressKm = lastStop ? Math.max(Number(lastStop.progressKm || 0), 0) : 0;
            const gapKm = Math.max(Number(context.totalDistanceKm || 0) - previousProgressKm, 0);
            const arrivalBattery = estimateArrivalBattery(gapKm, lastStop ? 100 : context.startBattery, context.vehicleRangeKm);
            const displayIndex = stops.length + 2;

            return `
                <article class="route-timeline-row">
                    <div class="route-timeline-number">${displayIndex}</div>
                    <div class="route-timeline-card is-end">
                        <div class="route-timeline-head">
                            <h3 class="route-timeline-name">${endName}</h3>
                            <span class="route-timeline-status-chip">Điểm đến</span>
                        </div>
                        <div class="route-timeline-address">${address}</div>
                        <div class="route-timeline-pills">
                            <span class="route-timeline-pill">Cách điểm trước ${formatDistanceValue(gapKm, 1)}</span>
                            <span class="route-timeline-pill">Pin dự kiến khi đến ${formatPercentValue(arrivalBattery)}</span>
                            <span class="route-timeline-pill">Tổng tuyến ${formatDistanceValue(context.totalDistanceKm, 1)}</span>
                        </div>
                    </div>
                </article>
            `;
        }

        function estimateArrivalBattery(distanceKm, departureBattery, vehicleRangeKm) {
            const rangeKm = Math.max(Number(vehicleRangeKm) || 0, 1);
            const usedPercent = (Math.max(Number(distanceKm) || 0, 0) / rangeKm) * 100;
            return Math.max(0, Math.min(100, Math.round((Number(departureBattery) || 0) - usedPercent)));
        }

        function estimateChargeMinutes(arrivalBattery, nextGapKm, vehicleRangeKm, reserveBattery) {
            const rangeKm = Math.max(Number(vehicleRangeKm) || 0, 1);
            const neededDepartureBattery = Math.min(95, Math.max(Number(reserveBattery) || 0, 0) + (Math.max(Number(nextGapKm) || 0, 0) / rangeKm) * 100);
            const percentToCharge = Math.max(0, neededDepartureBattery - Math.max(Number(arrivalBattery) || 0, 0));

            if (percentToCharge <= 3) {
                return 15;
            }

            return Math.max(18, Math.min(55, Math.round(percentToCharge * 0.9)));
        }

        function resetRouteListFilters() {
            routeListState.keyword = '';
            routeListState.detourLimit = 'all';
            routeListState.sortBy = 'progress';
            routeListState.page = 1;
            routeListState.pageSize = 6;

            const keywordInput = document.getElementById('stationFilterKeyword');
            const detourSelect = document.getElementById('stationFilterDetour');
            const sortSelect = document.getElementById('stationFilterSort');
            const pageSizeSelect = document.getElementById('stationPageSize');

            if (keywordInput) keywordInput.value = '';
            if (detourSelect) detourSelect.value = 'all';
            if (sortSelect) sortSelect.value = 'progress';
            if (pageSizeSelect) pageSizeSelect.value = '6';

            rerenderRouteStopsFromContext();
        }

        function rerenderRouteStopsFromContext() {
            if (!latestTripContext) {
                updateRouteStopToolbarState(0, 0, false);
                updateRouteStopMeta('Nhập thông tin chuyến đi để bắt đầu lập kế hoạch.');
                document.getElementById('routeStopList').innerHTML = '<div class="route-empty">Nhập thông tin chuyến đi để bắt đầu lập kế hoạch.</div>';
                document.getElementById('routeStopPagination').innerHTML = '';
                return;
            }

            renderRouteStops(
                {
                    isReachable: latestTripContext.isReachable,
                    stops: latestTripContext.selectedStops,
                    blockingDistanceKm: latestTripContext.blockingDistanceKm
                },
                latestTripContext.totalDistanceKm,
                latestTripContext.maxDetourKm,
                latestTripContext.corridorStations
            );
        }

        function updateRouteStopToolbarState(filteredCount, totalCount, isReady) {
            const element = document.getElementById('routeStopToolbarState');
            if (!element) {
                return;
            }

            element.textContent = !isReady
                ? 'Chưa có dữ liệu'
                : `${filteredCount}/${totalCount} trạm phù hợp`;
        }

        function updateRouteStopMeta(message) {
            const meta = document.getElementById('routeStopListMeta');
            if (!meta) {
                return;
            }

            meta.innerHTML = `<div class="route-stop-list-meta-text">${message}</div>`;
        }

        function getFilteredNearbyStations(stations) {
            const keyword = String(routeListState.keyword || '').trim().toLowerCase();
            const detourLimit = routeListState.detourLimit;
            const sortBy = routeListState.sortBy;

            let result = [...(Array.isArray(stations) ? stations : [])];

            if (keyword) {
                result = result.filter(station => {
                    const haystack = `${station?.name || ''} ${station?.address || ''}`.toLowerCase();
                    return haystack.includes(keyword);
                });
            }

            if (detourLimit !== 'all') {
                const maxDetour = Number(detourLimit);
                result = result.filter(station => Number(station?.routeDistanceKm || station?.detourKm || 0) <= maxDetour);
            }

            result.sort((a, b) => {
                if (sortBy === 'detour') {
                    return Number(a?.routeDistanceKm || a?.detourKm || 0) - Number(b?.routeDistanceKm || b?.detourKm || 0);
                }

                if (sortBy === 'rating') {
                    return Number(b?.averageRating || 0) - Number(a?.averageRating || 0);
                }

                if (sortBy === 'ports') {
                    return Number(b?.activePoleCount || b?.availablePoleCount || 0) - Number(a?.activePoleCount || a?.availablePoleCount || 0);
                }

                if (sortBy === 'name') {
                    return String(a?.name || '').localeCompare(String(b?.name || ''), 'vi');
                }

                return Number(a?.progressKm || 0) - Number(b?.progressKm || 0);
            });

            return result;
        }

        function buildPaginationHtml(page, totalPages) {
            if (totalPages <= 1) {
                return '';
            }

            const buttons = [];
            buttons.push(`
                <button type="button" class="btn btn-outline-secondary" onclick="goToRoutePage(${Math.max(1, page - 1)})" ${page <= 1 ? 'disabled' : ''}>
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
            `);

            const startPage = Math.max(1, page - 1);
            const endPage = Math.min(totalPages, startPage + 2);
            const realStart = Math.max(1, endPage - 2);

            for (let current = realStart; current <= endPage; current++) {
                buttons.push(`
                    <button type="button" class="btn ${current === page ? 'btn-success' : 'btn-outline-secondary'}" onclick="goToRoutePage(${current})">${current}</button>
                `);
            }

            buttons.push(`<span class="route-pagination-status">Trang ${page}/${totalPages}</span>`);
            buttons.push(`
                <button type="button" class="btn btn-outline-secondary" onclick="goToRoutePage(${Math.min(totalPages, page + 1)})" ${page >= totalPages ? 'disabled' : ''}>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            `);

            return buttons.join('');
        }

        function goToRoutePage(page) {
            routeListState.page = Math.max(1, Number(page || 1));
            rerenderRouteStopsFromContext();
        }

        function normalizeStationId(id) {
            return String(id ?? '');
        }

        function sortStationsByProgress(stations) {
            return [...(Array.isArray(stations) ? stations : [])]
                .sort((a, b) => Number(a?.progressKm || 0) - Number(b?.progressKm || 0));
        }

        function evaluateStopCoverage(stops, totalDistanceKm, firstLegKm, fullSafeLegKm) {
            const sortedStops = sortStationsByProgress(stops)
                .filter(station => station && Number.isFinite(Number(station.progressKm)));
            const totalKm = Math.max(Number(totalDistanceKm) || 0, 0);
            const safeFullLegKm = Math.max(Number(fullSafeLegKm) || 0, 0);
            let allowedKm = Math.max(Number(firstLegKm) || 0, 0);
            let previousProgressKm = 0;
            let previousName = 'Điểm xuất phát';
            const legs = [];

            for (const station of sortedStops) {
                const progressKm = Math.max(Number(station.progressKm || 0), 0);
                const gapKm = Math.max(progressKm - previousProgressKm, 0);
                const leg = {
                    fromName: previousName,
                    toName: station.name || 'Trạm sạc',
                    gapKm,
                    allowedKm
                };
                legs.push(leg);

                if (gapKm > allowedKm + 1) {
                    return {
                        isReachable: false,
                        legs,
                        firstFailedLeg: leg,
                        blockingDistanceKm: previousProgressKm + allowedKm
                    };
                }

                previousProgressKm = progressKm;
                previousName = station.name || 'Trạm sạc';
                allowedKm = safeFullLegKm;
            }

            const finalGapKm = Math.max(totalKm - previousProgressKm, 0);
            const finalLeg = {
                fromName: previousName,
                toName: 'Điểm đến',
                gapKm: finalGapKm,
                allowedKm
            };
            legs.push(finalLeg);

            if (finalGapKm > allowedKm + 1) {
                return {
                    isReachable: false,
                    legs,
                    firstFailedLeg: finalLeg,
                    blockingDistanceKm: previousProgressKm + allowedKm
                };
            }

            return {
                isReachable: true,
                legs,
                firstFailedLeg: null,
                blockingDistanceKm: totalKm
            };
        }

        function updateRouteNoteAfterSelection() {
            if (!latestTripContext) {
                return;
            }

            const noteEl = document.getElementById('routeNote');
            if (!noteEl) {
                return;
            }

            const stopCount = Array.isArray(latestTripContext.selectedStops)
                ? latestTripContext.selectedStops.length
                : 0;
            const coverage = evaluateStopCoverage(
                latestTripContext.selectedStops,
                latestTripContext.totalDistanceKm,
                latestTripContext.firstLegKm,
                latestTripContext.fullSafeLegKm || (Number(document.getElementById('vehicleRangeKm')?.value || 0) * ((100 - Number(document.getElementById('reserveBattery')?.value || 0)) / 100))
            );

            latestTripContext.isReachable = coverage.isReachable;
            latestTripContext.blockingDistanceKm = coverage.blockingDistanceKm;

            if (coverage.isReachable) {
                noteEl.innerHTML =
                    `Lộ trình hiện đã đủ an toàn theo ngưỡng pin dự phòng. Bạn có thể <strong>thêm/bớt trạm</strong> rồi bấm <strong>Đi ngay bằng Google Maps</strong>, hiện tại là <strong>${stopCount} điểm dừng</strong>.`;
                return;
            }

            const failedLeg = coverage.firstFailedLeg;
            const fromName = failedLeg ? escapeHtml(failedLeg.fromName) : 'điểm trước đó';
            const toName = failedLeg ? escapeHtml(failedLeg.toName) : 'điểm tiếp theo';
            const gapKm = failedLeg ? failedLeg.gapKm.toFixed(0) : '0';
            const allowedKm = failedLeg ? failedLeg.allowedKm.toFixed(0) : '0';

            noteEl.innerHTML =
                `Lộ trình hiện <strong>chưa đủ trạm sạc an toàn</strong>. Đoạn <strong>${fromName} → ${toName}</strong> dài khoảng <strong>${gapKm} km</strong>, trong khi xe chỉ nên đi khoảng <strong>${allowedKm} km</strong> theo mức pin dự phòng. Nguyên nhân thường là dữ liệu trạm hoạt động gần tuyến ở đoạn này còn ít, hãy thêm trạm vào dữ liệu hoặc tăng bán kính lệch tuyến.`;
        }

        function syncRouteFromCurrentSelection(focusStationId) {
            if (!latestTripContext) {
                return;
            }

            latestTripContext.selectedStops = sortStationsByProgress(latestTripContext.selectedStops);
            latestTripContext.stops = [...latestTripContext.selectedStops];

            drawRoute(
                latestTripContext.start,
                latestTripContext.end,
                latestTripContext.routePath,
                latestTripContext.corridorStations,
                latestTripContext.selectedStops
            );

            const coverage = evaluateStopCoverage(
                latestTripContext.selectedStops,
                latestTripContext.totalDistanceKm,
                latestTripContext.firstLegKm,
                latestTripContext.fullSafeLegKm || (Number(document.getElementById('vehicleRangeKm')?.value || 0) * ((100 - Number(document.getElementById('reserveBattery')?.value || 0)) / 100))
            );
            latestTripContext.isReachable = coverage.isReachable;
            latestTripContext.blockingDistanceKm = coverage.blockingDistanceKm;

            renderRouteSummary(
                latestTripContext.totalDistanceKm,
                latestTripContext.firstLegKm,
                latestTripContext.corridorStations.length,
                Math.max(latestTripContext.selectedStops.length, latestTripContext.requiredStopCount || 0),
                {
                    vehicleRangeKm: latestTripContext.vehicleRangeKm,
                    startBattery: latestTripContext.startBattery,
                    reserveBattery: latestTripContext.reserveBattery,
                    isReachable: coverage.isReachable
                }
            );

            renderRouteStops(
                {
                    isReachable: coverage.isReachable,
                    stops: latestTripContext.selectedStops,
                    blockingDistanceKm: coverage.blockingDistanceKm,
                    requiredStopCount: latestTripContext.requiredStopCount || latestTripContext.selectedStops.length,
                    missingStopCount: coverage.isReachable ? 0 : Math.max((latestTripContext.requiredStopCount || 0) - latestTripContext.selectedStops.length, 0)
                },
                latestTripContext.totalDistanceKm,
                latestTripContext.maxDetourKm,
                latestTripContext.corridorStations
            );
            renderRouteTimeline(latestTripContext);

            document.getElementById('routeMapChip').textContent = coverage.isReachable
                ? `${latestTripContext.selectedStops.length} điểm dừng / ${latestTripContext.corridorStations.length} trạm gần tuyến`
                : `${latestTripContext.selectedStops.length}/${latestTripContext.requiredStopCount || '?'} điểm dừng · còn thiếu trạm an toàn`;
            document.getElementById('routeResultState').textContent = coverage.isReachable
                ? 'Đủ trạm an toàn'
                : 'Cần bổ sung trạm';

            updateRouteNoteAfterSelection();
            toggleGoNowButton(true);

            if (focusStationId) {
                const station = latestTripContext.corridorStations.find(item =>
                    normalizeStationId(item.id) === normalizeStationId(focusStationId)
                );

                if (station) {
                    focusStopOnMap(
                        Number(station.latitude),
                        Number(station.longitude),
                        station.name || 'Trạm sạc'
                    );
                }
            }
        }

        function addStationToRouteById(stationId) {
            if (!latestTripContext || !Array.isArray(latestTripContext.corridorStations)) {
                return;
            }

            const normalizedId = normalizeStationId(stationId);
            const station = latestTripContext.corridorStations.find(item =>
                normalizeStationId(item.id) === normalizedId
            );

            if (!station) {
                return;
            }

            const existed = latestTripContext.selectedStops.some(item =>
                normalizeStationId(item.id) === normalizedId
            );

            if (!existed) {
                // Why changed: allow users to pin extra stations into the trip and reuse them in Google Maps.
                latestTripContext.selectedStops = [...latestTripContext.selectedStops, station];
            }

            syncRouteFromCurrentSelection(normalizedId);
        }

        function removeStationFromRouteById(stationId) {
            if (!latestTripContext) {
                return;
            }

            const normalizedId = normalizeStationId(stationId);
            latestTripContext.selectedStops = latestTripContext.selectedStops.filter(item =>
                normalizeStationId(item.id) !== normalizedId
            );

            syncRouteFromCurrentSelection();
        }

        function addStationToRouteFromButton(button) {
            if (!button) {
                return;
            }

            addStationToRouteById(button.getAttribute('data-station-id'));
        }

        function removeStationFromRouteFromButton(button) {
            if (!button) {
                return;
            }

            removeStationFromRouteById(button.getAttribute('data-station-id'));
        }

        function renderRouteStops(plan, totalDistanceKm, maxDetourKm, corridorStations) {
            const container = document.getElementById('routeStopList');
            const pagination = document.getElementById('routeStopPagination');
            const selectedStops = Array.isArray(plan?.stops) ? plan.stops : [];
            const safeCorridorStations = Array.isArray(corridorStations) ? corridorStations : [];
            const selectedIdSet = new Set(selectedStops.map(item => normalizeStationId(item.id)));

            if (!plan.isReachable && selectedStops.length === 0 && safeCorridorStations.length === 0) {
                updateRouteStopToolbarState(0, 0, true);
                updateRouteStopMeta(`Không tìm được trạm hoạt động nào nằm trong hành lang ${maxDetourKm} km của tuyến.`);
                pagination.innerHTML = '';
                container.innerHTML = `
                    <div class="route-error">
                        Đã vẽ đường đi nhưng không tìm được trạm hoạt động nào nằm trong hành lang ${maxDetourKm} km của tuyến.
                    </div>
                `;
                return;
            }

            const summaryBox = !plan.isReachable
                ? `
                    <div class="route-error">
                        Hệ thống mới đi được khoảng <strong>${plan.blockingDistanceKm.toFixed(0)} km</strong> trước khi chạm ngưỡng pin dự phòng. Bạn vẫn có thể thêm trạm thủ công vào lộ trình để mở Google Maps theo các điểm này.
                    </div>
                `
                : '';

            // Timeline phía trên đã thể hiện các điểm dừng trong lộ trình, vì vậy khu vực dưới chỉ còn danh sách trạm sạc.
            const nearbyStations = safeCorridorStations;
            const filteredNearbyStations = getFilteredNearbyStations(nearbyStations);
            const totalFiltered = filteredNearbyStations.length;
            const pageSize = Math.max(1, Number(routeListState.pageSize || 6));
            const totalPages = Math.max(1, Math.ceil(totalFiltered / pageSize));
            routeListState.page = Math.min(Math.max(1, Number(routeListState.page || 1)), totalPages);
            const startIndex = (routeListState.page - 1) * pageSize;
            const pagedNearbyStations = filteredNearbyStations.slice(startIndex, startIndex + pageSize);

            updateRouteStopToolbarState(totalFiltered, nearbyStations.length, true);
            updateRouteStopMeta(
                totalFiltered > 0
                    ? `Đang hiển thị <strong>${startIndex + 1}-${Math.min(startIndex + pagedNearbyStations.length, totalFiltered)}</strong> trên tổng <strong>${totalFiltered}</strong> trạm phù hợp. Danh sách trạm sạc được trình bày gọn để dễ theo dõi và lựa chọn.`
                    : 'Không có trạm nào phù hợp với bộ lọc hiện tại. Hãy nới điều kiện lọc hoặc xóa lọc.'
            );

            const nearbySection = totalFiltered > 0
                ? `
                    <div class="route-station-compact-list">
                        ${pagedNearbyStations.map(station => buildNearbyStationCompactHtml(station, totalDistanceKm, selectedIdSet.has(normalizeStationId(station.id)))).join('')}
                    </div>
                `
                : `
                    <div class="route-empty">
                        Không có trạm gần tuyến nào phù hợp với bộ lọc hiện tại.
                    </div>
                `;

            container.innerHTML = summaryBox + nearbySection;
            pagination.innerHTML = buildPaginationHtml(routeListState.page, totalPages);
        }

