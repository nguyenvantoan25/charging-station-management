        function buildDomesticRoutePoints(start, end) {
            const spine = getVietnamRoadSpine();
            const northToSouth = start.lat >= end.lat;
            const upperLat = Math.max(start.lat, end.lat);
            const lowerLat = Math.min(start.lat, end.lat);
            let middle = spine.filter(point => point.lat < upperLat - 0.18 && point.lat > lowerLat + 0.18);

            middle.sort((a, b) => northToSouth ? b.lat - a.lat : a.lat - b.lat);

            const points = [
                { lat: Number(start.lat), lng: Number(start.lng) },
                ...middle.map(point => ({ lat: point.lat, lng: point.lng })),
                { lat: Number(end.lat), lng: Number(end.lng) }
            ];

            const compact = [];
            for (const point of points) {
                const previous = compact[compact.length - 1];
                if (!previous || calculateDistanceKm(previous.lat, previous.lng, point.lat, point.lng) > 12) {
                    compact.push(point);
                }
            }

            return compact;
        }

        function buildDomesticDrivingRouteApproximation(start, end) {
            const controlPoints = buildDomesticRoutePoints(start, end);
            const path = [];
            let directDistance = 0;

            for (let i = 0; i < controlPoints.length - 1; i++) {
                const a = controlPoints[i];
                const b = controlPoints[i + 1];
                directDistance += calculateDistanceKm(a.lat, a.lng, b.lat, b.lng);
                const segmentSteps = Math.max(2, Math.ceil(calculateDistanceKm(a.lat, a.lng, b.lat, b.lng) / 35));

                for (let step = 0; step <= segmentSteps; step++) {
                    if (i > 0 && step === 0) {
                        continue;
                    }

                    const t = step / segmentSteps;
                    path.push({
                        lat: a.lat + (b.lat - a.lat) * t,
                        lng: a.lng + (b.lng - a.lng) * t
                    });
                }
            }

            return {
                distanceKm: directDistance * 1.16,
                path
            };
        }

