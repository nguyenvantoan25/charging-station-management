@section Scripts {
    <script>
        const MAP4D_API_KEY = '@(Configuration["Map4D:ApiKey"] ?? "")';
        const DEFAULT_MAP_CENTER = { lat: 16.5, lng: 107.5 };
        const IS_ROUTE_AUTHENTICATED = @((User.Identity?.IsAuthenticated == true).ToString().ToLowerInvariant());
        const LOGIN_ROUTE_URL = '@Url.Action("Login", "Account", new { area = "User", returnUrl = Url.Action("Route", "Home", new { area = "User" }) })';

        let currentRouteHistoryId = null;
        let currentRouteIsFavorite = false;
        let currentRouteShareUrl = '';

        const routeHistoryState = {
            items: [],
            keyword: '',
            filter: 'all',
            page: 1,
            pageSize: 5
        };

        let routeMap = null;
        let mapReadyPromise = null;
        let startMarker = null;
        let endMarker = null;
        let routeLine = null;
        let corridorMarkers = [];
        let stopMarkers = [];
        let focusMarker = null;
        let latestTripContext = null;
        // Why changed: keep list filters and pagination stable after each route update.
        const routeListState = {
            keyword: '',
            detourLimit: 'all',
            sortBy: 'progress',
            page: 1,
            pageSize: 6
        };

        const placePickerState = {
            start: { selected: null, debounceId: null },
            end: { selected: null, debounceId: null }
        };

        function isVietnamCoordinate(lat, lng) {
            const nLat = Number(lat);
            const nLng = Number(lng);
            return Number.isFinite(nLat) && Number.isFinite(nLng) &&
                nLat >= 8.0 && nLat <= 23.8 &&
                nLng >= 102.0 && nLng <= 110.5;
        }

        // Ràng buộc mềm theo hình chữ S của Việt Nam. BBox cũ vẫn chứa Lào/Campuchia,
        // nên cần thêm lớp kiểm tra này để không nhận tuyến OSRM chạy vòng sang nước ngoài.
        function getVietnamMinLngByLat(lat) {
            const points = [
                [23.4, 102.0], [22.2, 102.1], [21.0, 102.4], [20.0, 103.0],
                [19.0, 103.8], [18.0, 104.9], [17.0, 105.7], [16.0, 106.5],
                [15.0, 107.0], [14.0, 107.1], [13.0, 107.0], [12.0, 106.7],
                [11.0, 106.0], [10.0, 104.6], [9.0, 104.55], [8.3, 104.5]
            ];

            for (let i = 0; i < points.length - 1; i++) {
                const [latA, lngA] = points[i];
                const [latB, lngB] = points[i + 1];
                if ((lat <= latA && lat >= latB) || (lat >= latA && lat <= latB)) {
                    const t = (lat - latA) / (latB - latA || 1);
                    return lngA + (lngB - lngA) * t;
                }
            }

            return lat >= 15 ? 106.5 : 104.5;
        }

        function isLikelyInsideVietnamShape(lat, lng) {
            const nLat = Number(lat);
            const nLng = Number(lng);
            if (!isVietnamCoordinate(nLat, nLng)) {
                return false;
            }

            const minLng = getVietnamMinLngByLat(nLat) - 0.35;
            const maxLng = nLat >= 15 ? 109.8 : 107.9;
            return nLng >= minLng && nLng <= maxLng;
        }

        function isRouteInsideVietnam(routePath) {
            if (!Array.isArray(routePath) || routePath.length < 2) {
                return false;
            }

            const sampleStep = Math.max(1, Math.floor(routePath.length / 80));
            let checked = 0;
            let outside = 0;

            for (let i = 0; i < routePath.length; i += sampleStep) {
                const point = routePath[i];
                checked++;
                if (!isLikelyInsideVietnamShape(point.lat, point.lng)) {
                    outside++;
                }
            }

            return checked > 0 && outside / checked <= 0.08;
        }

        function getVietnamRoadSpine() {
            return [
                { lat: 22.8233, lng: 104.9836, name: 'Hà Giang' },
