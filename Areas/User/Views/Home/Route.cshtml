        function drawRoute(start, end, routePath, corridorStations, recommendedStops) {
            clearRouteVisuals();

            const startPosition = { lat: start.lat, lng: start.lng };
            const endPosition = { lat: end.lat, lng: end.lng };
            const stopIdSet = new Set((recommendedStops || []).map(stop => stop.id));

            startMarker = createMapMarker(startPosition, `Điểm đi: ${start.displayName}`, {
                icon: buildSvgMarker('#2563eb', 'S'),
                zIndex: 3000
            });

            endMarker = createMapMarker(endPosition, `Điểm đến: ${end.displayName}`, {
                icon: buildSvgMarker('#dc2626', 'Đ'),
                zIndex: 3001
            });

            routeLine = createPolyline(routePath);

            corridorMarkers = corridorStations
                .map(station => createMapMarker(
                    { lat: Number(station.latitude), lng: Number(station.longitude) },
                    `${stopIdSet.has(station.id) ? 'Điểm dừng gợi ý' : 'Trạm gần tuyến'}: ${station.name || 'Trạm sạc'}`,
                    {
                        icon: stopIdSet.has(station.id)
                            ? buildSvgMarker('#16a34a', '⚡')
                            : buildSvgMarker('#6b7280', 'T'),
                        zIndex: stopIdSet.has(station.id) ? 2000 : 1000
                    }
                ))
                .filter(Boolean);

            stopMarkers = recommendedStops
                .map((station, index) => createMapMarker(
                    { lat: Number(station.latitude), lng: Number(station.longitude) },
                    `Điểm dừng ${index + 1}: ${station.name || 'Trạm sạc'}`,
                    {
                        icon: buildSvgMarker('#15803d', String(index + 1)),
                        zIndex: 2500 + index
                    }
                ))
                .filter(Boolean);

            focusMapToPoints([
                startPosition,
                ...sampleRoutePoints(routePath, 16),
                ...recommendedStops.map(stop => ({ lat: Number(stop.latitude), lng: Number(stop.longitude) })),
                endPosition
            ]);
        }

        function createMapMarker(position, title, extraOptions) {
            if (!window.map4d || !routeMap || !position) {
                return null;
            }

            try {
                // Why changed: Map4D Web SDK creates the marker first, then attaches it to the map with setMap().
                const options = Object.assign({
                    position,
                    title: title || ''
                }, extraOptions || {});

                const marker = new map4d.Marker(options);
                marker.setMap(routeMap);
                return marker;
            } catch (error) {
                console.error('Map4D marker error:', error);
                return null;
            }
        }

        function createPolyline(path) {
            if (!window.map4d || !routeMap || !Array.isArray(path) || path.length < 2) {
                return null;
            }

            try {
                // Why changed: Polyline also needs setMap(routeMap), otherwise the route line is created but not rendered.
                const polyline = new map4d.Polyline({
                    path: path.map(point => ({ lat: point.lat, lng: point.lng })),
                    strokeColor: '#177b46',
                    strokeWidth: 6,
                    strokeOpacity: 0.92,
                    zIndex: 999
                });

                polyline.setMap(routeMap);
                return polyline;
            } catch (error) {
                console.error('Map4D polyline error:', error);
                return null;
            }
        }

        async function geocodeAddress(query) {
            const url = `https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&countrycodes=vn&q=${encodeURIComponent(query)}`;
            const response = await fetch(url, {
                headers: {
                    'Accept-Language': 'vi'
                }
            });

            if (!response.ok) {
                return null;
            }

            const data = await response.json();
            if (!data || data.length === 0) {
                return null;
            }

            const lat = parseFloat(data[0].lat);
            const lng = parseFloat(data[0].lon);
            if (!isLikelyInsideVietnamShape(lat, lng)) {
                return null;
            }

            return {
                lat,
                lng,
                displayName: data[0].display_name
            };
        }

        async function getDrivingRoute(start, end) {
            const domesticFallback = buildDomesticDrivingRouteApproximation(start, end);

            try {
                const url = `https://router.project-osrm.org/route/v1/driving/${start.lng},${start.lat};${end.lng},${end.lat}?overview=full&geometries=geojson&steps=false`;
                const response = await fetch(url);

                if (!response.ok) {
                    return domesticFallback;
                }

                const data = await response.json();
                const route = Array.isArray(data?.routes) ? data.routes[0] : null;
                const coordinates = Array.isArray(route?.geometry?.coordinates) ? route.geometry.coordinates : null;

                if (!route || !coordinates || coordinates.length < 2) {
                    return domesticFallback;
                }

                const path = coordinates.map(item => ({
                    lng: Number(item[0]),
                    lat: Number(item[1])
                }));

                // OSRM public đôi khi tối ưu đường vòng sang Lào/Campuchia. Không dùng tuyến đó.
                if (!isRouteInsideVietnam(path)) {
                    return domesticFallback;
                }

                return {
                    distanceKm: Number(route.distance || 0) / 1000,
                    path
                };
            } catch (error) {
                console.error('Route service error:', error);
                return domesticFallback;
            }
        }

        function analyzeStationAgainstRoute(lat, lng, routePath) {
            if (!Array.isArray(routePath) || routePath.length < 2) {
                return {
                    routeDistanceKm: Infinity,
                    progressKm: 0
                };
            }

            let bestDistanceKm = Infinity;
            let bestProgressKm = 0;
            let travelledKm = 0;

            for (let index = 0; index < routePath.length - 1; index++) {
                const start = routePath[index];
                const end = routePath[index + 1];
                const segmentLengthKm = calculateDistanceKm(start.lat, start.lng, end.lat, end.lng);
                const projection = projectPointToSegment(lat, lng, start.lat, start.lng, end.lat, end.lng);
                const progressKm = travelledKm + (segmentLengthKm * projection.ratio);

                if (projection.distanceKm < bestDistanceKm) {
                    bestDistanceKm = projection.distanceKm;
                    bestProgressKm = progressKm;
                }

                travelledKm += segmentLengthKm;
            }

            return {
                routeDistanceKm: bestDistanceKm,
                progressKm: bestProgressKm
            };
        }

        function projectPointToSegment(lat, lng, lat1, lng1, lat2, lng2) {
            const meanLat = ((lat1 + lat2 + lat) / 3) * Math.PI / 180;
            const kmPerDegLat = 111.32;
            const kmPerDegLng = 111.32 * Math.cos(meanLat);

            const p = { x: lng * kmPerDegLng, y: lat * kmPerDegLat };
            const a = { x: lng1 * kmPerDegLng, y: lat1 * kmPerDegLat };
            const b = { x: lng2 * kmPerDegLng, y: lat2 * kmPerDegLat };

            const abx = b.x - a.x;
            const aby = b.y - a.y;
            const apx = p.x - a.x;
            const apy = p.y - a.y;
            const ab2 = abx * abx + aby * aby;

            if (ab2 === 0) {
                return {
                    ratio: 0,
                    distanceKm: Math.sqrt(apx * apx + apy * apy)
                };
            }

            let ratio = (apx * abx + apy * aby) / ab2;
            ratio = Math.max(0, Math.min(1, ratio));

            const closest = {
                x: a.x + abx * ratio,
                y: a.y + aby * ratio
            };

            const dx = p.x - closest.x;
            const dy = p.y - closest.y;

            return {
                ratio,
                distanceKm: Math.sqrt(dx * dx + dy * dy)
            };
        }

        function sampleRoutePoints(routePath, step) {
            if (!Array.isArray(routePath) || routePath.length === 0) {
                return [];
            }

            const result = [];
            for (let index = 0; index < routePath.length; index += step) {
                result.push(routePath[index]);
            }

            const lastPoint = routePath[routePath.length - 1];
            if (result.length === 0 || result[result.length - 1] !== lastPoint) {
                result.push(lastPoint);
            }

            return result;
        }

        function focusMapToPoints(points) {
            if (!routeMap || !window.map4d || !Array.isArray(points) || points.length === 0) {
                return;
            }

            const validPoints = points.filter(point =>
                point &&
                Number.isFinite(Number(point.lat)) &&
                Number.isFinite(Number(point.lng))
            );

            if (validPoints.length === 0) {
                return;
            }

            try {
                if (typeof map4d.LatLngBounds === 'function') {
                    const bounds = new map4d.LatLngBounds();
                    validPoints.forEach(point => bounds.extend({ lat: Number(point.lat), lng: Number(point.lng) }));
                    routeMap.fitBounds(bounds);
                    return;
                }
            } catch (error) {
                console.error('Map4D fitBounds error:', error);
            }

            if (typeof routeMap.setCenter === 'function') {
                routeMap.setCenter(validPoints[0]);
            }

            if (typeof routeMap.setZoom === 'function') {
                routeMap.setZoom(validPoints.length > 1 ? 8 : 15);
            }
        }

        function focusStopOnMap(lat, lng, stationName) {
            if (!routeMap || !Number.isFinite(lat) || !Number.isFinite(lng)) {
                return;
            }

            const focusPoint = { lat, lng };

            if (typeof routeMap.setCenter === 'function') {
                routeMap.setCenter(focusPoint);
            }

            if (typeof routeMap.setZoom === 'function') {
                routeMap.setZoom(15);
            }

            clearMapObject(focusMarker);
            focusMarker = createMapMarker(focusPoint, `Đang xem: ${stationName}`, {
                icon: buildSvgMarker('#f59e0b', 'X'),
                zIndex: 3500
            });
        }

        function focusStopOnMapFromButton(button) {
            if (!button) {
                return;
            }

            const lat = Number(button.getAttribute('data-lat'));
            const lng = Number(button.getAttribute('data-lng'));
            const name = button.getAttribute('data-name') || 'Trạm sạc';
            focusStopOnMap(lat, lng, name);
        }

        function openSingleStationDirection(button) {
            if (!button) {
                return;
            }

            const lat = Number(button.getAttribute('data-lat'));
            const lng = Number(button.getAttribute('data-lng'));

            if (!Number.isFinite(lat) || !Number.isFinite(lng)) {
                return;
            }

            const destination = `${lat},${lng}`;
            const url = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(destination)}&travelmode=driving`;
            window.open(url, '_blank', 'noopener');
        }

        function openPlannedTripInGoogleMaps() {
            if (!latestTripContext || !latestTripContext.start || !latestTripContext.end) {
                alert('Bạn cần lập kế hoạch trước khi đi ngay.');
                return;
            }

            const origin = `${latestTripContext.start.lat},${latestTripContext.start.lng}`;
            const destination = `${latestTripContext.end.lat},${latestTripContext.end.lng}`;
            const waypointStrings = (latestTripContext.selectedStops || latestTripContext.stops || [])
                .filter(stop =>
                    Number.isFinite(Number(stop.latitude)) &&
                    Number.isFinite(Number(stop.longitude))
                )
                .map(stop => `${Number(stop.latitude)},${Number(stop.longitude)}`);

            let googleMapsUrl =
                `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(origin)}&destination=${encodeURIComponent(destination)}&travelmode=driving`;

            // Why changed: always use the current selected stop list so Google Maps follows the updated route.
            if (waypointStrings.length > 0) {
                googleMapsUrl += `&waypoints=${encodeURIComponent(waypointStrings.join('|'))}`;
            }

            if (currentRouteHistoryId) {
                markRouteHistoryUsed(currentRouteHistoryId);
            }

            window.open(googleMapsUrl, '_blank', 'noopener');
        }


        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        async function routeApiFetch(url, options) {
            const headers = Object.assign({
                'Content-Type': 'application/json',
                'RequestVerificationToken': getAntiForgeryToken()
            }, options?.headers || {});

            const response = await fetch(url, Object.assign({}, options || {}, { headers }));

            if (response.status === 401) {
                throw new Error('Bạn cần đăng nhập để dùng chức năng lịch sử lộ trình.');
            }

            const data = await response.json().catch(() => null);
            if (!response.ok || (data && data.success === false)) {
                throw new Error(data?.message || 'Thao tác lộ trình không thành công.');
            }

            return data;
        }

        function updateRouteHistoryStatus(message) {
            const element = document.getElementById('routeHistoryStatus');
            if (element) {
                element.textContent = message;
            }
        }

        async function loadRouteHistoryFromServer() {
            const container = document.getElementById('routeHistoryList');
            if (!container) return;

            if (!IS_ROUTE_AUTHENTICATED) {
                routeHistoryState.items = [];
                updateRouteHistoryStatus('Cần đăng nhập');
                container.innerHTML = '<div class="route-empty">Bạn cần đăng nhập để hệ thống lưu lịch sử, gắn sao và chia sẻ lộ trình.</div>';
                document.getElementById('routeHistoryPagination').innerHTML = '';
                return;
            }

            try {
                updateRouteHistoryStatus('Đang tải lịch sử...');
                const response = await fetch('/User/api/routes/my?take=80');

                if (response.status === 401) {
                    throw new Error('Bạn cần đăng nhập để xem lịch sử lộ trình.');
                }

                const result = await response.json();
                routeHistoryState.items = Array.isArray(result.items) ? result.items : [];
                updateRouteHistoryStatus(`${routeHistoryState.items.length} lộ trình đã lưu`);
                renderRouteHistoryList();
            } catch (error) {
                console.error(error);
                updateRouteHistoryStatus('Không tải được');
                container.innerHTML = `<div class="route-error">${escapeHtml(error.message || 'Không tải được lịch sử lộ trình.')}</div>`;
            }
        }

        function getFilteredRouteHistoryItems() {
            const keyword = String(routeHistoryState.keyword || '').trim().toLowerCase();
            let items = [...routeHistoryState.items];

            if (routeHistoryState.filter === 'favorite') {
                items = items.filter(item => item.isFavorite);
            }

            if (routeHistoryState.filter === 'recent') {
                items.sort((a, b) => new Date(b.lastUsedAt || b.updatedAt || b.createdAt) - new Date(a.lastUsedAt || a.updatedAt || a.createdAt));
            } else {
                items.sort((a, b) => {
                    if (Number(b.isFavorite) !== Number(a.isFavorite)) {
                        return Number(b.isFavorite) - Number(a.isFavorite);
                    }
                    return new Date(b.lastUsedAt || b.updatedAt || b.createdAt) - new Date(a.lastUsedAt || a.updatedAt || a.createdAt);
                });
            }

            if (keyword) {
                items = items.filter(item => {
                    const text = `${item.routeName || ''} ${item.start?.displayName || ''} ${item.end?.displayName || ''} ${item.start?.address || ''} ${item.end?.address || ''}`.toLowerCase();
                    return text.includes(keyword);
                });
            }

            return items;
        }

        function renderRouteHistoryList() {
            const container = document.getElementById('routeHistoryList');
            const pagination = document.getElementById('routeHistoryPagination');
            if (!container || !pagination) return;

            const items = getFilteredRouteHistoryItems();
            const total = items.length;
            const pageSize = Math.max(1, Number(routeHistoryState.pageSize || 5));
            const totalPages = Math.max(1, Math.ceil(total / pageSize));
            routeHistoryState.page = Math.min(Math.max(1, Number(routeHistoryState.page || 1)), totalPages);
            const startIndex = (routeHistoryState.page - 1) * pageSize;
            const pagedItems = items.slice(startIndex, startIndex + pageSize);

            updateRouteHistoryStatus(total > 0 ? `${total}/${routeHistoryState.items.length} lộ trình phù hợp` : `${routeHistoryState.items.length} lộ trình đã lưu`);

            if (routeHistoryState.items.length === 0) {
                container.innerHTML = '<div class="route-empty">Chưa có lịch sử lộ trình. Sau khi bạn lập kế hoạch, hệ thống sẽ tự lưu vào danh sách này.</div>';
                pagination.innerHTML = '';
                return;
            }

            if (pagedItems.length === 0) {
                container.innerHTML = '<div class="route-empty">Không có lộ trình nào khớp bộ lọc hiện tại.</div>';
                pagination.innerHTML = '';
                return;
            }

            container.innerHTML = pagedItems.map(buildRouteHistoryItemHtml).join('');
            pagination.innerHTML = buildRouteHistoryPaginationHtml(routeHistoryState.page, totalPages);
        }

        function buildRouteHistoryPaginationHtml(page, totalPages) {
            if (totalPages <= 1) return '';

            const buttons = [];
            buttons.push(`
                <button type="button" class="btn btn-outline-secondary" onclick="goToRouteHistoryPage(${Math.max(1, page - 1)})" ${page <= 1 ? 'disabled' : ''}>
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
            `);

            const startPage = Math.max(1, page - 1);
            const endPage = Math.min(totalPages, startPage + 2);
            const realStart = Math.max(1, endPage - 2);

            for (let current = realStart; current <= endPage; current++) {
                buttons.push(`<button type="button" class="btn ${current === page ? 'btn-success' : 'btn-outline-secondary'}" onclick="goToRouteHistoryPage(${current})">${current}</button>`);
            }

            buttons.push(`<span class="route-pagination-status">Trang ${page}/${totalPages}</span>`);
            buttons.push(`
                <button type="button" class="btn btn-outline-secondary" onclick="goToRouteHistoryPage(${Math.min(totalPages, page + 1)})" ${page >= totalPages ? 'disabled' : ''}>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            `);

            return buttons.join('');
        }

        function goToRouteHistoryPage(page) {
            routeHistoryState.page = Math.max(1, Number(page || 1));
            renderRouteHistoryList();
        }

        function buildRouteHistoryItemHtml(item) {
            const id = Number(item.id || 0);
            const routeName = escapeHtml(item.routeName || 'Lộ trình đã lưu');
            const startName = escapeHtml(item.start?.displayName || 'Điểm đi');
            const endName = escapeHtml(item.end?.displayName || 'Điểm đến');
            const totalDistance = Number(item.totalDistanceKm || 0).toFixed(0);
            const stopCount = Number(item.stopCount || (item.stops || []).length || 0);
            const usedAt = formatRouteDate(item.lastUsedAt || item.updatedAt || item.createdAt);
            const starClass = item.isFavorite ? 'route-star-btn is-active' : 'route-star-btn';
            const starIcon = item.isFavorite ? 'fa-solid fa-star' : 'fa-regular fa-star';

            return `
                <article class="route-history-item">
                    <div>
                        <div class="route-history-title-row">
                            <button type="button" class="${starClass}" title="Gắn sao lộ trình" onclick="toggleRouteHistoryFavorite(${id})">
                                <i class="${starIcon}"></i>
                            </button>
                            <h3 class="route-history-title">${routeName}</h3>
                        </div>
                        <div class="route-history-path">${startName} <i class="fa-solid fa-arrow-right mx-1"></i> ${endName}</div>
                        <div class="route-history-meta">
                            <span class="route-stop-pill">${totalDistance} km</span>
                            <span class="route-stop-pill">${stopCount} điểm dừng</span>
                            <span class="route-stop-pill">Pin ${Number(item.startBattery || 0)}%</span>
                            <span class="route-stop-pill">Dự phòng ${Number(item.reserveBattery || 0)}%</span>
                            <span class="route-stop-pill">Dùng gần nhất: ${escapeHtml(usedAt)}</span>
                        </div>
                    </div>
                    <div class="route-history-actions">
                        <button type="button" class="btn btn-success" onclick="reuseRouteHistory(${id})">
                            <i class="fa-solid fa-rotate-right mr-1"></i>Dùng lại
                        </button>
                        <button type="button" class="btn btn-outline-dark" onclick="shareRouteHistory(${id})">
                            <i class="fa-solid fa-share-nodes mr-1"></i>Chia sẻ
                        </button>
                        <button type="button" class="btn btn-outline-danger" onclick="deleteRouteHistory(${id})">
                            <i class="fa-solid fa-trash mr-1"></i>Xóa
                        </button>
                    </div>
                </article>
            `;
        }

        function formatRouteDate(value) {
            if (!value) return 'Chưa dùng';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return 'Không rõ';
            return date.toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit', year: 'numeric' });
        }

        function buildCurrentRoutePayload(markFavorite) {
            if (!latestTripContext || !latestTripContext.start || !latestTripContext.end) {
                return null;
            }

            const startName = latestTripContext.start.displayName || 'Điểm đi';
            const endName = latestTripContext.end.displayName || 'Điểm đến';
            const selectedStops = Array.isArray(latestTripContext.selectedStops) ? latestTripContext.selectedStops : [];
            const routeName = `${startName} → ${endName}`;

            return {
                id: currentRouteHistoryId,
                routeName,
                start: latestTripContext.start,
                end: latestTripContext.end,
                totalDistanceKm: Number(latestTripContext.totalDistanceKm || 0),
                firstLegKm: Number(latestTripContext.firstLegKm || 0),
                vehicleRangeKm: Number(document.getElementById('vehicleRangeKm')?.value || 0),
                startBattery: Number(document.getElementById('startBattery')?.value || 0),
                reserveBattery: Number(document.getElementById('reserveBattery')?.value || 0),
                maxDetourKm: Number(document.getElementById('maxDetourKm')?.value || 0),
                isFavorite: markFavorite ? true : currentRouteIsFavorite,
                routePath: compactRoutePathForSave(latestTripContext.routePath),
                stops: selectedStops.map(normalizeStopForSave)
            };
        }

        function compactRoutePathForSave(routePath) {
            const validPath = (Array.isArray(routePath) ? routePath : [])
                .filter(point => Number.isFinite(Number(point.lat)) && Number.isFinite(Number(point.lng)))
                .map(point => ({ lat: Number(point.lat), lng: Number(point.lng) }));

            if (validPath.length <= 180) return validPath;

            const result = [];
            const step = Math.ceil(validPath.length / 180);
            for (let index = 0; index < validPath.length; index += step) {
                result.push(validPath[index]);
            }

            const last = validPath[validPath.length - 1];
            if (result.length === 0 || result[result.length - 1] !== last) {
                result.push(last);
            }

            return result;
        }

        function normalizeStopForSave(station) {
            return {
                id: Number(station.id || 0),
                name: station.name || 'Trạm sạc',
                address: station.address || '',
                latitude: Number(station.latitude),
                longitude: Number(station.longitude),
                progressKm: Number(station.progressKm || 0),
                routeDistanceKm: Number(station.routeDistanceKm || station.detourKm || 0),
                detourKm: Number(station.detourKm || station.routeDistanceKm || 0),
                activePoleCount: Number(station.activePoleCount || station.availablePoleCount || 0),
                availablePoleCount: Number(station.availablePoleCount || station.activePoleCount || 0),
                totalPoleCount: Number(station.totalPoleCount || 0),
                averageRating: Number(station.averageRating || 0),
                chargerType: station.chargerType || station.ChargerType || '',
                status: station.status || 'Đang hoạt động'
            };
        }

        async function autoSavePlannedRoute() {
            if (!IS_ROUTE_AUTHENTICATED) {
                updateRouteHistoryStatus('Đăng nhập để lưu lịch sử');
                return;
            }

            try {
                await saveCurrentRoute(false, true);
            } catch (error) {
                console.warn('Không tự lưu được lộ trình:', error.message || error);
                updateRouteHistoryStatus('Chưa tự lưu được');
            }
        }

        async function saveCurrentRouteFromButton(markFavorite) {
            if (!requireRouteLogin()) {
                return;
            }

            try {
                const result = await saveCurrentRoute(markFavorite, false);
                alert(result?.message || 'Đã lưu lộ trình.');
            } catch (error) {
                alert(error.message || 'Không lưu được lộ trình.');
            }
        }

        async function saveCurrentRoute(markFavorite, silent) {
            if (!IS_ROUTE_AUTHENTICATED) {
                throw new Error('Bạn cần đăng nhập để lưu lộ trình.');
            }

            const payload = buildCurrentRoutePayload(markFavorite);
            if (!payload) {
                throw new Error('Bạn cần lập kế hoạch trước khi lưu lộ trình.');
            }

            const result = await routeApiFetch('/User/api/routes', {
                method: 'POST',
                body: JSON.stringify(payload)
            });

            if (result?.item) {
                currentRouteHistoryId = result.item.id;
                currentRouteIsFavorite = !!result.item.isFavorite;
                currentRouteShareUrl = result.item.shareUrl || currentRouteShareUrl || '';
                upsertRouteHistoryItem(result.item);
                updateCurrentRouteActionButtons();
                renderRouteHistoryList();
                updateRouteHistoryStatus('Đã lưu lộ trình mới nhất');
            }

            return result;
        }

        function upsertRouteHistoryItem(item) {
            if (!item || !item.id) return;
            const index = routeHistoryState.items.findIndex(x => Number(x.id) === Number(item.id));
            if (index >= 0) {
                routeHistoryState.items[index] = item;
            } else {
                routeHistoryState.items.unshift(item);
            }
        }

        function updateCurrentRouteActionButtons() {
            const hasRoute = !!latestTripContext;
            const canUseHistory = hasRoute && IS_ROUTE_AUTHENTICATED;
            const saveButton = document.getElementById('btnSaveCurrentRoute');
            const favoriteButton = document.getElementById('btnFavoriteCurrentRoute');
            const shareButton = document.getElementById('btnShareCurrentRoute');

            if (saveButton) {
                saveButton.disabled = !canUseHistory;
                saveButton.title = IS_ROUTE_AUTHENTICATED ? '' : 'Đăng nhập để lưu lộ trình';
            }
            if (favoriteButton) {
                favoriteButton.disabled = !canUseHistory;
                favoriteButton.title = IS_ROUTE_AUTHENTICATED ? '' : 'Đăng nhập để yêu thích lộ trình';
                favoriteButton.innerHTML = currentRouteIsFavorite
                    ? '<i class="fa-solid fa-star mr-2"></i>Đã yêu thích'
                    : '<i class="fa-regular fa-star mr-2"></i>Yêu thích';
            }
            if (shareButton) {
                shareButton.disabled = !canUseHistory;
                shareButton.title = IS_ROUTE_AUTHENTICATED ? '' : 'Đăng nhập để chia sẻ lộ trình';
            }

            if (hasRoute && !IS_ROUTE_AUTHENTICATED) {
                showRouteLoginRequired();
            }
        }

        async function toggleRouteHistoryFavorite(id) {
            try {
                const result = await routeApiFetch(`/User/api/routes/${id}/favorite`, { method: 'POST' });
                if (result?.item) {
                    upsertRouteHistoryItem(result.item);
                    if (Number(currentRouteHistoryId) === Number(id)) {
                        currentRouteIsFavorite = !!result.item.isFavorite;
                        updateCurrentRouteActionButtons();
                    }
                    renderRouteHistoryList();
                }
            } catch (error) {
                alert(error.message || 'Không cập nhật được yêu thích.');
            }
        }

        async function shareCurrentRoute() {
            if (!requireRouteLogin()) {
                return;
            }

            try {
                if (!currentRouteHistoryId) {
                    await saveCurrentRoute(false, true);
                }

                if (!currentRouteHistoryId) {
                    throw new Error('Chưa có lộ trình để chia sẻ.');
                }

                await shareRouteHistory(currentRouteHistoryId, true);
            } catch (error) {
                alert(error.message || 'Không chia sẻ được lộ trình.');
            }
        }

        async function shareRouteHistory(id, showOnlyBox) {
            try {
                const result = await routeApiFetch(`/User/api/routes/${id}/share`, { method: 'POST' });
                const shareUrl = result?.shareUrl || result?.item?.shareUrl || '';

                if (result?.item) {
                    upsertRouteHistoryItem(result.item);
                    renderRouteHistoryList();
                }

                if (Number(currentRouteHistoryId) === Number(id) || showOnlyBox) {
                    currentRouteShareUrl = shareUrl;
                    showRouteShareBox(shareUrl);
                }

                if (!showOnlyBox) {
                    showRouteShareBox(shareUrl);
                }

                if (shareUrl && navigator.clipboard?.writeText) {
                    await navigator.clipboard.writeText(shareUrl).catch(() => null);
                }

                if (!showOnlyBox) {
                    alert('Đã tạo link chia sẻ. Link đã được copy nếu trình duyệt cho phép.');
                }

                return shareUrl;
            } catch (error) {
                alert(error.message || 'Không chia sẻ được lộ trình.');
                return '';
            }
        }

        function showRouteShareBox(url) {
            const box = document.getElementById('routeShareBox');
            const input = document.getElementById('routeShareInput');
            if (!box || !input) return;

            input.value = url || '';
            box.classList.add('is-visible');
        }

        function hideRouteShareBox() {
            const box = document.getElementById('routeShareBox');
            const input = document.getElementById('routeShareInput');
            if (input) input.value = '';
            if (box) box.classList.remove('is-visible');
        }

        async function copyCurrentShareLink() {
            const input = document.getElementById('routeShareInput');
            const button = document.getElementById('btnCopyShareRoute');
            const value = input?.value || currentRouteShareUrl || '';
            if (!value) {
                alert('Chưa có liên kết để copy.');
                return;
            }

            const originalHtml = button?.innerHTML || '<i class="fa-regular fa-copy mr-2"></i>Copy link';

            try {
                await copyTextSafely(value);

                if (input) {
                    input.blur();
                }

                window.getSelection?.().removeAllRanges?.();

                if (button) {
                    button.disabled = true;
                    button.classList.add('is-copied');
                    button.innerHTML = '<i class="fa-solid fa-check mr-2"></i>Đã copy';

                    window.setTimeout(function () {
                        button.disabled = false;
                        button.classList.remove('is-copied');
                        button.innerHTML = originalHtml;
                    }, 1400);
                }
            } catch {
                alert('Không copy tự động được. Bạn hãy bôi đen link và copy thủ công.');
            }
        }

        async function copyTextSafely(value) {
            if (navigator.clipboard?.writeText && window.isSecureContext) {
                await navigator.clipboard.writeText(value);
                return;
            }

            const tempTextArea = document.createElement('textarea');
            tempTextArea.value = value;
            tempTextArea.setAttribute('readonly', 'readonly');
            tempTextArea.style.position = 'fixed';
            tempTextArea.style.top = '-9999px';
            tempTextArea.style.left = '-9999px';
            tempTextArea.style.opacity = '0';
            document.body.appendChild(tempTextArea);
            tempTextArea.focus();
            tempTextArea.select();

            const copied = document.execCommand('copy');
            document.body.removeChild(tempTextArea);

            if (!copied) {
                throw new Error('Không copy được liên kết.');
            }
        }

        async function reuseRouteHistory(id) {
            const item = routeHistoryState.items.find(x => Number(x.id) === Number(id));
            if (!item) return;

            applySavedRouteToPage(item, false);

            try {
                await routeApiFetch(`/User/api/routes/${id}/used`, { method: 'POST' });
                item.lastUsedAt = new Date().toISOString();
                renderRouteHistoryList();
            } catch (error) {
                console.warn(error);
            }
        }

        function applySavedRouteToPage(item, isSharedRoute) {
            if (!item || !item.start || !item.end) {
                alert('Lộ trình này không đủ dữ liệu để mở lại.');
                return;
            }

            currentRouteHistoryId = isSharedRoute ? null : item.id;
            currentRouteIsFavorite = !isSharedRoute && !!item.isFavorite;
            currentRouteShareUrl = !isSharedRoute ? (item.shareUrl || '') : '';
            hideRouteShareBox();

            const startInput = document.getElementById('startPoint');
            const endInput = document.getElementById('endPoint');
            if (startInput) startInput.value = item.start.displayName || '';
            if (endInput) endInput.value = item.end.displayName || '';

            document.getElementById('vehicleRangeKm').value = String(item.vehicleRangeKm || 400);
            document.getElementById('startBattery').value = String(item.startBattery || 80);
            document.getElementById('reserveBattery').value = String(item.reserveBattery || 20);
            document.getElementById('maxDetourKm').value = String(item.maxDetourKm || 10);

            placePickerState.start.selected = item.start;
            placePickerState.end.selected = item.end;
            renderSelectedPlace('start', item.start);
            renderSelectedPlace('end', item.end);

            const routePath = Array.isArray(item.routePath) && item.routePath.length >= 2
                ? item.routePath.map(point => ({ lat: Number(point.lat), lng: Number(point.lng) }))
                : [
                    { lat: Number(item.start.lat), lng: Number(item.start.lng) },
                    { lat: Number(item.end.lat), lng: Number(item.end.lng) }
                ];

            const savedStops = (Array.isArray(item.stops) ? item.stops : [])
                .filter(stop => Number.isFinite(Number(stop.latitude)) && Number.isFinite(Number(stop.longitude)))
                .map(stop => ({
                    id: stop.id,
                    name: stop.name,
                    address: stop.address,
                    latitude: Number(stop.latitude),
                    longitude: Number(stop.longitude),
                    progressKm: Number(stop.progressKm || 0),
                    routeDistanceKm: Number(stop.routeDistanceKm || stop.detourKm || 0),
                    detourKm: Number(stop.detourKm || stop.routeDistanceKm || 0),
                    activePoleCount: Number(stop.activePoleCount || stop.availablePoleCount || 0),
                    availablePoleCount: Number(stop.availablePoleCount || stop.activePoleCount || 0),
                    totalPoleCount: Number(stop.totalPoleCount || 0),
                    averageRating: Number(stop.averageRating || 0),
                    chargerType: stop.chargerType || stop.ChargerType || '',
                    status: stop.status || 'Đang hoạt động'
                }));

            const savedVehicleRangeKm = Number(item.vehicleRangeKm || 400);
            const savedStartBattery = Number(item.startBattery || 80);
            const savedReserveBattery = Number(item.reserveBattery || 20);
            const savedFirstLegKm = Number(item.firstLegKm || (savedVehicleRangeKm * ((savedStartBattery - savedReserveBattery) / 100)));
            const savedFullSafeLegKm = savedVehicleRangeKm * ((100 - savedReserveBattery) / 100);
            const savedCoverage = evaluateStopCoverage(
                savedStops,
                Number(item.totalDistanceKm || 0),
                savedFirstLegKm,
                savedFullSafeLegKm
            );

            latestTripContext = {
                start: item.start,
                end: item.end,
                routePath,
                corridorStations: savedStops,
                totalDistanceKm: Number(item.totalDistanceKm || 0),
                firstLegKm: savedFirstLegKm,
                vehicleRangeKm: savedVehicleRangeKm,
                startBattery: savedStartBattery,
                reserveBattery: savedReserveBattery,
                fullSafeLegKm: savedFullSafeLegKm,
                maxDetourKm: Number(item.maxDetourKm || 10),
                requiredStopCount: Number(item.stopCount || savedStops.length || 0),
                isReachable: savedCoverage.isReachable,
                blockingDistanceKm: savedCoverage.blockingDistanceKm,
                selectedStops: sortStationsByProgress(savedStops),
                stops: sortStationsByProgress(savedStops)
            };

            drawRoute(item.start, item.end, routePath, savedStops, savedStops);
            renderRouteSummary(latestTripContext.totalDistanceKm, latestTripContext.firstLegKm, savedStops.length, savedStops.length, {
                vehicleRangeKm: savedVehicleRangeKm,
                startBattery: savedStartBattery,
                reserveBattery: savedReserveBattery,
                isReachable: savedCoverage.isReachable
            });
            renderRouteStops({ isReachable: savedCoverage.isReachable, stops: savedStops, blockingDistanceKm: savedCoverage.blockingDistanceKm }, latestTripContext.totalDistanceKm, latestTripContext.maxDetourKm, savedStops);
            renderRouteTimeline(latestTripContext);

            document.getElementById('routeMapHint').textContent = isSharedRoute
                ? 'Đang xem lộ trình được chia sẻ.'
                : 'Đã mở lại lộ trình từ lịch sử.';
            document.getElementById('routeMapChip').textContent = `${savedStops.length} điểm dừng đã lưu`;
            document.getElementById('routeResultState').textContent = isSharedRoute ? 'Lộ trình chia sẻ' : 'Lộ trình đã lưu';
            document.getElementById('routeNote').innerHTML = isSharedRoute
                ? 'Bạn đang xem lộ trình người khác chia sẻ. Có thể bấm <strong>Đi ngay bằng Google Maps</strong> để sử dụng.'
                : 'Đã mở lại lộ trình cũ. Bạn có thể chỉnh điểm dừng, lưu lại, gắn sao hoặc chia sẻ cho người khác.';

            updateCurrentRouteActionButtons();
            toggleGoNowButton(true);

            document.getElementById('routeMap')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        async function deleteRouteHistory(id) {
            if (!confirm('Bạn có chắc muốn xóa lộ trình này khỏi lịch sử?')) {
                return;
            }

            try {
                await routeApiFetch(`/User/api/routes/${id}`, { method: 'DELETE' });
                routeHistoryState.items = routeHistoryState.items.filter(item => Number(item.id) !== Number(id));

                if (Number(currentRouteHistoryId) === Number(id)) {
                    currentRouteHistoryId = null;
                    currentRouteIsFavorite = false;
                    currentRouteShareUrl = '';
                    hideRouteShareBox();
                    updateCurrentRouteActionButtons();
                }

                renderRouteHistoryList();
            } catch (error) {
                alert(error.message || 'Không xóa được lộ trình.');
            }
        }

        async function markRouteHistoryUsed(id) {
            if (!id || !IS_ROUTE_AUTHENTICATED) return;

            try {
                await routeApiFetch(`/User/api/routes/${id}/used`, { method: 'POST' });
            } catch (error) {
                console.warn(error);
            }
        }

        async function loadSharedRouteFromUrl() {
            const params = new URLSearchParams(window.location.search);
            const token = params.get('share');
            if (!token) return;

            try {
                const response = await fetch(`/User/api/routes/shared/${encodeURIComponent(token)}`);
                const result = await response.json();
                if (!response.ok || !result.success || !result.item) {
                    throw new Error(result.message || 'Không mở được lộ trình chia sẻ.');
                }

                await ensureRouteMapReady();
                applySavedRouteToPage(result.item, true);
            } catch (error) {
                alert(error.message || 'Không mở được lộ trình chia sẻ.');
            }
        }

        async function loadReusableRouteFromQuery() {
            const params = new URLSearchParams(window.location.search);
            const reuseId = Number(params.get('reuseId') || 0);
            if (!reuseId || !IS_ROUTE_AUTHENTICATED) {
                return;
            }

            try {
                const response = await fetch('/User/api/routes/my?take=120');
                const result = await response.json();
                if (!response.ok || !result.success) {
                    return;
                }

                const item = (result.items || []).find(x => Number(x.id) === reuseId);
                if (item) {
                    await ensureRouteMapReady();
                    applySavedRouteToPage(item, false);
                    await routeApiFetch(`/User/api/routes/${reuseId}/used`, { method: 'POST' }).catch(() => null);
                }
            } catch (error) {
                console.warn(error);
            }
        }

        async function loadReusableRouteFromSession() {
            const raw = sessionStorage.getItem('tramSacRouteReuse');
            if (!raw) return;

            try {
                const item = JSON.parse(raw);
                sessionStorage.removeItem('tramSacRouteReuse');

                if (item && item.start && item.end) {
                    await ensureRouteMapReady();
                    applySavedRouteToPage(item, false);
                }
            } catch (error) {
                console.warn(error);
                sessionStorage.removeItem('tramSacRouteReuse');
            }
        }

        function toggleGoNowButton(isVisible) {
            const button = document.getElementById('btnGoNow');
            if (!button) {
                return;
            }

            button.classList.toggle('is-visible', !!isVisible);
            button.disabled = !isVisible;
        }

        function clearRouteVisuals() {
            clearMapObject(startMarker);
            clearMapObject(endMarker);
            clearMapObject(routeLine);
            clearMapObject(focusMarker);

            startMarker = null;
            endMarker = null;
            routeLine = null;
            focusMarker = null;

            corridorMarkers.forEach(clearMapObject);
            stopMarkers.forEach(clearMapObject);

            corridorMarkers = [];
            stopMarkers = [];
        }

        function clearMapObject(mapObject) {
            if (!mapObject || typeof mapObject.setMap !== 'function') {
                return;
            }

            try {
                mapObject.setMap(null);
            } catch (error) {
                console.error('Map4D clear object error:', error);
            }
        }

        function resetRoutePage() {
            resetRouteListFilters();
            resetPlacePicker('start');
            resetPlacePicker('end');
            document.getElementById('startPoint').value = '';
            document.getElementById('endPoint').value = '';
            document.getElementById('vehicleRangeKm').value = '400';
            document.getElementById('startBattery').value = '80';
            document.getElementById('reserveBattery').value = '20';
            document.getElementById('maxDetourKm').value = '10';
            renderRouteSummary(0, 0, 0, 0, { vehicleRangeKm: 400, startBattery: 80, reserveBattery: 20, isReachable: false });
            renderRouteTimeline(null);
            document.getElementById('routeMapHint').textContent = 'Chưa có dữ liệu hành trình.';
            document.getElementById('routeMapChip').textContent = '0 điểm dừng';
            document.getElementById('routeResultState').textContent = 'Chưa lập kế hoạch';
            document.getElementById('routeNote').innerHTML = 'Gợi ý lập kế hoạch: hệ thống ưu tiên trạm <strong>Đang hoạt động</strong>, gần tuyến và đủ để xe luôn giữ lại mức pin dự phòng bạn đã chọn.';
            document.getElementById('routeStopList').innerHTML = '<div class="route-empty">Nhập thông tin chuyến đi để bắt đầu lập kế hoạch.</div>';
            document.getElementById('routeStopPagination').innerHTML = '';
            updateRouteStopToolbarState(0, 0, false);
            updateRouteStopMeta('Nhập thông tin chuyến đi để bắt đầu lập kế hoạch.');

            latestTripContext = null;
            currentRouteHistoryId = null;
            currentRouteIsFavorite = false;
            currentRouteShareUrl = '';
            hideRouteShareBox();
            updateCurrentRouteActionButtons();
            toggleGoNowButton(false);
            clearRouteVisuals();

            if (routeMap) {
                try {
                    if (typeof routeMap.setCenter === 'function') {
                        routeMap.setCenter(DEFAULT_MAP_CENTER);
                    }

                    if (typeof routeMap.setZoom === 'function') {
                        routeMap.setZoom(6);
                    }
                } catch (error) {
                    console.error('Map4D reset camera error:', error);
                }
            }
        }

        function setRouteLoadingState() {
            document.getElementById('routeStopList').innerHTML =
                '<div class="route-loading">Đang tính toán hành trình và tìm trạm gần tuyến...</div>';
            document.getElementById('routeStopPagination').innerHTML = '';
            updateRouteStopToolbarState(0, 0, false);
            updateRouteStopMeta('Đang tính toán hành trình và làm mới danh sách trạm...');
            document.getElementById('routeResultState').textContent = 'Đang xử lý';
            const statusElement = document.getElementById('summaryStatus');
            if (statusElement) {
                statusElement.className = 'route-overview-status is-warning';
                statusElement.innerHTML = '<i class="fa-solid fa-spinner"></i>Đang xử lý';
            }
            const timeline = document.getElementById('routeTimelineList');
            if (timeline) {
                timeline.classList.remove('has-items');
                timeline.innerHTML = '<div class="route-loading">Đang dựng timeline điểm dừng...</div>';
            }
        }

        function setRouteErrorState(message) {
            document.getElementById('routeStopList').innerHTML =
                `<div class="route-error">${escapeHtml(message)}</div>`;
            document.getElementById('routeStopPagination').innerHTML = '';
            updateRouteStopToolbarState(0, 0, false);
            updateRouteStopMeta(escapeHtml(message));
            document.getElementById('routeResultState').textContent = 'Có lỗi';
            const statusElement = document.getElementById('summaryStatus');
            if (statusElement) {
                statusElement.className = 'route-overview-status is-danger';
                statusElement.innerHTML = '<i class="fa-solid fa-circle-xmark"></i>Có lỗi';
            }
            const timeline = document.getElementById('routeTimelineList');
            if (timeline) {
                timeline.classList.remove('has-items');
                timeline.innerHTML = `<div class="route-error">${escapeHtml(message)}</div>`;
            }
            toggleGoNowButton(false);
        }

        function showMapLoadError(message) {
            const mapElement = document.getElementById('routeMap');
            if (!mapElement) {
                return;
            }

            mapElement.classList.add('route-map-failed');
            mapElement.innerHTML = `<div class="route-map-message">${escapeHtml(message)}</div>`;
            document.getElementById('routeMapHint').textContent = 'Bản đồ chưa sẵn sàng.';
        }

        function calculateDistanceKm(lat1, lon1, lat2, lon2) {
            const radiusKm = 6371;
            const dLat = degreesToRadians(lat2 - lat1);
            const dLon = degreesToRadians(lon2 - lon1);
            const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                Math.cos(degreesToRadians(lat1)) * Math.cos(degreesToRadians(lat2)) *
                Math.sin(dLon / 2) * Math.sin(dLon / 2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            return radiusKm * c;
        }

        function degreesToRadians(deg) {
            return deg * (Math.PI / 180);
        }

        function buildSvgMarker(color, text) {
            const markerText = String(text || '').substring(0, 2);
            const markerColor = String(color || '#177b46');
            const svg = `
                <svg xmlns="http://www.w3.org/2000/svg" width="42" height="52" viewBox="0 0 42 52">
                    <path d="M21 0C11.61 0 4 7.61 4 17c0 12.37 17 35 17 35s17-22.63 17-35C38 7.61 30.39 0 21 0z" fill="${markerColor}" />
                    <circle cx="21" cy="17" r="11" fill="white" />
                    <text x="21" y="21" text-anchor="middle" font-size="11" font-family="Arial" font-weight="700" fill="${markerColor}">${markerText}</text>
                </svg>`;

            return `data:image/svg+xml;charset=UTF-8,${encodeURIComponent(svg)}`;
        }

        function escapeHtml(text) {
            return String(text || '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }
    </script>
}
