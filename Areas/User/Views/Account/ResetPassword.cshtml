@model tramsac99.Areas.User.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

@section Styles {
    <style>
        .account-page {
            position: relative;
            z-index: 10;
            padding: 100px 0 70px;
            background: url('/user/assets/images/whatever.jpg') no-repeat center center;
            background-size: cover;
        }

            .account-page::before {
                content: "";
                position: absolute;
                inset: 0;
                background: rgba(15, 23, 42, 0.6);
                z-index: -1;
            }

        .account-card {
            background: rgba(255,255,255,0.96);
            padding: 35px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,.15);
        }
    </style>
}

<div class="sub_banner_outer position-relative user-header-shell">
    @await Html.PartialAsync("_UserHeader")
</div>

<section class="account-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="account-card">
                    <h2 class="text-center mb-4">Đặt lại mật khẩu</h2>

                    <form asp-area="User" asp-controller="Account" asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Token" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="NewPassword"></label>
                            <input asp-for="NewPassword" type="password" class="form-control" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ConfirmPassword"></label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">Cập nhật mật khẩu mới</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="footer-con position-relative">
    <div class="container position-relative">
        <div class="copyright text-center">
            <p class="mb-0">© 2026 TramSac99. All rights reserved.</p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
