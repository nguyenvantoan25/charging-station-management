@model tramsac99.Areas.User.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

@section Styles {
    <style>
        .account-page {
            position: relative;
            z-index: 10;
            padding: 100px 0 70px;
            background: url('/user/assets/images/whatever.jpg') no-repeat center center;
            background-size: cover;
        }

            .account-page::before {
                content: "";
                position: absolute;
                inset: 0;
                background: rgba(15, 23, 42, 0.6);
                z-index: -1;
            }

        .account-card {
            background: rgba(255,255,255,0.96);
            padding: 35px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,.15);
        }

        .account-note {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 20px;
        }
    </style>
}

<div class="sub_banner_outer position-relative user-header-shell">
    @await Html.PartialAsync("_UserHeader")
</div>

<section class="account-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                <div class="account-card">
                    <h2 class="text-center mb-3">Quên mật khẩu</h2>
                    <p class="account-note text-center">
                        Nhập email đã đăng ký. Hệ thống sẽ gửi liên kết đặt lại mật khẩu về email của bạn.
                    </p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }
                    @* link test *@
                    @* @if (TempData["DevResetUrl"] != null)
                    {
                        <div class="alert alert-info">
                            <strong>Link test trên máy local:</strong>
                            <div style="word-break: break-all; margin-top: 6px;">
                                <a href="@TempData["DevResetUrl"]">@TempData["DevResetUrl"]</a>
                            </div>
                            <small>Phần này chỉ hiện khi chạy môi trường Development.</small>
                        </div>
                    } *@

                    <form asp-area="User" asp-controller="Account" asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" placeholder="email@domain.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">Gửi email đặt lại mật khẩu</button>

                        <div class="text-center mt-3">
                            <a asp-area="User" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="footer-con position-relative">
    <div class="container position-relative">
        <div class="copyright text-center">
            <p class="mb-0">© 2026 TramSac99. All rights reserved.</p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

