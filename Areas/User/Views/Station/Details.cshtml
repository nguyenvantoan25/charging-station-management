<div class="sub_banner_outer position-relative user-header-shell">
    @await Html.PartialAsync("_UserHeader")
</div>

<section class="station-detail-page">
    <div class="container">
        @Html.AntiForgeryToken()

        <div class="detail-shell">
            <div class="detail-hero">
                <div class="detail-title-row">
                    <div>
                        <h1 class="detail-title">@Model.Name</h1>
                        <p class="detail-address">@Model.Address</p>
                    </div>

                    <div class="hero-badges">
                        <span class="hero-badge @(Model.Status == "Đang hoạt động" ? "" : "badge-danger-soft")">
                            Trạng thái: @Model.Status
                        </span>
                        <span class="hero-badge">⭐ @Model.AverageRating.ToString("0.0")</span>
                        <span class="hero-badge">@Model.ReviewCount đánh giá</span>
                    </div>
                </div>
            </div>

            <div class="detail-grid">
                <div class="detail-card">
                    <div class="detail-card-header">
                        <h2 class="detail-card-title">Thông tin trạm sạc</h2>
                        <p class="detail-card-subtitle">Tổng quan nhanh về trạm và tình trạng sử dụng hiện tại.</p>
                    </div>

                    <div class="detail-card-body">
                        <div class="info-grid">
                            <div class="info-box">
                                <div class="info-label">Tổng trụ sạc</div>
                                <div class="info-value">@Model.TotalPoleCount</div>
                            </div>

                            <div class="info-box">
                                <div class="info-label">Trụ đang hoạt động</div>
                                <div class="info-value">@Model.AvailablePoleCount</div>
                            </div>

                            <div class="info-box">
                                <div class="info-label">Vĩ độ</div>
                                <div class="info-value info-text">@Model.Latitude.ToString("0.######")</div>
                            </div>

                            <div class="info-box">
                                <div class="info-label">Kinh độ</div>
                                <div class="info-value info-text">@Model.Longitude.ToString("0.######")</div>
                            </div>

                            <div class="info-box">
                                <div class="info-label">Google Maps</div>
                                <div class="info-value info-sub">
                                    <a href="@Model.GoogleMapUrl" target="_blank" rel="noopener noreferrer">Mở bản đồ</a>
                                </div>
                            </div>
                        </div>

                        <div class="summary-line">
                            <span class="summary-pill"><i class="fa-solid fa-bolt"></i> @Model.TotalPoleCount trụ sạc</span>
                            <span class="summary-pill"><i class="fa-solid fa-circle-check"></i> @Model.AvailablePoleCount/@Model.TotalPoleCount trụ đang hoạt động</span>
                            <span class="summary-pill"><i class="fa-solid fa-location-dot"></i> @Model.Latitude.ToString("0.######"), @Model.Longitude.ToString("0.######")</span>
                        </div>
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-card-header">
                        <h2 class="detail-card-title">Thao tác nhanh</h2>
                        <p class="detail-card-subtitle">Chỉ đường, lưu yêu thích và chuyển nhanh sang Google Maps.</p>
                    </div>

                    <div class="detail-card-body">
                        <div class="action-stack">
                            <a href="@($"https://www.google.com/maps/dir/?api=1&destination={Model.Latitude.ToString(CultureInfo.InvariantCulture)},{Model.Longitude.ToString(CultureInfo.InvariantCulture)}")"
                               target="_blank"
                               rel="noopener noreferrer"
                               class="btn btn-success">
                                <i class="fa-solid fa-location-arrow mr-2"></i>Chỉ đường
                            </a>

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <button id="btnToggleFavorite"
                                        type="button"
                                        class="btn @(Model.IsFavorite ? "btn-warning" : "btn-outline-warning")">
                                    <i class="fa-solid fa-heart mr-2"></i>
                                    @(Model.IsFavorite ? "Bỏ yêu thích" : "Thêm vào yêu thích")
                                </button>

                                <a asp-area="User"
                                   asp-controller="Station"
                                   asp-action="Favorites"
                                   class="btn btn-outline-dark">
                                    <i class="fa-solid fa-bookmark mr-2"></i>Xem trạm yêu thích
                                </a>
                            }
                            else
                            {
                                <a asp-area="User"
                                   asp-controller="Account"
                                   asp-action="Login"
                                   asp-route-returnUrl="@returnUrl"
                                   class="btn btn-outline-warning">
                                    <i class="fa-solid fa-heart mr-2"></i>Đăng nhập để yêu thích
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-card-header">
                    <h2 class="detail-card-title">Bản đồ trạm sạc</h2>
                    <p class="detail-card-subtitle">Vị trí chính xác của trạm trên bản đồ.</p>
                </div>

                <div class="detail-card-body">
                    <div id="detailMap"></div>
                </div>
            </div>

            <div class="detail-card">
                <div class="detail-card-header">
                    <h2 class="detail-card-title">Danh sách trụ sạc</h2>
                    <p class="detail-card-subtitle">Chi tiết các trụ thuộc trạm này.</p>
                </div>

                <div class="detail-card-body">
                    @if (Model.Poles.Any())
                    {
                        <div class="pole-list">
                            @foreach (var pole in Model.Poles)
                            {
                                <div class="pole-card">
                                    <div class="pole-header">
                                        <div>
                                            <div class="pole-title">@pole.PoleCode</div>
                                            <div class="pole-meta">
                                                Công suất tối đa: @(string.IsNullOrWhiteSpace(pole.MaxPower) ? "-" : pole.MaxPower)
                                            </div>
                                        </div>

                                        <div class="pole-status">@pole.Status</div>
                                    </div>

                                    <div class="pole-body">
                                        @if (!string.IsNullOrWhiteSpace(pole.Note))
                                        {
                                            <div class="pole-note">
                                                <strong>Ghi chú:</strong> @pole.Note
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">Trạm này chưa có dữ liệu trụ sạc.</div>
                    }
                </div>
            </div>

            <div class="detail-grid">
                <div class="detail-card">
                    <div class="detail-card-header">
                        <h2 class="detail-card-title">Gửi đánh giá</h2>
                        <p class="detail-card-subtitle">Chia sẻ trải nghiệm thực tế của bạn tại trạm sạc này.</p>
                    </div>

                    <div class="detail-card-body">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form id="reviewForm" class="review-form-shell">
                                <input type="hidden" id="StationId" name="StationId" value="@Model.Id" />

                                @if (Model.HasReviewed)
                                {
                                    <div class="empty-box mb-3">
                                        Bạn đã có đánh giá ở trạm này. Bạn có thể sửa lại ngay tại đây hoặc vào mục lịch sử đánh giá để chỉnh sửa sau.
                                    </div>
                                }

                                <div>
                                    <label class="font-weight-bold mb-2 d-block">Chấm sao</label>
                                    <div class="star-input">
                                        <input type="radio" id="star5" name="Rating" value="5" @(Model.CurrentUserRating == 5 ? "checked" : "") required />
                                        <label for="star5"><i class="fa-solid fa-star"></i></label>

                                        <input type="radio" id="star4" name="Rating" value="4" @(Model.CurrentUserRating == 4 ? "checked" : "") />
                                        <label for="star4"><i class="fa-solid fa-star"></i></label>

                                        <input type="radio" id="star3" name="Rating" value="3" @(Model.CurrentUserRating == 3 ? "checked" : "") />
                                        <label for="star3"><i class="fa-solid fa-star"></i></label>

                                        <input type="radio" id="star2" name="Rating" value="2" @(Model.CurrentUserRating == 2 ? "checked" : "") />
                                        <label for="star2"><i class="fa-solid fa-star"></i></label>

                                        <input type="radio" id="star1" name="Rating" value="1" @(Model.CurrentUserRating == 1 ? "checked" : "") />
                                        <label for="star1"><i class="fa-solid fa-star"></i></label>
                                    </div>
                                </div>

                                <div>
                                    <label class="font-weight-bold mb-2">Bình luận</label>
                                    <textarea id="Comment"
                                          name="Comment"
                                          class="form-control"
                                          rows="6"
                                          placeholder="Chia sẻ trải nghiệm của bạn tại trạm này">@Model.CurrentUserComment</textarea>
                                </div>

                                <button id="btnSubmitReview" type="submit" class="btn btn-success">
                                    <i class="fa-solid @(Model.HasReviewed ? "fa-pen-to-square" : "fa-paper-plane") mr-2"></i>@(Model.HasReviewed ? "Cập nhật đánh giá" : "Gửi đánh giá")
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="login-box">
                                Bạn cần đăng nhập để gửi đánh giá cho trạm này.
                            </div>

                            <a asp-area="User"
                               asp-controller="Account"
                               asp-action="Login"
                               asp-route-returnUrl="@returnUrl"
                               class="btn btn-success btn-block mt-3">
                                Đăng nhập ngay
                            </a>
                        }
                    </div>
                </div>

                <div class="detail-card">
                    <div class="detail-card-header">
                        <h2 class="detail-card-title">Đánh giá từ người dùng</h2>
                        <p class="detail-card-subtitle">Những chia sẻ mới nhất từ người đã sử dụng trạm.</p>
                    </div>

                    <div class="detail-card-body">
                        @if (Model.Reviews.Any())
                        {
                            <div class="review-list">
                                @foreach (var review in Model.Reviews)
                                {
                                    <div class="review-item">
                                        <div class="review-top">
                                            <div class="review-user">@review.UserName</div>
                                            <div class="review-time">
                                                @((review.UpdatedAt ?? review.CreatedAt).ToString("dd/MM/yyyy HH:mm"))
                                                @if (review.IsEdited)
                                                {
                                                    <span>- đã chỉnh sửa</span>
                                                }
                                            </div>
                                        </div>

                                        <div class="review-rating">⭐ @review.Rating</div>
                                        <p class="review-comment">@review.Comment</p>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="empty-box">Chưa có đánh giá nào cho trạm này.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="detailPageData"
     data-station-id="@Model.Id"
     data-lat="@Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
     data-lng="@Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
     data-name="@Model.Name"
     data-address="@Model.Address">
</div>

@section Scripts {
    <script>
        const MAP4D_API_KEY = '@(Configuration["Map4D:ApiKey"] ?? "")';
        // const stationLat = @Html.Raw(Model.Latitude.ToString(CultureInfo.InvariantCulture));
        // const stationLng = @Html.Raw(Model.Longitude.ToString(CultureInfo.InvariantCulture));
        // const stationName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name ?? ""));
        // const stationAddress = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Address ?? ""));
                // Why changed: read Razor values from data attributes to avoid JS parser warnings in .cshtml.
        const detailPageData = document.getElementById('detailPageData');
        const stationId = Number(detailPageData?.dataset.stationId || 0);
        const stationLat = Number(detailPageData?.dataset.lat || 0);
        const stationLng = Number(detailPageData?.dataset.lng || 0);
        const stationName = detailPageData?.dataset.name || '';
        const stationAddress = detailPageData?.dataset.address || '';

        document.addEventListener('DOMContentLoaded', async function () {
            await initDetailMap();
        });

        async function initDetailMap() {
            const mapElement = document.getElementById('detailMap');
            if (!mapElement) return;

            try {
                await TramSacMap4D.ensureSdk(MAP4D_API_KEY);

                const map = new map4d.Map(mapElement, {
                    center: { lat: stationLat, lng: stationLng },
                    zoom: 15,
                    controls: true
                });

                const marker = TramSacMap4D.createMarker(map, {
                    position: { lat: stationLat, lng: stationLng },
                    title: stationName || 'Trạm sạc'
                });

                if (typeof marker.setTitle === 'function') {
                    marker.setTitle(`${stationName} - ${stationAddress}`);
                }
            } catch (error) {
                console.error(error);
                mapElement.innerHTML = '<div class="empty-box">Không tải được bản đồ Map4D.</div>';
            }
        }

        function escapeHtml(text) {
            return String(text ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        const favoriteButton = document.getElementById('btnToggleFavorite');
        if (favoriteButton) {
            favoriteButton.addEventListener('click', toggleFavoriteDetail);
        }

        async function toggleFavoriteDetail() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            if (!token) {
                alert('Thiếu anti-forgery token.');
                return;
            }

            try {
                const response = await fetch(`/User/api/favorites/${stationId}/toggle`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                const result = await response.json();

                if (!response.ok || !result.success) {
                    alert(result.message || 'Không thể cập nhật yêu thích.');
                    return;
                }

                favoriteButton.innerHTML = result.isFavorite
                    ? '<i class="fa-solid fa-heart mr-2"></i>Bỏ yêu thích'
                    : '<i class="fa-solid fa-heart mr-2"></i>Thêm vào yêu thích';

                favoriteButton.classList.remove('btn-warning', 'btn-outline-warning');
                favoriteButton.classList.add(result.isFavorite ? 'btn-warning' : 'btn-outline-warning');
            } catch (error) {
                console.error(error);
                alert('Có lỗi xảy ra khi cập nhật yêu thích.');
            }
        }

        const reviewForm = document.getElementById('reviewForm');
        if (reviewForm) {
            reviewForm.addEventListener('submit', async function (e) {
                e.preventDefault();

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                if (!token) {
                    alert('Thiếu anti-forgery token.');
                    return;
                }

                const formData = new FormData(reviewForm);

                try {
                    const response = await fetch('/User/Station/AddReviewAjax', {
                        method: 'POST',
                        headers: {
                            'Accept': 'application/json',
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            StationId: Number(formData.get('StationId')),
                            Rating: Number(formData.get('Rating')),
                            Comment: formData.get('Comment')
                        })
                    });

                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        alert(result.message || 'Có lỗi xảy ra khi gửi đánh giá.');
                        return;
                    }

                    alert(result.message || 'Gửi đánh giá thành công.');
                    window.location.reload();
                } catch (error) {
                    console.error(error);
                    alert('Có lỗi xảy ra khi gửi đánh giá.');
                }
            });
        }
    </script>
}
